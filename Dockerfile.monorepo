# syntax=docker/dockerfile:1.7
FROM node:20.10.0-slim

ENV SKIP_DIDKIT_NAPI=1
ENV MONGOMS_DISABLE_POSTINSTALL=1

WORKDIR /app

RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    python3 \
    && npm install -g bun@1.3.14

COPY package.json bun.lock bunfig.toml nx.json tsconfig.json .gitignore .nxignore ./
COPY tools/executors/workspace/run-command tools/executors/workspace/run-command
COPY reference/package.json reference/
COPY scripts/siwa-migration/package.json scripts/siwa-migration/
COPY tools/capgo tools/capgo

COPY services/learn-card-network/lca-api/package.json services/learn-card-network/lca-api/
COPY packages/lca-api-client/package.json packages/lca-api-client/
COPY packages/plugins/lca-api-plugin/package.json packages/plugins/lca-api-plugin/
COPY packages/learn-card-helpers/package.json packages/learn-card-helpers/
COPY packages/react-learn-card/package.json packages/react-learn-card/
COPY packages/learn-card-base/package.json packages/learn-card-base/
COPY packages/learn-card-types/package.json packages/learn-card-types/
COPY packages/learn-card-init/package.json packages/learn-card-init/
COPY packages/learn-card-core/package.json packages/learn-card-core/
COPY packages/learn-card-network/brain-client/package.json packages/learn-card-network/brain-client/
COPY packages/learn-card-network/cloud-client/package.json packages/learn-card-network/cloud-client/
COPY packages/learn-card-network/simple-signing-client/package.json packages/learn-card-network/simple-signing-client/
COPY services/learn-card-network/brain-service/package.json services/learn-card-network/brain-service/
COPY services/learn-card-network/learn-cloud-service/package.json services/learn-card-network/learn-cloud-service/
COPY services/learn-card-network/simple-signing-service/package.json services/learn-card-network/simple-signing-service/
COPY packages/plugins/chapi/package.json packages/plugins/chapi/
COPY packages/plugins/crypto/package.json packages/plugins/crypto/
COPY packages/plugins/ceramic/package.json packages/plugins/ceramic/
COPY packages/plugins/idx/package.json packages/plugins/idx/
COPY packages/plugins/didkey/package.json packages/plugins/didkey/
COPY packages/plugins/didkit/package.json packages/plugins/didkit/
COPY packages/plugins/didkit-plugin-node/package.json packages/plugins/didkit-plugin-node/
COPY packages/plugins/did-web-plugin/package.json packages/plugins/did-web-plugin/
COPY packages/plugins/dynamic-loader/package.json packages/plugins/dynamic-loader/
COPY packages/plugins/encryption/package.json packages/plugins/encryption/
COPY packages/plugins/ethereum/package.json packages/plugins/ethereum/
COPY packages/plugins/expiration/package.json packages/plugins/expiration/
COPY packages/plugins/learn-card/package.json packages/plugins/learn-card/
COPY packages/plugins/learn-card-network/package.json packages/plugins/learn-card-network/
COPY packages/plugins/ler-rs/package.json packages/plugins/ler-rs/
COPY packages/plugins/render-method/package.json packages/plugins/render-method/
COPY packages/plugins/open-badge-v2/package.json packages/plugins/open-badge-v2/
COPY packages/plugins/openid4vc/package.json packages/plugins/openid4vc/
COPY packages/plugins/sd-jwt-vc/package.json packages/plugins/sd-jwt-vc/
COPY packages/plugins/vc/package.json packages/plugins/vc/
COPY packages/plugins/vc-api/package.json packages/plugins/vc-api/
COPY packages/plugins/vc-templates/package.json packages/plugins/vc-templates/
COPY packages/plugins/vpqr/package.json packages/plugins/vpqr/
COPY packages/plugins/simple-signing-plugin/package.json packages/plugins/simple-signing-plugin/
COPY packages/learn-card-embed-sdk/package.json packages/learn-card-embed-sdk/
COPY packages/credential-library/package.json packages/credential-library/
COPY apps/learn-card-app/package.json apps/learn-card-app/
COPY packages/sss-key-manager/package.json packages/sss-key-manager/
COPY packages/email-templates/package.json packages/email-templates/
COPY apps/scouts/package.json apps/scouts/
COPY examples/chapi-example/package.json examples/chapi-example/
COPY examples/consent-flow-test/package.json examples/consent-flow-test/
COPY examples/credential-viewer/package.json examples/credential-viewer/
COPY examples/embed-example/package.json examples/embed-example/
COPY examples/openid4vc-playground/package.json examples/openid4vc-playground/
COPY examples/snap-chapi-example/package.json examples/snap-chapi-example/
COPY examples/snap-example-dapp/package.json examples/snap-example-dapp/
COPY examples/app-store-apps/1-basic-launchpad-app/package.json examples/app-store-apps/1-basic-launchpad-app/
COPY examples/app-store-apps/2-lore-card-app/package.json examples/app-store-apps/2-lore-card-app/
COPY examples/app-store-apps/3-mozilla-social-badges-app/package.json examples/app-store-apps/3-mozilla-social-badges-app/
COPY examples/app-store-apps/4-request-learner-context-app/package.json examples/app-store-apps/4-request-learner-context-app/
COPY examples/app-store-apps/5-northstar-learning/package.json examples/app-store-apps/5-northstar-learning/
COPY packages/holder-continuity-bundle/package.json packages/holder-continuity-bundle/
COPY packages/learn-card-bridge-http/package.json packages/learn-card-bridge-http/
COPY packages/learn-card-cli/package.json packages/learn-card-cli/
COPY packages/learn-card-partner-connect-sdk/package.json packages/learn-card-partner-connect-sdk/
COPY packages/plugins/claimable-boosts/package.json packages/plugins/claimable-boosts/
COPY packages/render-method-templates/package.json packages/render-method-templates/
COPY services/learn-card-discord-bot/package.json services/learn-card-discord-bot/
COPY services/meta-mask-snap/package.json services/meta-mask-snap/
COPY services/playwright-delete-service/package.json services/playwright-delete-service/
COPY tests/benchmarking/package.json tests/benchmarking/
COPY tests/e2e/package.json tests/e2e/
COPY tests/federation-e2e/package.json tests/federation-e2e/
COPY tests/openid4vc-e2e/package.json tests/openid4vc-e2e/
COPY tests/openid4vc-interop-e2e/package.json tests/openid4vc-interop-e2e/
COPY tests/smoketests/package.json tests/smoketests/
RUN --mount=type=bind,source=.,target=/src,ro \
    mkdir -p packages/plugins/linked-claims packages/plugins/learn-cloud && \
    cp /src/packages/plugins/linked-claims/package.json packages/plugins/linked-claims/ && \
    cp /src/packages/plugins/learn-cloud/package.json packages/plugins/learn-cloud/ && \
    cp /src/packages/plugins/learn-cloud/project.json packages/plugins/learn-cloud/

RUN --mount=type=cache,id=bun-cache,target=/root/.bun/install/cache \
    bun install --ignore-scripts --frozen-lockfile --linker=hoisted --backend=copyfile && \
    # Keep one canonical dependency tree at /app/node_modules. Bun may create
    # package-local node_modules directories/symlinks for workspaces; some Docker
    # Desktop/BuildKit versions hit "max depth exceeded" while snapshotting or
    # creating containers from those workspace-local trees.
    rm -rf \
    apps/*/node_modules \
    examples/*/node_modules \
    examples/app-store-apps/*/node_modules \
    packages/*/node_modules \
    packages/*/*/node_modules \
    services/*/node_modules \
    services/*/*/node_modules \
    tests/*/node_modules

COPY services/learn-card-network/lca-api/project.json services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/esbuild-docker.mjs services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/esbuild.mjs services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/esbuildPlugins.cjs services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/lambda.ts services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/serverless-local.yml services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/serverless.yml services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/src services/learn-card-network/lca-api/src
COPY services/learn-card-network/lca-api/test services/learn-card-network/lca-api/test
COPY services/learn-card-network/lca-api/tsconfig.build.json services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/tsconfig.json services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/vite.config.ts services/learn-card-network/lca-api/
COPY services/learn-card-network/lca-api/vitest-setup.ts services/learn-card-network/lca-api/
COPY packages/lca-api-client packages/lca-api-client
COPY packages/plugins/lca-api-plugin packages/plugins/lca-api-plugin
COPY packages/learn-card-helpers packages/learn-card-helpers
COPY packages/react-learn-card packages/react-learn-card
COPY packages/learn-card-base packages/learn-card-base
COPY packages/learn-card-types packages/learn-card-types
COPY packages/learn-card-init packages/learn-card-init
COPY packages/learn-card-core packages/learn-card-core
COPY packages/learn-card-network/brain-client packages/learn-card-network/brain-client
COPY packages/learn-card-network/cloud-client packages/learn-card-network/cloud-client
COPY packages/learn-card-network/simple-signing-client packages/learn-card-network/simple-signing-client
COPY services/learn-card-network/brain-service services/learn-card-network/brain-service
COPY services/learn-card-network/learn-cloud-service services/learn-card-network/learn-cloud-service
COPY services/learn-card-network/simple-signing-service services/learn-card-network/simple-signing-service
RUN --mount=type=bind,source=packages/plugins,target=/src/plugins,ro \
    set -eu; \
    copy_plugin() { \
    pkg="$1"; \
    mkdir -p "packages/plugins/$pkg/scripts" "packages/plugins/$pkg/src"; \
    for file in package.json project.json tsconfig.json; do \
    if [ -f "/src/plugins/$pkg/$file" ]; then \
    cp "/src/plugins/$pkg/$file" "packages/plugins/$pkg/"; \
    fi; \
    done; \
    if [ -d "/src/plugins/$pkg/scripts" ]; then \
    cp -R "/src/plugins/$pkg/scripts/." "packages/plugins/$pkg/scripts/"; \
    fi; \
    if [ -d "/src/plugins/$pkg/src" ]; then \
    cp -R "/src/plugins/$pkg/src/." "packages/plugins/$pkg/src/"; \
    fi; \
    }; \
    copy_plugin chapi; \
    copy_plugin crypto; \
    copy_plugin ceramic; \
    copy_plugin idx; \
    copy_plugin didkey; \
    copy_plugin didkit; \
    copy_plugin didkit-plugin-node; \
    copy_plugin did-web-plugin; \
    copy_plugin dynamic-loader; \
    copy_plugin encryption; \
    copy_plugin ethereum; \
    copy_plugin expiration; \
    copy_plugin learn-card; \
    copy_plugin learn-card-network; \
    copy_plugin ler-rs; \
    copy_plugin render-method; \
    copy_plugin simple-signing-plugin
RUN --mount=type=bind,source=packages/plugins/vpqr,target=/src/vpqr,ro \
    mkdir -p packages/plugins/vpqr/scripts packages/plugins/vpqr/src && \
    cp /src/vpqr/package.json packages/plugins/vpqr/ && \
    cp /src/vpqr/project.json packages/plugins/vpqr/ && \
    cp /src/vpqr/tsconfig.json packages/plugins/vpqr/ && \
    cp -R /src/vpqr/scripts/. packages/plugins/vpqr/scripts/ && \
    cp -R /src/vpqr/src/. packages/plugins/vpqr/src/
RUN --mount=type=bind,source=packages/plugins/vc-templates,target=/src/vc-templates,ro \
    mkdir -p packages/plugins/vc-templates/scripts packages/plugins/vc-templates/src && \
    cp /src/vc-templates/package.json packages/plugins/vc-templates/ && \
    cp /src/vc-templates/project.json packages/plugins/vc-templates/ && \
    cp /src/vc-templates/tsconfig.json packages/plugins/vc-templates/ && \
    cp -R /src/vc-templates/scripts/. packages/plugins/vc-templates/scripts/ && \
    cp -R /src/vc-templates/src/. packages/plugins/vc-templates/src/
RUN --mount=type=bind,source=packages/plugins/vc-api,target=/src/vc-api,ro \
    mkdir -p packages/plugins/vc-api/scripts packages/plugins/vc-api/src && \
    cp /src/vc-api/package.json packages/plugins/vc-api/ && \
    cp /src/vc-api/project.json packages/plugins/vc-api/ && \
    cp /src/vc-api/tsconfig.json packages/plugins/vc-api/ && \
    cp -R /src/vc-api/scripts/. packages/plugins/vc-api/scripts/ && \
    cp -R /src/vc-api/src/. packages/plugins/vc-api/src/
RUN --mount=type=bind,source=packages/plugins/vc,target=/src/vc,ro \
    mkdir -p packages/plugins/vc/scripts packages/plugins/vc/src && \
    cp /src/vc/package.json packages/plugins/vc/ && \
    cp /src/vc/project.json packages/plugins/vc/ && \
    cp /src/vc/tsconfig.json packages/plugins/vc/ && \
    cp -R /src/vc/scripts/. packages/plugins/vc/scripts/ && \
    cp -R /src/vc/src/. packages/plugins/vc/src/
RUN --mount=type=bind,source=packages/plugins/sd-jwt-vc,target=/src/sd-jwt-vc,ro \
    mkdir -p packages/plugins/sd-jwt-vc/scripts packages/plugins/sd-jwt-vc/src && \
    cp /src/sd-jwt-vc/package.json packages/plugins/sd-jwt-vc/ && \
    cp /src/sd-jwt-vc/project.json packages/plugins/sd-jwt-vc/ && \
    cp /src/sd-jwt-vc/tsconfig.json packages/plugins/sd-jwt-vc/ && \
    cp -R /src/sd-jwt-vc/scripts/. packages/plugins/sd-jwt-vc/scripts/ && \
    cp -R /src/sd-jwt-vc/src/. packages/plugins/sd-jwt-vc/src/
RUN --mount=type=bind,source=packages/plugins/openid4vc,target=/src/openid4vc,ro \
    mkdir -p packages/plugins/openid4vc/scripts packages/plugins/openid4vc/src && \
    cp /src/openid4vc/package.json packages/plugins/openid4vc/ && \
    cp /src/openid4vc/project.json packages/plugins/openid4vc/ && \
    cp /src/openid4vc/tsconfig.json packages/plugins/openid4vc/ && \
    cp -R /src/openid4vc/scripts/. packages/plugins/openid4vc/scripts/ && \
    cp -R /src/openid4vc/src/. packages/plugins/openid4vc/src/
RUN --mount=type=bind,source=packages/plugins/open-badge-v2,target=/src/open-badge-v2,ro \
    mkdir -p packages/plugins/open-badge-v2/scripts packages/plugins/open-badge-v2/src && \
    cp /src/open-badge-v2/package.json packages/plugins/open-badge-v2/ && \
    cp /src/open-badge-v2/project.json packages/plugins/open-badge-v2/ && \
    cp /src/open-badge-v2/tsconfig.json packages/plugins/open-badge-v2/ && \
    cp /src/open-badge-v2/scripts/build.mjs packages/plugins/open-badge-v2/scripts/ && \
    cp /src/open-badge-v2/scripts/mixedEntypoint.js packages/plugins/open-badge-v2/scripts/ && \
    cp /src/open-badge-v2/src/index.ts packages/plugins/open-badge-v2/src/ && \
    cp /src/open-badge-v2/src/plugin.ts packages/plugins/open-badge-v2/src/ && \
    cp /src/open-badge-v2/src/types.ts packages/plugins/open-badge-v2/src/
RUN --mount=type=bind,source=.,target=/src,ro \
    mkdir -p packages/plugins/linked-claims/scripts packages/plugins/linked-claims/src packages/plugins/learn-cloud/scripts packages/plugins/learn-cloud/src && \
    cp /src/packages/plugins/linked-claims/jest.config.cjs packages/plugins/linked-claims/ && \
    cp /src/packages/plugins/linked-claims/tsconfig.json packages/plugins/linked-claims/ && \
    cp /src/packages/plugins/linked-claims/scripts/build.mjs packages/plugins/linked-claims/scripts/ && \
    cp /src/packages/plugins/linked-claims/scripts/mixedEntypoint.js packages/plugins/linked-claims/scripts/ && \
    cp /src/packages/plugins/linked-claims/src/index.ts packages/plugins/linked-claims/src/ && \
    cp /src/packages/plugins/linked-claims/src/types.ts packages/plugins/linked-claims/src/ && \
    cp /src/packages/plugins/learn-cloud/jest.config.cjs packages/plugins/learn-cloud/ && \
    cp /src/packages/plugins/learn-cloud/tsconfig.json packages/plugins/learn-cloud/ && \
    cp /src/packages/plugins/learn-cloud/scripts/build.mjs packages/plugins/learn-cloud/scripts/ && \
    cp /src/packages/plugins/learn-cloud/scripts/mixedEntypoint.js packages/plugins/learn-cloud/scripts/ && \
    cp /src/packages/plugins/learn-cloud/src/index.ts packages/plugins/learn-cloud/src/ && \
    cp /src/packages/plugins/learn-cloud/src/helpers.ts packages/plugins/learn-cloud/src/ && \
    cp /src/packages/plugins/learn-cloud/src/plugin.ts packages/plugins/learn-cloud/src/ && \
    cp /src/packages/plugins/learn-cloud/src/types.ts packages/plugins/learn-cloud/src/
# Final pass: remove any workspace-local node_modules trees without relying on
# shell glob expansion over deep workspace paths.
RUN find apps examples packages services tests -name node_modules -prune -exec rm -rf {} +

RUN chmod -R a+rwX apps/learn-card-app

# Local Docker dev and PR previews bind-mount app/package sources over these
# paths. Do not copy learn-card-app, credential-library, sss-key-manager,
# email-templates, or embed-sdk source into the image: some Docker
# Desktop/BuildKit builds recurse through Bun workspace symlinks when those
# paths are copied and fail with "max depth exceeded". package.json files are
# still copied before bun install so workspace resolution remains valid.

