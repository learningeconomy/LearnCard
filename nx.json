{
    "targetDefaults": {
        "start": {
            "dependsOn": ["^build"]
        },
        "dev": {
            "dependsOn": ["^build"]
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["{projectRoot}/dist"],
            "cache": true
        },
        "test": {
            "dependsOn": ["^build", "^test"],
            "outputs": ["{projectRoot}/coverage"],
            "cache": true
        }
    },
    "defaultBase": "main",
    "analytics": false,
    "cacheDirectory": ".nx-cache",
    "useInferencePlugins": false
}
