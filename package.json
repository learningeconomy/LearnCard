{
    "name": "learncard-monorepo",
    "private": true,
    "version": "1.0.1",
    "workspaces": [
        "apps/*",
        "reference*",
        "examples/*",
        "examples/app-store-apps/*",
        "packages/*",
        "packages/learn-card-network/*",
        "packages/plugins/*",
        "scripts/*",
        "services/*",
        "services/learn-card-network/*",
        "tests/*",
        "tools/executors/workspace/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/learningeconomy/LearnCard"
    },
    "scripts": {
        "prepare": "husky install",
        "lint:staged": "lint-staged",
        "build": "nx run-many -t build --all --exclude=docs,reference,chapi-example,snap-chapi-example,snap-example-dapp",
        "build:bootstrap": "nx run-many -t build --projects=types,helpers,core,vc-plugin,email-templates",
        "test:e2e": "nx run e2e:test:e2e",
        "run-network-tests": "nx run network-brain-service:build && bun run --cwd services/learn-card-network/brain-service test",
        "validate-packages": "node scripts/validate-packages.mjs",
        "env:pull": "bash scripts/pull-env.sh",
        "env:backup": "bash scripts/backup-env.sh",
        "env:compare-backup": "bash scripts/compare-env-backup.sh",
        "env:compare-infisical": "bash scripts/compare-env-infisical.sh"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.3",
        "@changesets/changelog-github": "^0.4.8",
        "@changesets/cli": "^2.26.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^18.19.68",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.0.6",
        "@types/react-router-dom": "^5.3.3",
        "@typescript-eslint/eslint-plugin": "^5.54.0",
        "@typescript-eslint/parser": "^5.54.0",
        "esbuild-jest": "^0.5.0",
        "eslint": "^8.35.0",
        "eslint-config-airbnb-typescript": "^17.0.0",
        "eslint-import-resolver-typescript": "^2.7.1",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.32.2",
        "husky": "8.0.3",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^29.5.0",
        "jest-silent-reporter": "^0.5.0",
        "lint-staged": "13.3.0",
        "node-gyp": "^12.2.0",
        "nx": "16.1.4",
        "prettier": "^2.8.4",
        "prettier-plugin-astro": "^0.5.5",
        "publint": "^0.3.21",
        "shx": "^0.3.4",
        "ts-jest": "^29.0.5",
        "vite-tsconfig-paths": "^4.3.2",
        "vitest": "^1.4.0"
    },
    "dependencies": {
        "@ionic/react": "8.7.2",
        "@ionic/react-router": "8.7.2",
        "@radix-ui/react-popover": "1.0.7",
        "@tanstack/query-async-storage-persister": "^5.54.1",
        "@tanstack/query-sync-storage-persister": "^5.54.1",
        "@tanstack/react-query": "^5.54.1",
        "@tanstack/react-query-devtools": "^5.54.1",
        "@tanstack/react-query-persist-client": "^5.54.1",
        "@traversable/zod": "^0.0.57",
        "core-js": "^3.25.1",
        "firebase": "12.8.0",
        "history": "4.10.1",
        "launchdarkly-react-client-sdk": "^3.0.1",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router": "5.3.3",
        "react-router-dom": "5.3.3",
        "regenerator-runtime": "0.13.7",
        "tslib": "^2.4.0",
        "typescript": "5.9.3",
        "zod": "4.1.13",
        "zod-openapi": "5.4.5"
    },
    "overrides": {
        "fastify": "5.7.2",
        "pvutils": "1.0.17",
        "did-jwt": "5.9.0",
        "typescript": "5.6.2",
        "uint8arrays": "^3.0.0",
        "serverless": "3.40.0",
        "zod": "4.1.13",
        "astro>zod": "3.25.76",
        "zod-openapi": "5.4.5",
        "trpc-to-openapi": "3.1.0",
        "@ceramicnetwork/streamid": "2.7.0",
        "@ionic/react": "8.7.2",
        "@ionic/react-router": "8.7.2",
        "history": "4.10.1",
        "react-router": "5.3.3",
        "react-router-dom": "5.3.3",
        "@types/minimatch": "5.1.2",
        "next": "15.5.18",
        "protobufjs": "7.6.3",
        "jsonpath-plus": "10.3.0",
        "simple-git": "3.36.0",
        "handlebars": "4.7.9",
        "fast-xml-parser@4": "5.8.0",
        "fast-xml-parser@5": "5.8.0",
        "basic-ftp": "5.3.1",
        "sharp": "0.34.5",
        "jspdf": "4.2.1",
        "swiper": "12.1.2"
    },
    "packageManager": "bun@1.3.14",
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,md,yml,yaml,css,html}": [
            "prettier --write"
        ]
    }
}
