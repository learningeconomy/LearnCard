# Exclude Rust build artifacts to save massive amounts of space
lib/didkit/target
lib/ssi/target

scripts/siwa-migration
reference

# Dependencies (copied selectively in Dockerfiles)
node_modules
**/node_modules
node_modules/**
**/node_modules/**
# Docker Desktop/BuildKit can still traverse package-local Bun workspace
# symlinks during path-specific COPY instructions unless the workspace
# node_modules directories are matched explicitly.
**/node_modules/
**/node_modules/*
packages/*/node_modules
packages/*/node_modules/**
packages/*/*/node_modules
packages/*/*/node_modules/**
packages/*/*/*/node_modules
packages/*/*/*/node_modules/**
packages/plugins/learn-cloud/node_modules
packages/plugins/learn-cloud/node_modules/**
packages/plugins/linked-claims/node_modules
packages/plugins/linked-claims/node_modules/**
packages/plugins/learn-cloud/**
!packages/plugins/learn-cloud/
!packages/plugins/learn-cloud/package.json
!packages/plugins/learn-cloud/project.json
!packages/plugins/learn-cloud/jest.config.cjs
!packages/plugins/learn-cloud/tsconfig.json
!packages/plugins/learn-cloud/scripts/
!packages/plugins/learn-cloud/scripts/**
!packages/plugins/learn-cloud/src/
!packages/plugins/learn-cloud/src/**
packages/plugins/linked-claims/**
!packages/plugins/linked-claims/
!packages/plugins/linked-claims/package.json
!packages/plugins/linked-claims/project.json
!packages/plugins/linked-claims/jest.config.cjs
!packages/plugins/linked-claims/tsconfig.json
!packages/plugins/linked-claims/scripts/
!packages/plugins/linked-claims/scripts/**
!packages/plugins/linked-claims/src/
!packages/plugins/linked-claims/src/**
apps/*/node_modules
apps/*/node_modules/**
services/*/node_modules
services/*/node_modules/**
services/*/*/node_modules
services/*/*/node_modules/**

# Build outputs
**/dist
**/build
**/.next
**/.turbo
**/.nx

# The Pathways module owns a `src/pages/pathways/build/` subtree (the
# "Build mode" — authoring UI, policy editors, history reducer, etc.).
# It is *source*, not output; without this negation the `**/build` line
# above silently strips it from the Docker context and Rollup fails to
# resolve `./build/BuildMode` from `PathwaysShell.tsx` at image-build time.
!**/pages/pathways/build
!**/pages/pathways/build/**

# Common exclusions
*.log
.git
.github
docs
examples
!examples/
!examples/**/
!examples/**/package.json
*.md
.vscode
.idea
.changeset

# Test artifacts
**/*.test.ts
**/*.spec.ts
**/coverage
**/__tests__
**/playwright-report
**/test-results

# Native build artifacts
**/*.node
**/native/target
