{
    "name": "smoketests",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "tests/smoketests",
    "projectType": "application",
    "targets": {
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "bun run test",
                "cwd": "tests/smoketests"
            }
        },
        "smoke": {
            "executor": "nx:run-commands",
            "options": {
                "command": "bun run smoke",
                "cwd": "tests/smoketests"
            }
        },
        "smoke:api": {
            "executor": "nx:run-commands",
            "options": {
                "command": "bun run smoke:api",
                "cwd": "tests/smoketests"
            }
        },
        "smoke:browser": {
            "executor": "nx:run-commands",
            "options": {
                "command": "bun run smoke:browser",
                "cwd": "tests/smoketests"
            }
        }
    }
}
