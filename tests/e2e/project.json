{
    "name": "e2e",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "tests/e2e/tests",
    "projectType": "application",
    "tags": [],
    "implicitDependencies": ["init", "helpers", "simple-signing-plugin", "nx-run-command"],
    "namedInputs": {
        "tests": ["{projectRoot}/tests/**/*"]
    },
    "targets": {
        "test": {
            "executor": "./tools/executors/workspace:run-command",
            "dependsOn": ["^build"],
            "options": {
                "command": "pnpm test",
                "cwd": "{root}/tests/e2e"
            }
        },
        "test:e2e": {
            "executor": "./tools/executors/workspace:run-command",
            "dependsOn": ["^build"],
            "options": {
                "command": "pnpm test:e2e",
                "cwd": "{root}/tests/e2e"
            }
        },
        "test:run": {
            "executor": "./tools/executors/workspace:run-command",
            "dependsOn": ["^build"],
            "options": {
                "command": "pnpm test:run",
                "cwd": "{root}/tests/e2e"
            }
        },
        "build": {
            "executor": "nx:noop",
            "dependsOn": ["^build"]
        }
    }
}
