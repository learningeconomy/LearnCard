{
    "name": "@workspace/e2e-tests",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "echo \"Skipping E2E tests in CI. Run test:e2e if you'd like to actually run this!\"",
        "test:docker-up": "PORT_OFFSET=100 ../../scripts/dc.sh -f compose.yaml up --build",
        "test:e2e": "PORT_OFFSET=${PORT_OFFSET:-100} vitest",
        "test:e2e:no-docker": "PORT_OFFSET=${PORT_OFFSET:-100} E2E_MANAGE_DOCKER=false vitest",
        "test:run": "PORT_OFFSET=${PORT_OFFSET:-100} vitest run",
        "test:e2e:interop": "PORT_OFFSET=${PORT_OFFSET:-100} TEST_TAGS=@interop vitest",
        "test:run:interop": "PORT_OFFSET=${PORT_OFFSET:-100} TEST_TAGS=@interop vitest run",
        "test:e2e:no-interop": "PORT_OFFSET=${PORT_OFFSET:-100} TEST_TAGS_NOT=@interop vitest",
        "test:run:no-interop": "PORT_OFFSET=${PORT_OFFSET:-100} TEST_TAGS_NOT=@interop vitest run",
        "logs": "PORT_OFFSET=${PORT_OFFSET:-100} ../../scripts/dc.sh -f compose.yaml logs -f",
        "test:proxy:docker-up": "../../scripts/dc.sh -f compose-proxy.yaml up --build",
        "test:proxy:e2e": "vitest",
        "test:proxy:run": "vitest run",
        "test:proxy:down": "../../scripts/dc.sh -f compose-proxy.yaml down",
        "logs:proxy": "../../scripts/dc.sh -f compose-proxy.yaml logs -f"
    },
    "dependencies": {
        "@learncard/core": "workspace:*",
        "@learncard/didkit-plugin": "workspace:*",
        "@learncard/init": "workspace:*",
        "@learncard/lca-api-plugin": "workspace:*",
        "@learncard/simple-signing-plugin": "workspace:*",
        "@learncard/types": "workspace:*",
        "@xapi/xapi": "^3.0.0",
        "execa": "^9.5.1",
        "hex-lite": "^1.5.0",
        "ioredis": "^5.2.2",
        "mongodb": "^6.2.0",
        "neo4j-driver": "^5.18.0",
        "pg": "^8.13.1"
    },
    "devDependencies": {
        "@types/pg": "^8.11.10",
        "@digitalcredentials/verifier-core": "^1.0.0-beta.8"
    }
}
