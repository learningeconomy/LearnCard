# Docker Compose Port Namespacing
#
# Set PORT_OFFSET to shift ALL host port bindings, allowing multiple stacks
# (e.g. local dev + e2e) to run simultaneously without port conflicts.
#
# Default: 0 (no change — ports resolve to their original values)
#
# Example: PORT_OFFSET=100 maps brain to 4100, cloud to 4200, etc.
PORT_OFFSET=0

# Override the compose project name (default: derived from git branch)
# LC_PROJECT=my-custom-project

# Set to "true" to have the test runner start/stop Docker automatically
# E2E_MANAGE_DOCKER=false
