{
    "name": "@workspace/openid4vc-interop-e2e-tests",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "echo 'Skipping OID4VC interop E2E in CI. Run test:interop:e2e (requires docker).'",
        "test:interop:e2e": "vitest run",
