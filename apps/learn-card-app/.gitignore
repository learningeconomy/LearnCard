# ---------------------------------------------------------------------------
# Platform assets populated by: npx tsx scripts/prepare-native-config.ts
# Source of truth lives in environments/<tenant>/assets/ (git-tracked).
# Run `prepare-native-config.ts learncard` to restore defaults.
# ---------------------------------------------------------------------------

