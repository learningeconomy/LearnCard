{
    "_comment": "Shared tenant registry — maps hostnames to tenant IDs. Used by the Netlify edge function and build scripts. To add a new tenant, add entries here AND create environments/<tenantId>/config.json.",
    "hostnames": {
        "learncard.app": {
            "tenantId": "learncard",
            "domain": "learncard.app"
        },
        "learncardapp.netlify.app": {
            "tenantId": "learncard",
            "domain": "learncard.app"
        },
        "lc-test-tenant.netlify.app": {
            "tenantId": "vetpass",
            "domain": "vetpass.app",
            "configOverrides": {
                "branding": {
                    "name": "VetPass",
                    "shortName": "VP",
                    "defaultTheme": "vetpass",
                    "allowedThemes": ["vetpass"],
                    "brandingKey": "vetpass",
                    "headerText": "VETPASS",
                    "homeRoute": "/wallet",
                    "categoryLabels": {
                        "learningHistory": "Training",
                        "workHistory": "Service",
                        "accommodation": "Benefits",
                        "accomplishment": "Awards",
                        "socialBadge": "Badge"
                    }
                },
                "features": {
                    "aiFeatures": true,
                    "appStore": true,
                    "analytics": true,
                    "themeSwitching": false,
                    "introSlides": true
                }
            }
        }
    },
    "defaultTenant": {
        "tenantId": "learncard",
        "domain": "learncard.app"
    }
}
