# =============================================================================
# LearnCard App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Vite automatically exposes VITE_* vars via import.meta.env.
# Non-VITE vars are injected via the `define` block in vite.config.ts.
#
# NOTE: Tenant config JSON (environments/<tenant>/config.json) is now the
# canonical source for most of these values. Vars marked [DEPRECATED] below
# are still read as fallbacks but should be set in config.json instead.
# See environments/README.md → "Config precedence" for the full layering.
# =============================================================================

# ---------------------------------------------------------------------------
# LearnCard Network / API URLs
# ---------------------------------------------------------------------------
# Brain service URL (e.g. https://network.learncard.com)
LCN_URL=
# Brain service API URL (e.g. https://network.learncard.com/api)
LCN_API_URL=
# LearnCloud service URL (e.g. https://cloud.learncard.com)
CLOUD_URL=
# LearnCloud xAPI URL
LEARN_CLOUD_XAPI_URL=
# LCA API URL (e.g. https://api.learncard.app)
API_URL=

# ---------------------------------------------------------------------------
# Auth Provider Configuration (read by learn-card-base authConfig.ts)
# [DEPRECATED] — set these in config.json → auth.* instead
# ---------------------------------------------------------------------------
# Which auth provider to use: 'firebase' (default)  →  config.json auth.provider
VITE_AUTH_PROVIDER=firebase
# Which key derivation strategy: 'sss' | 'web3auth'  →  config.json auth.keyDerivation
VITE_KEY_DERIVATION=sss
# Server URL for SSS key share operations  →  config.json auth.sssServerUrl
VITE_SSS_SERVER_URL=http://localhost:5100/api
# Auto-send backup share  →  config.json auth.enableEmailBackupShare
VITE_ENABLE_EMAIL_BACKUP_SHARE=true
# Require phone-only users to link email  →  config.json auth.requireEmailForPhoneUsers
VITE_REQUIRE_EMAIL_FOR_PHONE_USERS=true
# Show the auth/key debug widget in the UI: 'true' | 'false'
VITE_ENABLE_AUTH_DEBUG_WIDGET=false

# ---------------------------------------------------------------------------
# Web3Auth Configuration (used for Web3Auth key derivation and SSS migration)
# ---------------------------------------------------------------------------
# Client ID from the Web3Auth dashboard
VITE_WEB3AUTH_CLIENT_ID=
# Network: 'testnet' | 'cyan' | 'sapphire_mainnet'
VITE_WEB3AUTH_NETWORK=
# Verifier name configured in Web3Auth dashboard (e.g. 'learncardapp-firebase')
VITE_WEB3AUTH_VERIFIER_ID=
# Ethereum RPC URL for Web3Auth (e.g. Infura endpoint)
VITE_WEB3AUTH_RPC_TARGET=

# ---------------------------------------------------------------------------
# Analytics
# ---------------------------------------------------------------------------
# Analytics provider: 'posthog' | '' (disabled)
VITE_ANALYTICS_PROVIDER=
# PostHog project API key
VITE_POSTHOG_KEY=
# PostHog host (defaults to PostHog cloud)
VITE_POSTHOG_HOST=

# ---------------------------------------------------------------------------
# Sentry Error Tracking
# [DEPRECATED] — set in config.json → observability.sentryDsn / sentryEnv
# ---------------------------------------------------------------------------
SENTRY_ENV=development
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Google Maps
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# App color theme  [DEPRECATED] — set in config.json → branding.defaultTheme
APP_THEME=colorful
# CORS proxy API key (if using a CORS proxy service)
CORS_PROXY_API_KEY=
# Node environment
NODE_ENV=development
VITE_NODE_ENV=development
