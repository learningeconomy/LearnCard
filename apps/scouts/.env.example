# =============================================================================
# ScoutPass App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Vite automatically exposes VITE_* vars via import.meta.env.
# Non-VITE vars are injected via the `define` block in vite.config.ts.
# =============================================================================

# ---------------------------------------------------------------------------
# LearnCard Network / API URLs
# ---------------------------------------------------------------------------
# Brain service URL (e.g. https://network.learncard.com)
LCN_URL=
# Brain service API URL (e.g. https://network.learncard.com/api)
LCN_API_URL=
# LearnCloud service URL (e.g. https://cloud.learncard.com)
CLOUD_URL=
# LearnCloud xAPI URL
LEARN_CLOUD_XAPI_URL=
# LCA API URL (e.g. https://api.learncard.app)
API_URL=

# ---------------------------------------------------------------------------
# Auth Provider Configuration (read by learn-card-base authConfig.ts)
# ---------------------------------------------------------------------------
# Which auth provider to use: 'firebase' (default)
VITE_AUTH_PROVIDER=firebase
# Which key derivation strategy: 'sss' (default) | 'web3auth'
VITE_KEY_DERIVATION=sss
# Server URL for SSS key share operations (REQUIRED for non-local deployments)
# Defaults to http://localhost:5100/api — must be set to real lca-api URL in prod
VITE_SSS_SERVER_URL=http://localhost:5100/api
# Auto-send backup share to user's email during key setup: 'true' (default) | 'false'
VITE_ENABLE_EMAIL_BACKUP_SHARE=true
# Require phone-only users to link an email before proceeding: 'true' (default) | 'false'
VITE_REQUIRE_EMAIL_FOR_PHONE_USERS=true
# Show the auth/key debug widget in the UI: 'true' | 'false'
VITE_ENABLE_AUTH_DEBUG_WIDGET=false

# ---------------------------------------------------------------------------
# Web3Auth Configuration (used for Web3Auth key derivation and SSS migration)
# ---------------------------------------------------------------------------
# Client ID from the Web3Auth dashboard
VITE_WEB3AUTH_CLIENT_ID=
# Network: 'testnet' | 'cyan' | 'sapphire_mainnet'
VITE_WEB3AUTH_NETWORK=
# Verifier name configured in Web3Auth dashboard (e.g. 'learncardapp-firebase')
VITE_WEB3AUTH_VERIFIER_ID=
# Ethereum RPC URL for Web3Auth (e.g. Infura endpoint)
VITE_WEB3AUTH_RPC_TARGET=

# ---------------------------------------------------------------------------
# Sentry Error Tracking
# ---------------------------------------------------------------------------
SENTRY_ENV=scouts-development
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Google Maps
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Node environment
NODE_ENV=development
VITE_NODE_ENV=development
