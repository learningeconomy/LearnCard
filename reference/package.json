    },
    "dependencies": {
        "@docusaurus/core": "2.1.0",
        "@docusaurus/preset-classic": "2.1.0",
        "@mdx-js/react": "^1.6.22",
        "clsx": "^1.2.1",
        "prism-react-renderer": "^1.3.5",
        "react": "^18.0.0",
        "react-dom": "^18.0.0"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "2.1.0",
