# Space Dodger - Environment Configuration
#
# NOTE: This app uses the Partner Connect SDK template-based credential issuance.
# No backend issuer seed is required. Credentials are issued directly from the
# user's wallet using pre-configured boost templates.
#
# Template Aliases - configure these to match your app store listing boosts.
# These must match the templateAlias values configured in your app store listing.
# Default values match the templates created in the LearnCard Developer Portal.
LEARNCARD_TEMPLATE_BRONZE=bronze-space-pilot
LEARNCARD_TEMPLATE_SILVER=silver-space-pilot
LEARNCARD_TEMPLATE_GOLD=gold-space-pilot
LEARNCARD_TEMPLATE_PLATINUM=platinum-space-ace
#
# Optional host override (for staging)
LEARNCARD_HOST_ORIGIN=https://learncard.app
