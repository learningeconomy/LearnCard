---
import '../styles/global.css';
// Server-side host origin is no longer needed - client uses dynamic detection
// const hostOrigin = import.meta.env.LEARNCARD_HOST_ORIGIN || 'https://learncard.app';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Space Dodger - LearnCard High Score Game</title>
  <meta name="description" content="An arcade-style space dodger game that issues verifiable credentials for high scores">
  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap');
    
    :root {
      --color-primary: #00d4ff;
      --color-primary-dark: #00a8cc;
      --color-secondary: #8b5cf6;
      --color-accent: #f472b6;
      --color-success: #22c55e;
      --color-warning: #f59e0b;
      --color-danger: #ef4444;
      --color-gold: #ffd700;
      --color-silver: #c0c0c0;
      --color-bronze: #cd7f32;
      --color-platinum: #e5e4e2;
      --glow-primary: 0 0 20px rgba(0, 212, 255, 0.6), 0 0 40px rgba(0, 212, 255, 0.3);
      --glow-secondary: 0 0 20px rgba(139, 92, 246, 0.6), 0 0 40px rgba(139, 92, 246, 0.3);
      --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
      --transition-normal: 250ms cubic-bezier(0.4, 0, 0.2, 1);
      --transition-slow: 350ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    * {
      box-sizing: border-box;
    }
    
    body {
      margin: 0;
      min-height: 100vh;
      background: linear-gradient(135deg, #0a0a1a 0%, #1a0a2e 50%, #0d1b2a 100%);
      font-family: 'Rajdhani', sans-serif;
      overflow-x: hidden;
      color: #e2e8f0;
    }
    
    .neon-text {
      font-family: 'Orbitron', sans-serif;
      text-shadow: 0 0 10px var(--color-primary), 0 0 30px var(--color-primary), 0 0 60px rgba(0, 212, 255, 0.5);
      letter-spacing: 0.05em;
    }
    
    .neon-border {
      box-shadow: var(--glow-primary), inset 0 0 20px rgba(0, 212, 255, 0.1);
    }
    
    /* Enhanced Button Styles - Redesigned */
    .btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 1.75rem;
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 0.9375rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border: none;
      border-radius: 14px;
      cursor: pointer;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      transform: translateZ(0);
      will-change: transform, box-shadow;
    }
    
    /* Button shine effect */
    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(255, 255, 255, 0.3),
        transparent
      );
      transition: left 0.5s ease;
    }
    
    .btn::after {
      content: '';
      position: absolute;
      inset: -3px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary), var(--color-accent));
      border-radius: 16px;
      z-index: -1;
      opacity: 0;
      filter: blur(8px);
      transition: opacity 0.3s ease;
    }
    
    .btn:hover {
      transform: translateY(-3px) scale(1.03);
    }
    
    .btn:hover::before {
      left: 100%;
    }
    
    .btn:hover::after {
      opacity: 0.4;
    }
    
    .btn:active {
      transform: translateY(-1px) scale(0.97);
      transition-duration: 0.1s;
    }
    
    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      filter: grayscale(0.5);
    }
    
    .btn:disabled::before,
    .btn:disabled::after {
      display: none;
    }
    
    /* Primary Button - Cyan */
    .btn-primary {
      background: linear-gradient(145deg, #00d4ff 0%, #0099cc 50%, #0077aa 100%);
      color: white;
      box-shadow: 
        0 8px 20px rgba(0, 212, 255, 0.4),
        0 4px 8px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.3),
        inset 0 -2px 0 rgba(0, 0, 0, 0.2);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
    
    .btn-primary:hover {
      box-shadow: 
        0 12px 30px rgba(0, 212, 255, 0.6),
        0 6px 12px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.4),
        0 0 30px rgba(0, 212, 255, 0.4);
    }
    
    .btn-primary:active {
      box-shadow: 
        0 4px 12px rgba(0, 212, 255, 0.3),
        inset 0 2px 4px rgba(0, 0, 0, 0.2);
      background: linear-gradient(145deg, #0099cc 0%, #0077aa 100%);
    }
    
    /* Secondary Button - Purple */
    .btn-secondary {
      background: linear-gradient(145deg, #a78bfa 0%, #8b5cf6 50%, #7c3aed 100%);
      color: white;
      box-shadow: 
        0 8px 20px rgba(139, 92, 246, 0.4),
        0 4px 8px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.3),
        inset 0 -2px 0 rgba(0, 0, 0, 0.2);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
    
    .btn-secondary:hover {
      box-shadow: 
        0 12px 30px rgba(139, 92, 246, 0.6),
        0 6px 12px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.4),
        0 0 30px rgba(139, 92, 246, 0.4);
    }
    
    .btn-secondary:active {
      background: linear-gradient(145deg, #8b5cf6 0%, #7c3aed 100%);
      box-shadow: 
        0 4px 12px rgba(139, 92, 246, 0.3),
        inset 0 2px 4px rgba(0, 0, 0, 0.2);
    }
    
    /* Success Button - Green */
    .btn-success {
      background: linear-gradient(145deg, #4ade80 0%, #22c55e 50%, #16a34a 100%);
      color: white;
      box-shadow: 
        0 8px 20px rgba(34, 197, 94, 0.4),
        0 4px 8px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.3),
        inset 0 -2px 0 rgba(0, 0, 0, 0.2);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
    
    .btn-success:hover {
      box-shadow: 
        0 12px 30px rgba(34, 197, 94, 0.6),
        0 6px 12px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.4),
        0 0 30px rgba(34, 197, 94, 0.4);
    }
    
    /* Gold Button - Premium */
    .btn-gold {
      background: linear-gradient(145deg, #fcd34d 0%, #fbbf24 50%, #f59e0b 100%);
      color: #1a1a2e;
      box-shadow: 
        0 8px 20px rgba(251, 191, 36, 0.5),
        0 4px 8px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.5),
        inset 0 -2px 0 rgba(0, 0, 0, 0.1);
      font-weight: 800;
    }
    
    .btn-gold:hover {
      box-shadow: 
        0 12px 30px rgba(251, 191, 36, 0.7),
        0 6px 12px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.6),
        0 0 30px rgba(251, 191, 36, 0.5);
    }
    
    /* Outline Button */
    .btn-outline {
      background: rgba(0, 212, 255, 0.08);
      color: var(--color-primary);
      border: 2px solid rgba(0, 212, 255, 0.5);
      box-shadow: 0 0 0 rgba(0, 212, 255, 0);
      position: relative;
      overflow: hidden;
    }
    
    .btn-outline::before {
      background: linear-gradient(
        90deg,
        transparent,
        rgba(0, 212, 255, 0.2),
        transparent
      );
    }
    
    .btn-outline:hover {
      background: rgba(0, 212, 255, 0.15);
      border-color: var(--color-primary);
      box-shadow: 
        0 0 20px rgba(0, 212, 255, 0.3),
        inset 0 0 20px rgba(0, 212, 255, 0.1);
      color: #00f0ff;
    }
    
    .btn-outline::after {
      display: none;
    }
    
    /* Small Button */
    .btn-sm {
      padding: 0.625rem 1.25rem;
      font-size: 0.8125rem;
      border-radius: 10px;
      letter-spacing: 0.06em;
    }
    
    /* Large Button */
    .btn-lg {
      padding: 1.125rem 2.5rem;
      font-size: 1.0625rem;
      border-radius: 16px;
      letter-spacing: 0.1em;
    }
    
    .game-container {
      position: relative;
      width: 100%;
      max-width: 900px;
      margin: 0 auto;
    }

    #gameCanvas {
      border: 2px solid var(--color-primary);
      border-radius: 16px;
      box-shadow: var(--glow-primary), 0 20px 60px rgba(0, 0, 0, 0.5);
      background: radial-gradient(ellipse at center, #0a1628 0%, #000000 100%);
      transition: all var(--transition-normal);
    }

    #gameCanvas:hover {
      box-shadow: 0 0 30px rgba(0, 212, 255, 0.8), 0 0 60px rgba(0, 212, 255, 0.4), 0 25px 70px rgba(0, 0, 0, 0.6);
    }

    /* Enhanced Container */
    .game-container {
      padding: 0 0.5rem;
    }

    @media (min-width: 640px) {
      .game-container {
        padding: 0;
      }
    }

    /* Smooth transitions for game canvas */
    #gameCanvas {
      transition: box-shadow var(--transition-normal), transform var(--transition-normal);
    }

    /* Claim button visibility fix */
    .claim-btn {
      display: inline-flex !important;
      visibility: visible !important;
      opacity: 1 !important;
    }

    /* Ensure credential offers are visible */
    #credential-offers {
      display: block !important;
      visibility: visible !important;
    }

    #credential-offers .credential-card {
      display: block !important;
      visibility: visible !important;
    }

    /* Achievement Badge */
    .achievement-badge {
      animation: achievementPulse 3s ease-in-out infinite;
      filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
    }

    @keyframes achievementPulse {
      0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5)); }
      50% { transform: scale(1.08); filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.8)); }
    }

    /* Stars */
    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle 4s infinite ease-in-out;
    }

    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
    }

    /* Modal Overlay */
    .modal-overlay {
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(20px);
    }

    /* Boost Meter */
    #boost-meter-container {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.9));
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 12px;
      padding: 0.75rem 1rem;
      backdrop-filter: blur(10px);
    }

    /* Auth Panel */
    #auth-panel {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.9));
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(10px);
    }

    /* Loading/Status Indicators */
    .status-dot {
      box-shadow: 0 0 10px currentColor;
    }

    /* Touch zone active states */
    .touch-zone.active {
      border-color: var(--color-primary);
      background: rgba(0, 212, 255, 0.2);
      box-shadow: 0 0 30px rgba(0, 212, 255, 0.4);
      transform: scale(0.98);
    }
    
    /* Enhanced Score Display - Modern Design */
    .score-display {
      font-family: 'Orbitron', sans-serif;
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
      border: 1px solid rgba(0, 212, 255, 0.25);
      border-radius: 20px;
      box-shadow: 
        0 8px 32px rgba(0, 0, 0, 0.4), 
        0 2px 8px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.2);
      backdrop-filter: blur(12px);
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
      overflow: hidden;
    }
    
    .score-display::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(0, 212, 255, 0.05),
        transparent
      );
      transition: left 0.6s ease;
    }
    
    .score-display:hover::before {
      left: 100%;
    }
    
    .score-display:hover {
      border-color: rgba(0, 212, 255, 0.5);
      box-shadow: 
        0 16px 48px rgba(0, 0, 0, 0.5), 
        0 0 30px rgba(0, 212, 255, 0.15),
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
      transform: translateY(-4px) scale(1.02);
    }
    
    .score-display.score-highlight {
      animation: scorePulse 0.5s ease-out;
    }
    
    @keyframes scorePulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.08); }
      100% { transform: scale(1); }
    }
    
    .score-label {
      font-size: 0.625rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.9;
      margin-bottom: 0.25rem;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
    
    .score-value {
      font-size: 1.875rem;
      font-weight: 900;
      text-shadow: 
        0 2px 4px rgba(0, 0, 0, 0.4),
        0 0 20px currentColor;
      letter-spacing: 0.02em;
      line-height: 1;
    }
    
    @media (min-width: 640px) {
      .score-value {
        font-size: 2.5rem;
      }
      .score-label {
        font-size: 0.6875rem;
      }
    }
    
    @media (min-width: 768px) {
      .score-value {
        font-size: 3rem;
      }
    }
    
    /* Achievement Badge */
    .achievement-badge {
      animation: achievementPulse 3s ease-in-out infinite;
      filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
    }
    
    @keyframes achievementPulse {
      0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5)); }
      50% { transform: scale(1.08); filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.8)); }
    }
    
    /* Stars */
    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle 4s infinite ease-in-out;
    }
    
    @keyframes twinkle {
      0%, 100% { opacity: 0.2; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
    }
    
    /* Modal Overlay */
    .modal-overlay {
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(20px);
    }
    
    /* Touch Control Zones - Enhanced */
    .touch-zone {
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.85), rgba(15, 23, 42, 0.85));
      border: 2px solid rgba(71, 85, 105, 0.4);
      border-radius: 20px;
      transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      backdrop-filter: blur(12px);
      position: relative;
      overflow: hidden;
    }
    
    .touch-zone::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(0, 212, 255, 0.1) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    
    .touch-zone:hover {
      border-color: rgba(0, 212, 255, 0.5);
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.9), rgba(15, 23, 42, 0.9));
      transform: translateY(-2px);
    }
    
    .touch-zone:active,
    .touch-zone.active {
      border-color: var(--color-primary);
      background: rgba(0, 212, 255, 0.2);
      box-shadow: 
        0 0 30px rgba(0, 212, 255, 0.4),
        inset 0 0 20px rgba(0, 212, 255, 0.1);
      transform: scale(0.96);
    }
    
    .touch-zone.active::before {
      opacity: 1;
    }
    
    .touch-zone svg {
      transition: all 0.2s ease;
    }
    
    .touch-zone:hover svg {
      transform: scale(1.1);
      color: rgba(0, 212, 255, 0.9);
    }
    
    .touch-zone.active svg {
      transform: scale(1.15);
      color: var(--color-primary);
      filter: drop-shadow(0 0 10px rgba(0, 212, 255, 0.8));
    }
    
    /* Credential Card - Premium Design */
    .credential-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.98));
      border: 1px solid rgba(0, 212, 255, 0.25);
      border-radius: 20px;
      box-shadow: 
        0 12px 48px rgba(0, 0, 0, 0.5),
        0 4px 12px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
      overflow: hidden;
    }
    
    .credential-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(0, 212, 255, 0.05),
        transparent
      );
      transition: left 0.6s ease;
    }
    
    .credential-card:hover {
      border-color: rgba(0, 212, 255, 0.45);
      box-shadow: 
        0 20px 60px rgba(0, 0, 0, 0.6), 
        0 0 40px rgba(0, 212, 255, 0.15),
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
      transform: translateY(-4px) scale(1.01);
    }
    
    .credential-card:hover::before {
      left: 100%;
    }
    
    /* Tier Milestones - Interactive Cards */
    .tier-milestone {
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.8), rgba(15, 23, 42, 0.8));
      border: 1px solid rgba(71, 85, 105, 0.4);
      border-radius: 16px;
      transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
      overflow: hidden;
    }
    
    .tier-milestone::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    
    .tier-milestone:hover {
      border-color: rgba(0, 212, 255, 0.5);
      transform: translateY(-4px) scale(1.05);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 212, 255, 0.1);
    }
    
    .tier-milestone:hover::before {
      opacity: 1;
    }
    
    .tier-milestone .emoji {
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    
    .tier-milestone:hover .emoji {
      transform: scale(1.2);
    }
    
    /* Boost Meter */
    #boost-meter-container {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.9));
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 12px;
      padding: 0.75rem 1rem;
      backdrop-filter: blur(10px);
    }
    
    /* Auth Panel */
    #auth-panel {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.9));
      border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(10px);
    }
    
    /* Screen Overlays - Premium Dark */
    .screen-overlay {
      background: linear-gradient(180deg, rgba(0,0,0,0.92) 0%, rgba(10,10,35,0.96) 50%, rgba(5,5,25,0.98) 100%);
      backdrop-filter: blur(40px) saturate(180%);
    }
    
    .screen-overlay::before {
      content: '';
      position: absolute;
      inset: 0;
      background: 
        radial-gradient(ellipse at 50% 0%, rgba(0, 212, 255, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 100%, rgba(139, 92, 246, 0.05) 0%, transparent 50%);
      pointer-events: none;
    }
    
    /* Key/Button Hints - 3D Effect */
    .key-hint {
      background: linear-gradient(145deg, #3d4f6f, #1e293b);
      border: 1px solid rgba(71, 85, 105, 0.6);
      border-radius: 8px;
      box-shadow: 
        0 4px 0 #0f172a, 
        0 6px 8px rgba(0,0,0,0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    }
    
    .key-hint:hover {
      background: linear-gradient(145deg, #4a5d7f, #334155);
      transform: translateY(-2px);
      box-shadow: 
        0 5px 0 #0f172a, 
        0 8px 12px rgba(0,0,0,0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
    }
    
    .key-hint:active {
      transform: translateY(2px);
      box-shadow: 
        0 1px 0 #0f172a, 
        0 2px 4px rgba(0,0,0,0.3),
        inset 0 2px 4px rgba(0, 0, 0, 0.2);
    }
    
    /* Loading/Status Indicators */
    .status-dot {
      box-shadow: 0 0 10px currentColor;
    }
    
    /* Enhanced Animations */
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(0, 212, 255, 0.3); }
      50% { box-shadow: 0 0 40px rgba(0, 212, 255, 0.6); }
    }
    
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    
    @keyframes shimmer {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    
    .animate-float {
      animation: float 3s ease-in-out infinite;
    }
    
