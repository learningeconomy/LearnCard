  <script>
    import { actions } from 'astro:actions';
    import { createPartnerConnect } from '@learncard/partner-connect';
    
    // --- LEARNCARD SDK SETUP ---
    // Use default configuration - SDK auto-detects host origin from lc_host_override query param
    const learnCard = createPartnerConnect();
    
    let isAuthenticated = false;
    let userDid = null;
    let earnedTiers = new Set();
    let availableCredentials = []; // Credentials available to claim at game end
    
    // --- GAME CONSTANTS ---
    const CANVAS_WIDTH = 800;
    const CANVAS_HEIGHT = 600;
    const PLAYER_SIZE = 40;
    const PLAYER_SPEED = 7;
    const ASTEROID_BASE_SPEED = 3;
    const POWERUP_CHANCE = 0.01;
    
    // --- BOOST CONSTANTS ---
    const BOOST_DURATION = 1500; // 1.5 seconds
    const BOOST_COOLDOWN = 3000; // 3 seconds
    const BOOST_SPEED_MULTIPLIER = 2.5; // Speed multiplier during boost
    
    // --- GAME STATE ---
    let canvas, ctx;
    let gameLoop;
    let gameState = 'start'; // start, playing, paused, gameover
    let score = 0;
    let highScore = parseInt(localStorage.getItem('spaceDodgerHighScore') || '0');
    let level = 1;
    let frames = 0;
    let difficultyMultiplier = 1;

    // --- BOOST STATE ---
    let isBoosting = false;
    let boostTimer = 0;
    let boostCooldownTimer = 0;
    let boostReady = true;

    // --- TIME-BASED ANIMATION ---
    let lastTime = 0;
    let asteroidSpawnTimer = 0;
    const TARGET_FPS = 60;
    const TARGET_FRAME_TIME = 1000 / TARGET_FPS; // ~16.67ms
    
    // --- ENTITIES ---
    let player = {
      x: CANVAS_WIDTH / 2 - PLAYER_SIZE / 2,
      y: CANVAS_HEIGHT - 100,
      width: PLAYER_SIZE,
      height: PLAYER_SIZE,
      velocity: 0,
      trail: []
    };
    
    let asteroids = [];
    let particles = [];
    let powerUps = [];
    let stars = [];
    
    // --- INPUT HANDLING ---
    const keys = {};
    let touchState = { left: false, right: false };
    
    // --- INITIALIZATION ---
    function init() {
      canvas = document.getElementById('gameCanvas');
      ctx = canvas.getContext('2d');
      
      // Create background stars
      for (let i = 0; i < 100; i++) {
        stars.push({
          x: Math.random() * CANVAS_WIDTH,
          y: Math.random() * CANVAS_HEIGHT,
          size: Math.random() * 2 + 0.5,
          speed: Math.random() * 0.5 + 0.1,
          brightness: Math.random()
        });
      }
      
      // Event listeners
      document.addEventListener('keydown', (e) => {
        keys[e.key] = true;
        if (e.key === ' ' && gameState === 'playing') {
          e.preventDefault();
          togglePause();
        }
        if ((e.key === 'ArrowUp' || e.key === 'w' || e.key === 'W') && gameState === 'playing') {
          e.preventDefault();
          activateBoost();
        }
      });
      
      document.addEventListener('keyup', (e) => {
        keys[e.key] = false;
      });
      
      // Button listeners
      document.getElementById('start-btn').addEventListener('click', startGame);
      document.getElementById('restart-btn').addEventListener('click', resetGame);
      document.getElementById('mobile-pause-btn').addEventListener('click', togglePause);
      document.getElementById('mobile-boost-btn').addEventListener('click', activateBoost);
      
      // Setup touch controls for mobile
      setupTouchControls();
      
      // Show mobile controls on touch devices, always show boost meter
      if (isTouchDevice()) {
        document.getElementById('mobile-controls').classList.remove('hidden');
      }
      document.getElementById('boost-meter-container').classList.remove('hidden');
      
      // Update high score display
      document.getElementById('high-score').textContent = highScore;
      
      // Create background stars animation
      createBackgroundStars();
      
      // Authenticate with LearnCard
      authenticate();
    }
    
    // --- TOUCH CONTROLS ---
    function isTouchDevice() {
      return 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    }
    
    function setupTouchControls() {
      // Prevent default touch behaviors during gameplay
      document.addEventListener('touchstart', (e) => {
        if (gameState === 'playing') {
          e.preventDefault();
        }
      }, { passive: false });
      
      document.addEventListener('touchmove', (e) => {
        if (gameState === 'playing') {
          e.preventDefault();
        }
      }, { passive: false });
      
      // Canvas touch controls
      canvas.addEventListener('touchstart', handleTouchStart, { passive: false });
      canvas.addEventListener('touchend', handleTouchEnd, { passive: false });
      canvas.addEventListener('touchcancel', handleTouchEnd, { passive: false });
      
      // Touch zone controls for mobile UI
      const touchLeft = document.getElementById('touch-left');
      const touchRight = document.getElementById('touch-right');
      
      if (touchLeft && touchRight) {
        // Left zone
        touchLeft.addEventListener('touchstart', (e) => {
          e.preventDefault();
          touchState.left = true;
          touchState.right = false;
          touchLeft.classList.add('active');
        }, { passive: false });
        
        touchLeft.addEventListener('touchend', (e) => {
          e.preventDefault();
          touchState.left = false;
          touchLeft.classList.remove('active');
        }, { passive: false });
        
        touchLeft.addEventListener('touchcancel', (e) => {
          e.preventDefault();
          touchState.left = false;
          touchLeft.classList.remove('active');
        }, { passive: false });
        
        // Right zone
        touchRight.addEventListener('touchstart', (e) => {
          e.preventDefault();
          touchState.right = true;
          touchState.left = false;
          touchRight.classList.add('active');
        }, { passive: false });
        
        touchRight.addEventListener('touchend', (e) => {
          e.preventDefault();
          touchState.right = false;
          touchRight.classList.remove('active');
        }, { passive: false });
        
        touchRight.addEventListener('touchcancel', (e) => {
          e.preventDefault();
          touchState.right = false;
          touchRight.classList.remove('active');
        }, { passive: false });
      }
    }
    
    function handleTouchStart(e) {
      e.preventDefault();
      const rect = canvas.getBoundingClientRect();
      
      for (let i = 0; i < e.changedTouches.length; i++) {
        const touch = e.changedTouches[i];
        const x = touch.clientX - rect.left;
        const y = touch.clientY - rect.top;
        
        // Scale touch coordinates to canvas coordinates
        const scaleX = CANVAS_WIDTH / rect.width;
        const canvasX = x * scaleX;
        
        // Left half = move left, Right half = move right
        if (canvasX < CANVAS_WIDTH / 2) {
          touchState.left = true;
          touchState.right = false;
        } else {
          touchState.right = true;
          touchState.left = false;
        }
      }
    }
    
    function handleTouchEnd(e) {
      e.preventDefault();
      touchState.left = false;
      touchState.right = false;
    }
    
    function createBackgroundStars() {
      const container = document.getElementById('stars-container');
      for (let i = 0; i < 50; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        star.style.left = Math.random() * 100 + '%';
        star.style.top = Math.random() * 100 + '%';
        star.style.width = Math.random() * 3 + 1 + 'px';
        star.style.height = star.style.width;
        star.style.animationDelay = Math.random() * 3 + 's';
        container.appendChild(star);
      }
    }
    
    // --- AUTHENTICATION ---
    async function authenticate() {
      const indicator = document.getElementById('auth-indicator');
      const text = document.getElementById('auth-text');
      
      try {
        text.textContent = 'Connecting to LearnCard...';
        indicator.className = 'w-3 h-3 rounded-full bg-yellow-500 animate-pulse';
        
        const identity = await learnCard.requestIdentity();
        userDid = identity.user.did;
        isAuthenticated = true;
        
        indicator.className = 'w-3 h-3 rounded-full bg-green-500';
        text.innerHTML = `Connected: <span class="font-mono text-xs">${userDid.slice(0, 20)}...</span>`;
        
        // If game is over, refresh the credential offers UI
        if (gameState === 'gameover') {
          updateCredentialOffersUI();
        }
      } catch (error) {
        if (error.code === 'LC_UNAUTHENTICATED') {
          indicator.className = 'w-3 h-3 rounded-full bg-red-500';
          text.textContent = 'Not logged into LearnCard';
        } else {
          indicator.className = 'w-3 h-3 rounded-full bg-red-500';
          text.textContent = 'Connection failed';
        }
      }
    }
    
    // --- GAME LOOP ---
    function startGame() {
      document.getElementById('start-screen').classList.add('hidden');
      document.getElementById('game-over-screen').classList.add('hidden');
      gameState = 'playing';
      resetEntities();
      lastTime = 0;
      asteroidSpawnTimer = 0;
      gameLoop = requestAnimationFrame(update);
    }
    
    function resetGame() {
      score = 0;
      level = 1;
      frames = 0;
      difficultyMultiplier = 1;
      earnedTiers.clear();
      availableCredentials = [];
      lastTime = 0;
      asteroidSpawnTimer = 0;
      updateUI();
      // Show start screen instead of immediately starting
      document.getElementById('game-over-screen').classList.add('hidden');
      document.getElementById('start-screen').classList.remove('hidden');
      gameState = 'start';
    }
    
    function resetEntities() {
      player.x = CANVAS_WIDTH / 2 - PLAYER_SIZE / 2;
      player.y = CANVAS_HEIGHT - 100;
      player.velocity = 0;
      player.trail = [];
      asteroids = [];
      particles = [];
      powerUps = [];
      asteroidSpawnTimer = 0;
      lastTime = 0;
      
      // Reset boost state
      isBoosting = false;
      boostTimer = 0;
      boostCooldownTimer = 0;
      boostReady = true;
      updateBoostUI();
    }
    
    // --- BOOST FUNCTIONS ---
    function activateBoost() {
      if (!boostReady || isBoosting || gameState !== 'playing') return;
      
      isBoosting = true;
      boostTimer = BOOST_DURATION;
      boostReady = false;
      
      // Create boost activation particles
      createExplosion(player.x + PLAYER_SIZE / 2, player.y + PLAYER_SIZE, '0, 255, 255');
      
      updateBoostUI();
    }
    
    function updateBoost(deltaTime) {
      if (!isBoosting && !boostReady) {
        // Update cooldown
        boostCooldownTimer -= deltaTime;
        if (boostCooldownTimer <= 0) {
          boostReady = true;
          boostCooldownTimer = 0;
        }
        updateBoostUI();
        return;
      }
      
      if (isBoosting) {
        // Update boost timer
        boostTimer -= deltaTime;
        if (boostTimer <= 0) {
          // Boost ended, start cooldown
          isBoosting = false;
          boostTimer = 0;
          boostCooldownTimer = BOOST_COOLDOWN;
        }
        updateBoostUI();
      }
    }
    
    function updateBoostUI() {
      const boostMeter = document.getElementById('boost-meter');
      const boostStatus = document.getElementById('boost-status');
      const boostBtn = document.getElementById('mobile-boost-btn');
      
      if (!boostMeter || !boostStatus) return;
      
      if (isBoosting) {
        // Boost active - show remaining boost time
        const remainingPercent = (boostTimer / BOOST_DURATION) * 100;
        boostMeter.style.width = `${remainingPercent}%`;
        boostMeter.className = 'h-full bg-gradient-to-r from-yellow-400 to-orange-500 w-full transition-all duration-100';
        boostStatus.textContent = 'ACTIVE!';
        boostStatus.className = 'text-xs text-yellow-400 font-bold animate-pulse';
        if (boostBtn) {
          boostBtn.disabled = true;
          boostBtn.textContent = '🚀 BOOSTING!';
        }
      } else if (!boostReady) {
        // Cooldown - show charging
        const cooldownPercent = ((BOOST_COOLDOWN - boostCooldownTimer) / BOOST_COOLDOWN) * 100;
        boostMeter.style.width = `${cooldownPercent}%`;
        boostMeter.className = 'h-full bg-gradient-to-r from-gray-600 to-gray-500 w-full transition-all duration-100';
        boostStatus.textContent = 'CHARGING...';
        boostStatus.className = 'text-xs text-gray-400';
        if (boostBtn) {
          boostBtn.disabled = true;
          boostBtn.textContent = '🚀 CHARGING...';
        }
      } else {
        // Ready
        boostMeter.style.width = '100%';
        boostMeter.className = 'h-full bg-gradient-to-r from-cyan-500 to-purple-500 w-full transition-all duration-300';
        boostStatus.textContent = 'READY';
        boostStatus.className = 'text-xs text-cyan-400 font-bold';
        if (boostBtn) {
          boostBtn.disabled = false;
          boostBtn.textContent = '🚀 BOOST';
        }
      }
    }
    
    function togglePause() {
      const pauseBtn = document.getElementById('mobile-pause-btn');
      
      if (gameState === 'playing') {
        gameState = 'paused';
        cancelAnimationFrame(gameLoop);
        if (pauseBtn) pauseBtn.innerHTML = '▶️ RESUME';
      } else if (gameState === 'paused') {
        gameState = 'playing';
        lastTime = 0; // Reset to avoid large delta after pause
        gameLoop = requestAnimationFrame(update);
        if (pauseBtn) pauseBtn.innerHTML = '⏸️ PAUSE';
      }
    }
    
    function update(timestamp) {
      if (gameState !== 'playing') return;
      
      // Calculate delta time for frame-rate independent animation
      if (lastTime === 0) lastTime = timestamp;
      const deltaTime = timestamp - lastTime;
      lastTime = timestamp;
      
      // Normalize delta to target frame rate (60fps)
      const deltaMultiplier = deltaTime / TARGET_FRAME_TIME;
      
      frames++;
      
      // Clear canvas
      ctx.fillStyle = 'rgba(10, 22, 40, 0.3)';
      ctx.fillRect(0, 0, CANVAS_WIDTH, CANVAS_HEIGHT);
      
      // Draw stars
      drawStars();
      
      // Update difficulty
      difficultyMultiplier = 1 + (score / 5000);
      level = Math.floor(score / 1000) + 1;
      
      // Update boost
      updateBoost(deltaTime);
      
      // Player movement
      updatePlayer(deltaMultiplier);

      // Spawn asteroids (time-based instead of frame-based)
      asteroidSpawnTimer += deltaTime;
      const spawnInterval = Math.max(20, Math.floor(60 / difficultyMultiplier)) * TARGET_FRAME_TIME;
      if (asteroidSpawnTimer >= spawnInterval) {
        spawnAsteroid();
        asteroidSpawnTimer = 0;
      }

      // Spawn power-ups
      if (Math.random() < POWERUP_CHANCE * deltaMultiplier) {
        spawnPowerUp();
      }

      // Update entities with delta time
      updateAsteroids(deltaMultiplier);
      updatePowerUps(deltaMultiplier);
      updateParticles(deltaMultiplier);
      updateStars(deltaMultiplier);

      // Check collisions
      checkCollisions();

      // Draw entities
      drawPlayer();
      drawAsteroids();
      drawPowerUps();
      drawParticles();

      // Draw touch zone indicators on mobile
      if (isTouchDevice() && (touchState.left || touchState.right)) {
        drawTouchIndicators();
      }

      // Update score (time-based)
      score += Math.round(10 * deltaMultiplier);
      if (frames % 10 === 0) {
        updateUI();
        checkAchievements();
      }

      gameLoop = requestAnimationFrame(update);
    }
    
    // --- UPDATE FUNCTIONS ---
    function updatePlayer(deltaMultiplier) {
      // Calculate current speed (boost applies multiplier)
      const currentSpeed = isBoosting ? PLAYER_SPEED * BOOST_SPEED_MULTIPLIER : PLAYER_SPEED;
      
      // Movement - support both keyboard and touch
      if (keys['ArrowLeft'] || keys['a'] || keys['A'] || touchState.left) {
        player.velocity = -currentSpeed * deltaMultiplier;
      } else if (keys['ArrowRight'] || keys['d'] || keys['D'] || touchState.right) {
        player.velocity = currentSpeed * deltaMultiplier;
      } else {
        player.velocity *= 0.9; // Friction (applied per frame, not time-based for feel)
      }

      player.x += player.velocity;

      // Boundaries
      if (player.x < 0) player.x = 0;
      if (player.x > CANVAS_WIDTH - PLAYER_SIZE) player.x = CANVAS_WIDTH - PLAYER_SIZE;

      // Trail effect (enhanced during boost)
      const trailLength = isBoosting ? 20 : 10;
      const trailAlphaDecay = isBoosting ? 0.05 : 0.1;
      player.trail.push({ x: player.x, y: player.y + PLAYER_SIZE, alpha: 1 });
      if (player.trail.length > trailLength) player.trail.shift();
      player.trail.forEach(t => t.alpha -= trailAlphaDecay * deltaMultiplier);
      player.trail = player.trail.filter(t => t.alpha > 0);
    }
    
    function spawnAsteroid() {
      const size = Math.random() * 30 + 20;
      asteroids.push({
        x: Math.random() * (CANVAS_WIDTH - size),
        y: -size,
        width: size,
        height: size,
        speed: (ASTEROID_BASE_SPEED + Math.random() * 2) * difficultyMultiplier,
        rotation: 0,
        rotationSpeed: (Math.random() - 0.5) * 0.1,
        vertices: generateAsteroidVertices(size)
      });
    }
    
    function generateAsteroidVertices(size) {
      const vertices = [];
      const numVertices = 6 + Math.floor(Math.random() * 4);
      for (let i = 0; i < numVertices; i++) {
        const angle = (i / numVertices) * Math.PI * 2;
        const radius = size * (0.5 + Math.random() * 0.5);
        vertices.push({
          x: Math.cos(angle) * radius,
          y: Math.sin(angle) * radius
        });
      }
      return vertices;
    }
    
    function spawnPowerUp() {
      const types = ['score', 'shield', 'speed'];
      const type = types[Math.floor(Math.random() * types.length)];
      powerUps.push({
        x: Math.random() * (CANVAS_WIDTH - 30),
        y: -30,
        width: 30,
        height: 30,
        speed: 2,
        type: type,
        pulse: 0
      });
    }
    
    function updateAsteroids(deltaMultiplier) {
      asteroids.forEach((asteroid, index) => {
        asteroid.y += asteroid.speed * deltaMultiplier;
        asteroid.rotation += asteroid.rotationSpeed * deltaMultiplier;

        if (asteroid.y > CANVAS_HEIGHT) {
          asteroids.splice(index, 1);
        }
      });
    }
    
    function updatePowerUps(deltaMultiplier) {
      powerUps.forEach((powerUp, index) => {
        powerUp.y += powerUp.speed * deltaMultiplier;
        powerUp.pulse += 0.1 * deltaMultiplier;

        if (powerUp.y > CANVAS_HEIGHT) {
          powerUps.splice(index, 1);
        }
      });
    }
    
    function updateParticles(deltaMultiplier) {
      particles.forEach((particle, index) => {
        particle.x += particle.vx * deltaMultiplier;
        particle.y += particle.vy * deltaMultiplier;
        particle.life -= 0.02 * deltaMultiplier;
        particle.alpha = particle.life;

        if (particle.life <= 0) {
          particles.splice(index, 1);
        }
      });
    }
    
    // --- DRAW FUNCTIONS ---
    function updateStars(deltaMultiplier) {
      stars.forEach(star => {
        star.y += star.speed * deltaMultiplier;
        if (star.y > CANVAS_HEIGHT) {
          star.y = 0;
          star.x = Math.random() * CANVAS_WIDTH;
        }
      });
    }

    function drawStars() {
      stars.forEach(star => {
        ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
        ctx.fill();
      });
    }
    
    function drawPlayer() {
      // Trail (enhanced during boost)
      player.trail.forEach((t, i) => {
        const alpha = isBoosting ? t.alpha * 0.5 : t.alpha * 0.3;
        const width = isBoosting ? 25 - (i * 0.5) : 20;
        ctx.fillStyle = `rgba(0, 255, 255, ${alpha})`;
        ctx.fillRect(t.x + (PLAYER_SIZE - width) / 2, t.y, width, isBoosting ? 8 : 5);
      });
      
      // Ship body
      ctx.save();
      ctx.translate(player.x + PLAYER_SIZE / 2, player.y + PLAYER_SIZE / 2);
      
      // Glow effect (intense during boost)
      if (isBoosting) {
        ctx.shadowColor = '#ff00ff';
        ctx.shadowBlur = 30;
        
        // Boost aura
        ctx.strokeStyle = `rgba(255, 0, 255, ${0.3 + Math.random() * 0.3})`;
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(0, 0, PLAYER_SIZE * 0.8, 0, Math.PI * 2);
        ctx.stroke();
      } else {
        ctx.shadowColor = '#00ffff';
        ctx.shadowBlur = 20;
      }
      
      // Main body (purple tint during boost)
      ctx.fillStyle = isBoosting ? '#ff00ff' : '#00ffff';
      ctx.beginPath();
      ctx.moveTo(0, -PLAYER_SIZE / 2);
      ctx.lineTo(-PLAYER_SIZE / 2, PLAYER_SIZE / 2);
      ctx.lineTo(0, PLAYER_SIZE / 3);
      ctx.lineTo(PLAYER_SIZE / 2, PLAYER_SIZE / 2);
      ctx.closePath();
      ctx.fill();
      
      // Inner glow
      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.moveTo(0, -PLAYER_SIZE / 3);
      ctx.lineTo(-PLAYER_SIZE / 4, PLAYER_SIZE / 3);
      ctx.lineTo(0, PLAYER_SIZE / 4);
      ctx.lineTo(PLAYER_SIZE / 4, PLAYER_SIZE / 3);
      ctx.closePath();
      ctx.fill();
      
      // Engine flame (enhanced during boost)
      const baseFlameHeight = isBoosting ? 20 : 10;
      const flameVariation = isBoosting ? 15 : 10;
      const flameHeight = baseFlameHeight + Math.random() * flameVariation;
      
      // Outer flame (yellow during boost)
      ctx.fillStyle = isBoosting ? '#ffff00' : '#ff6600';
      ctx.beginPath();
      ctx.moveTo(-10, PLAYER_SIZE / 3);
      ctx.lineTo(0, PLAYER_SIZE / 3 + flameHeight * 1.2);
      ctx.lineTo(10, PLAYER_SIZE / 3);
      ctx.closePath();
      ctx.fill();
      
      // Inner flame
      ctx.fillStyle = isBoosting ? '#ff6600' : '#ffaa00';
      ctx.beginPath();
      ctx.moveTo(-6, PLAYER_SIZE / 3);
      ctx.lineTo(0, PLAYER_SIZE / 3 + flameHeight * 0.8);
      ctx.lineTo(6, PLAYER_SIZE / 3);
      ctx.closePath();
      ctx.fill();
      
      ctx.restore();
    }
    
    function drawAsteroids() {
      asteroids.forEach(asteroid => {
        ctx.save();
        ctx.translate(asteroid.x + asteroid.width / 2, asteroid.y + asteroid.height / 2);
        ctx.rotate(asteroid.rotation);
        
        ctx.strokeStyle = '#ff6b6b';
        ctx.fillStyle = 'rgba(255, 107, 107, 0.2)';
        ctx.lineWidth = 2;
        ctx.shadowColor = '#ff6b6b';
        ctx.shadowBlur = 10;
        
        ctx.beginPath();
        asteroid.vertices.forEach((vertex, i) => {
          if (i === 0) ctx.moveTo(vertex.x, vertex.y);
          else ctx.lineTo(vertex.x, vertex.y);
        });
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
        
        ctx.restore();
      });
    }
    
    function drawPowerUps() {
      powerUps.forEach(powerUp => {
        ctx.save();
        ctx.translate(powerUp.x + 15, powerUp.y + 15);
        
        const pulse = Math.sin(powerUp.pulse) * 3;
        
        let color, icon;
        switch (powerUp.type) {
          case 'score':
            color = '#ffd700';
            icon = '+';
            break;
          case 'shield':
            color = '#00ff00';
            icon = '🛡️';
            break;
          case 'speed':
            color = '#ff00ff';
            icon = '⚡';
            break;
        }
        
        ctx.shadowColor = color;
        ctx.shadowBlur = 15 + pulse;
        ctx.fillStyle = color;
        
        ctx.beginPath();
        ctx.arc(0, 0, 12, 0, Math.PI * 2);
        ctx.fill();
        
        ctx.fillStyle = '#000';
        ctx.font = '14px Arial';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(icon, 0, 0);
        
        ctx.restore();
      });
    }
    
    function drawParticles() {
      particles.forEach(particle => {
        ctx.fillStyle = `rgba(${particle.color}, ${particle.alpha})`;
        ctx.beginPath();
        ctx.arc(particle.x, particle.y, particle.size, 0, Math.PI * 2);
        ctx.fill();
      });
    }
    
    function drawTouchIndicators() {
      ctx.save();
      ctx.globalAlpha = 0.15;
      
      // Left zone
      if (touchState.left) {
        ctx.fillStyle = '#00ffff';
        ctx.fillRect(0, 0, CANVAS_WIDTH / 2, CANVAS_HEIGHT);
      }
      
      // Right zone
      if (touchState.right) {
        ctx.fillStyle = '#00ffff';
        ctx.fillRect(CANVAS_WIDTH / 2, 0, CANVAS_WIDTH / 2, CANVAS_HEIGHT);
      }
      
      ctx.restore();
    }
    
    function createExplosion(x, y, color = '255, 100, 100') {
      for (let i = 0; i < 20; i++) {
        const angle = (Math.PI * 2 / 20) * i;
        const speed = Math.random() * 5 + 2;
        particles.push({
          x: x,
          y: y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: 1,
          alpha: 1,
          size: Math.random() * 3 + 1,
          color: color
        });
      }
    }
    
    // --- COLLISION DETECTION ---
    function checkCollisions() {
      // Asteroid collisions
      asteroids.forEach((asteroid, asteroidIndex) => {
        if (rectIntersect(
          player.x + 5, player.y + 5, PLAYER_SIZE - 10, PLAYER_SIZE - 10,
          asteroid.x, asteroid.y, asteroid.width, asteroid.height
        )) {
          createExplosion(player.x + PLAYER_SIZE / 2, player.y + PLAYER_SIZE / 2, '0, 255, 255');
          gameOver();
        }
      });
      
      // Power-up collisions
      powerUps.forEach((powerUp, index) => {
        if (rectIntersect(
          player.x, player.y, PLAYER_SIZE, PLAYER_SIZE,
          powerUp.x, powerUp.y, powerUp.width, powerUp.height
        )) {
          collectPowerUp(powerUp, index);
        }
      });
    }
    
    function rectIntersect(x1, y1, w1, h1, x2, y2, w2, h2) {
      return x1 < x2 + w2 && x1 + w1 > x2 && y1 < y2 + h2 && y1 + h1 > y2;
    }
    
    function collectPowerUp(powerUp, index) {
      powerUps.splice(index, 1);
      createExplosion(powerUp.x + 15, powerUp.y + 15, '255, 215, 0');
      
      switch (powerUp.type) {
        case 'score':
          score += 500;
          break;
        case 'shield':
          // Shield effect would go here
          score += 200;
          break;
        case 'speed':
          // Speed boost would go here
          score += 200;
          break;
      }
      
      updateUI();
    }
    
    // --- UI UPDATES ---
    let lastScore = 0;
    let lastLevel = 1;
    
    function updateUI() {
      const scoreEl = document.getElementById('score');
      const highScoreEl = document.getElementById('high-score');
      const levelEl = document.getElementById('level');
      
      // Update score with highlight animation on significant changes
      const scoreDisplay = document.querySelector('.score-display');
      if (score > lastScore && (score - lastScore) >= 100) {
        scoreDisplay.classList.add('score-highlight');
        setTimeout(() => scoreDisplay.classList.remove('score-highlight'), 500);
      }
      
      scoreEl.textContent = score.toLocaleString();
      levelEl.textContent = level;
      
      // Highlight on new high score
      if (score > highScore) {
        highScore = score;
        localStorage.setItem('spaceDodgerHighScore', highScore);
        highScoreEl.textContent = highScore.toLocaleString();
        highScoreEl.parentElement.classList.add('score-highlight');
        setTimeout(() => highScoreEl.parentElement.classList.remove('score-highlight'), 600);
      }
      
      // Highlight on level up
      if (level > lastLevel) {
        levelEl.parentElement.classList.add('score-highlight');
        setTimeout(() => levelEl.parentElement.classList.remove('score-highlight'), 600);
      }
      
      lastScore = score;
      lastLevel = level;
    }
    
    // --- ACHIEVEMENTS ---
    // Track which tiers were achieved during gameplay (for display purposes)
    function checkAchievements() {
      const tiers = [
        { key: 'bronze', minScore: 1000, name: 'Bronze Space Pilot', emoji: '🥉' },
        { key: 'silver', minScore: 5000, name: 'Silver Space Pilot', emoji: '🥈' },
        { key: 'gold', minScore: 10000, name: 'Gold Space Pilot', emoji: '🥇' },
        { key: 'platinum', minScore: 25000, name: 'Platinum Space Ace', emoji: '💎' }
      ];
      
      for (const tier of tiers) {
        if (score >= tier.minScore && !earnedTiers.has(tier.key)) {
          earnedTiers.add(tier.key);
          // Add to available credentials for claiming at game end
          availableCredentials.push({
            key: tier.key,
            name: tier.name,
            emoji: tier.emoji,
            score: score,
            claimed: false
          });
        }
      }
    }
    
    async function claimCredential(tierKey) {
      const credential = availableCredentials.find(c => c.key === tierKey && !c.claimed);
      if (!credential) return;
      
      try {
        // First validate the achievement on the backend
        const { data, error } = await actions.validateAchievement({
          score: credential.score,
          tier: tierKey
        });

        if (error) {
          console.error('Failed to validate achievement:', error);
          showClaimError(tierKey, 'Validation failed');
          return;
        }

        // Issue credential using Partner Connect SDK template-based approach
        const templateAliases = {
          bronze: import.meta.env.LEARNCARD_TEMPLATE_BRONZE || 'bronze-space-pilot',
          silver: import.meta.env.LEARNCARD_TEMPLATE_SILVER || 'silver-space-pilot',
          gold: import.meta.env.LEARNCARD_TEMPLATE_GOLD || 'gold-space-pilot',
          platinum: import.meta.env.LEARNCARD_TEMPLATE_PLATINUM || 'platinum-space-ace'
        };

        const templateAlias = templateAliases[tierKey];
        
        const response = await learnCard.sendCredential({
          templateAlias: templateAlias,
          templateData: {
            score: credential.score.toString(),
            tierName: data.name,
            tierDescription: data.description,
            achievementDate: new Date().toISOString()
          }
        });
        
        if (response.credentialUri) {
          credential.claimed = true;
          showClaimedConfirmation(tierKey);
          updateCredentialOffersUI();
        }
      } catch (err) {
        console.error('Credential claim error:', err);
        showClaimError(tierKey, err.message || 'Failed to claim');
      }
    }
    
    function showClaimedConfirmation(tierKey) {
      const tierEmojis = {
        bronze: '🥉',
        silver: '🥈',
        gold: '🥇',
        platinum: '💎'
      };
      
      const tierNames = {
        bronze: 'BRONZE PILOT',
        silver: 'SILVER PILOT',
        gold: 'GOLD PILOT',
        platinum: 'PLATINUM ACE'
      };
      
      const tierColors = {
        bronze: 'from-orange-600 to-amber-600',
        silver: 'from-gray-500 to-slate-500',
        gold: 'from-yellow-500 to-amber-500',
        platinum: 'from-purple-600 to-pink-600'
      };
      
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 bg-gradient-to-r ${tierColors[tierKey]} p-4 rounded-2xl shadow-2xl z-50 animate-slide-up border border-white/10`;
      notification.id = `claim-notification-${tierKey}`;
      notification.innerHTML = `
        <div class="flex items-center gap-4">
          <span class="text-5xl filter drop-shadow-lg">${tierEmojis[tierKey]}</span>
          <div>
            <div class="font-black text-white tracking-wider flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
              CREDENTIAL CLAIMED!
            </div>
            <div class="text-white/90 font-semibold">${tierNames[tierKey]} added to your wallet</div>
          </div>
        </div>
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => notification.remove(), 300);
      }, 4000);
    }
    
    function showClaimError(tierKey, message) {
      const notification = document.createElement('div');
      notification.className = 'fixed top-4 right-4 bg-gradient-to-r from-red-600 to-rose-600 p-4 rounded-2xl shadow-2xl z-50 animate-slide-up border border-white/10';
      notification.innerHTML = `
        <div class="flex items-center gap-4">
          <span class="text-4xl">⚠️</span>
          <div>
            <div class="font-black text-white tracking-wider flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              CLAIM FAILED
            </div>
            <div class="text-white/90 font-medium">${message}</div>
          </div>
        </div>
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        notification.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => notification.remove(), 300);
      }, 4000);
    }
    
    // --- GAME OVER ---
    function gameOver() {
      gameState = 'gameover';
      cancelAnimationFrame(gameLoop);
      
      document.getElementById('final-score').textContent = score.toLocaleString();
      
      // Show earned achievements
      const achievementsContainer = document.getElementById('achievements-earned');
      achievementsContainer.innerHTML = '';
      
      const tierEmojis = {
        bronze: '🥉',
        silver: '🥈',
        gold: '🥇',
        platinum: '💎'
      };
      
      earnedTiers.forEach(tier => {
        const badge = document.createElement('span');
        badge.className = 'text-3xl achievement-badge';
        badge.textContent = tierEmojis[tier];
        achievementsContainer.appendChild(badge);
      });
      
      // Show credential claim UI
      updateCredentialOffersUI();
      
      document.getElementById('game-over-screen').classList.remove('hidden');
    }
    
    function updateCredentialOffersUI() {
      const offersContainer = document.getElementById('credential-offers');
      offersContainer.innerHTML = '';
      
      if (!isAuthenticated && score >= 1000) {
        offersContainer.innerHTML = `
          <div class="credential-card p-4 text-center">
            <div class="text-yellow-300/90 mb-3 font-semibold">Connect LearnCard to claim your credentials!</div>
            <button id="connect-wallet-btn" class="btn btn-gold btn-sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <span>Connect Now</span>
            </button>
          </div>
        `;
        document.getElementById('connect-wallet-btn').addEventListener('click', authenticate);
      } else if (isAuthenticated && availableCredentials.length > 0) {
        // Group by claimed status
        const unclaimed = availableCredentials.filter(c => !c.claimed);
        const claimed = availableCredentials.filter(c => c.claimed);
        
        if (unclaimed.length > 0) {
          const unclaimedSection = document.createElement('div');
          unclaimedSection.className = 'credential-card p-4 mb-3';
          unclaimedSection.innerHTML = `
            <div class="text-cyan-300/90 mb-3 font-black text-sm tracking-wider uppercase flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Credentials Available to Claim
            </div>
            <div id="unclaimed-list" class="space-y-2"></div>
          `;
          offersContainer.appendChild(unclaimedSection);
          
          const unclaimedList = unclaimedSection.querySelector('#unclaimed-list');
          unclaimed.forEach(cred => {
            const claimRow = document.createElement('div');
            claimRow.className = 'flex items-center justify-between bg-black/40 rounded-xl p-3 border border-cyan-500/20';
            claimRow.innerHTML = `
              <div class="flex items-center gap-3">
                <span class="text-3xl filter drop-shadow-lg">${cred.emoji}</span>
                <div>
                  <div class="text-white font-bold text-sm">${cred.name}</div>
                  <div class="text-xs text-cyan-400/70">Score: ${cred.score.toLocaleString()}</div>
                </div>
              </div>
              <button class="claim-btn btn btn-primary btn-sm" data-tier="${cred.key}" style="display:inline-flex;visibility:visible;opacity:1;">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>Claim</span>
              </button>
            `;
            unclaimedList.appendChild(claimRow);
            
            claimRow.querySelector('.claim-btn').addEventListener('click', () => claimCredential(cred.key));
          });
        }
        
        if (claimed.length > 0) {
          const claimedSection = document.createElement('div');
          claimedSection.className = 'credential-card p-4 border-green-500/30 bg-green-900/10';
          claimedSection.innerHTML = `
            <div class="text-green-300/90 mb-2 text-sm font-black tracking-wider uppercase flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Claimed Credentials
            </div>
            <div id="claimed-list" class="flex flex-wrap gap-2 justify-center"></div>
          `;
          offersContainer.appendChild(claimedSection);
          
          const claimedList = claimedSection.querySelector('#claimed-list');
          claimed.forEach(cred => {
            const badge = document.createElement('span');
            badge.className = 'inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-500/20 rounded-full text-sm border border-green-500/30';
            badge.innerHTML = `<span class="text-lg">${cred.emoji}</span> <span class="text-green-200 font-semibold">${cred.name}</span>`;
            claimedList.appendChild(badge);
          });
        }
      } else if (isAuthenticated && score < 1000) {
        offersContainer.innerHTML = `
          <div class="credential-card p-4 text-center border-gray-500/30 bg-gray-800/30">
            <div class="text-gray-400/90 flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              Reach 1,000 points to earn your first credential!
            </div>
          </div>
        `;
      }
    }
    
    // Start initialization when DOM is ready
    window.onload = init;
  </script>
</body>
</html>
