# Healthcare Credentials Demo App - Environment Configuration

# Required: Issuer seed for signing credentials (hex string)
LEARNCARD_ISSUER_SEED=your_hex_seed_here

# Optional: Host origin for LearnCard connection (defaults to production)
# LEARNCARD_HOST_ORIGIN=https://learncard.app

# Optional: Custom URIs for testing
# CONTRACT_URI=lc:network:network.learncard.com/trpc:contract:...
# BOOST_URI=lc:network:network.learncard.com/trpc:boost:...
