# Northstar Learning — LearnCard Configuration
# Copy this file to .env and fill in your own values.

# ---------------------------------------------------------------------------
# Required: Seed phrase for Northstar's LearnCard issuer instance.
# Hex-encoded; used to deterministically derive Northstar's issuer DID and
# signing keys. The same seed always produces the same DID — so across
# dev runs the boost templates and the VCs that carry their URIs stay
# stable. Swap the seed in production; never commit real seeds to git.
#
# Generate a fresh seed with: openssl rand -hex 32
# ---------------------------------------------------------------------------
LEARNCARD_ISSUER_SEED=your_secure_seed_here

# ---------------------------------------------------------------------------
# Optional: LearnCard host origin for postMessage validation.
# The partner-connect SDK uses this to verify which LearnCard instance it's
# talking to. Defaults to http://localhost:3000; override for staging/prod.
# ---------------------------------------------------------------------------
# LEARNCARD_HOST_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional: LearnCard Network API (brain-service) URL.
# Only the /course email-claim flow needs the network — it calls
# `initLearnCard({ seed, network: LEARNCARD_NETWORK_URL })` to reach the
# Universal Inbox and generate claim URLs.
#
#   • Leave unset to hit production network.learncard.com.
#   • Set to your brain-service URL for local dev — the action normalizes
#     the value, so either `http://localhost:4000` OR
#     `http://localhost:4000/trpc` works. (Under the hood the tRPC router
#     mounts under `/trpc`; the action auto-appends if missing.)
#
# The practice and coaching flows don't touch the network, so this is
# irrelevant for them.
# ---------------------------------------------------------------------------
# LEARNCARD_NETWORK_URL=http://localhost:4000
