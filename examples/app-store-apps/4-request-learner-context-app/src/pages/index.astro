---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>AI Tutor Context Demo</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="gradient-bg min-h-screen flex items-center justify-center p-4">
        <div class="w-full max-w-5xl relative z-10">
            <div class="text-center mb-8">
                <div
                    class="inline-flex items-center justify-center w-20 h-20 mb-4 rounded-2xl bg-white/20 backdrop-blur-lg border border-white/30 shadow-2xl"
                >
                    <span class="text-5xl">🎓</span>
                </div>
                <h1 class="text-5xl md:text-6xl font-bold text-white mb-3">AI Tutor Context</h1>
                <p class="text-xl text-white/80 font-light">Powered by requestLearnerContext</p>
            </div>

            <div class="glass-card rounded-3xl p-8 md:p-10 space-y-8">
                <div
                    id="setup-banner"
                    class="bg-gradient-to-r from-amber-100 to-orange-100 border-l-4 border-amber-500 p-5 rounded-2xl shadow-lg"
                >
                    <div class="flex items-start gap-4">
                        <div
                            class="flex-shrink-0 w-12 h-12 bg-amber-500 rounded-xl flex items-center justify-center text-2xl shadow-lg"
                        >
                            ⚠️
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-amber-900 text-lg mb-1">Setup Required</h3>
                            <p class="text-amber-800 leading-relaxed">
                                This app must be installed in the LearnCard App Store and have a
                                ConsentFlow contract configured.
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    id="status-box"
                    class="flex items-center gap-4 p-5 rounded-2xl bg-indigo-100 border-2 border-indigo-300 shadow-lg"
                >
                    <div
                        id="status-icon"
                        class="w-12 h-12 rounded-xl bg-indigo-500 flex items-center justify-center text-2xl shadow-lg"
                    >
                        🔌
                    </div>
                    <div class="flex-1">
                        <p id="auth-status" class="font-semibold text-indigo-900 text-lg">
                            Ready to Connect
                        </p>
                    </div>
                </div>

                <div id="auth-section" class="text-center py-8">
                    <button
                        id="connect-btn"
                        class="btn-primary text-white font-bold py-4 px-10 rounded-2xl text-lg shadow-2xl"
                    >
                        Connect with LearnCard
                    </button>
                </div>
                <div id="controls" class="hidden space-y-8">
                    <!-- Consent Section -->
                    <div
                        id="consent-section"
                        class="bg-gradient-to-r from-indigo-50 to-blue-50 rounded-2xl p-6 border-2 border-indigo-200 text-center"
                    >
                        <div
                            class="w-16 h-16 mx-auto mb-4 rounded-full bg-indigo-100 flex items-center justify-center"
                        >
                            <svg
                                class="w-8 h-8 text-indigo-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                ></path>
                            </svg>
                        </div>
                        <h3 class="text-lg font-bold text-gray-800 mb-2">
                            Data Sharing Consent Required
                        </h3>
                        <p class="text-gray-600 mb-4">
                            This app needs your permission to access your learning data for AI
                            personalization.
                        </p>
                        <button
                            id="request-consent-btn"
                            class="btn-primary text-white font-bold py-3 px-8 rounded-xl shadow-lg"
                        >
                            Grant Access
                        </button>
                    </div>

                    <!-- Request Options (hidden until consent granted) -->
                    <div id="request-options" class="hidden space-y-6">
                        <div class="glass-panel rounded-2xl p-6 space-y-6">
                            <h3 class="text-xl font-bold text-gray-800">Request Options</h3>

                            <div class="space-y-4">
                                <div
                                    class="flex items-center justify-between p-4 rounded-xl border-2 border-gray-200"
                                >
                                    <div class="flex items-center gap-3">
                                        <span class="text-2xl">📜</span>
                                        <div>
                                            <span class="font-semibold block">Credentials</span>
                                            <span class="text-sm text-gray-500"
                                                >Include your earned credentials and badges</span
                                            >
                                        </div>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input
                                            type="checkbox"
                                            id="include-credentials"
                                            class="sr-only peer"
                                            checked
                                        />
                                        <div
                                            class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"
                                        >
                                        </div>
                                    </label>
                                </div>

                                <div
                                    class="flex items-center justify-between p-4 rounded-xl border-2 border-gray-200"
                                >
                                    <div class="flex items-center gap-3">
                                        <span class="text-2xl">👤</span>
                                        <div>
                                            <span class="font-semibold block">Personal Data</span>
                                            <span class="text-sm text-gray-500"
                                                >Include your name, bio, and other profile info</span
                                            >
                                        </div>
                                    </div>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input
                                            type="checkbox"
                                            id="include-personal-data"
                                            class="sr-only peer"
                                        />
                                        <div
                                            class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"
                                        >
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-sm font-semibold mb-2">Format</label>
                                    <select
                                        id="format"
                                        class="w-full border-2 border-gray-200 rounded-xl px-4 py-3"
                                    >
                                        <option value="prompt">LLM Prompt</option>
                                        <option value="structured">Structured Data</option>
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold mb-2"
                                        >Detail Level</label
                                    >
                                    <select
                                        id="detail-level"
                                        class="w-full border-2 border-gray-200 rounded-xl px-4 py-3"
                                    >
                                        <option value="compact">Compact</option>
                                        <option value="expanded">Expanded</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <button
                            id="request-btn"
                            class="btn-primary w-full text-white font-bold py-5 rounded-2xl text-lg shadow-2xl"
                        >
                            Get Learner Context
                        </button>

                        <!-- AI Session Test Section -->
                        <div
                            class="bg-gradient-to-r from-purple-50 to-pink-50 rounded-2xl p-6 border-2 border-purple-200"
                        >
                            <h3 class="text-lg font-bold text-gray-800 mb-2">🤖 AI Session Test</h3>
                            <p class="text-sm text-gray-600 mb-4">
                                Create a test AI Session credential. Uses ConsentFlow contract if
                                write permission granted, otherwise falls back to manual send.
                            </p>

                            <!-- Preset Buttons -->
                            <div class="mb-6">
                                <h4 class="text-sm font-semibold text-gray-700 mb-3">Quick Presets</h4>
                                <div class="grid grid-cols-2 gap-3">
                                    <button
                                        id="preset-learning-btn"
                                        class="btn-secondary text-white font-bold py-3 px-4 rounded-xl text-sm shadow-lg"
                                        data-preset="learning"
                                    >
                                        📚 Learning Session
                                    </button>
                                    <button
                                        id="preset-coding-btn"
                                        class="btn-secondary text-white font-bold py-3 px-4 rounded-xl text-sm shadow-lg"
                                        data-preset="coding"
                                    >
                                        💻 Coding Practice
                                    </button>
                                    <button
                                        id="preset-design-btn"
                                        class="btn-secondary text-white font-bold py-3 px-4 rounded-xl text-sm shadow-lg"
                                        data-preset="design"
                                    >
                                        🎨 Design Workshop
                                    </button>
                                    <button
                                        id="preset-minimal-btn"
                                        class="btn-secondary text-white font-bold py-3 px-4 rounded-xl text-sm shadow-lg"
                                        data-preset="minimal"
                                    >
                                        ⚡ Minimal Test
                                    </button>
                                </div>
                            </div>

                            <!-- Custom Form -->
                            <div class="border-t border-purple-200 pt-4 mb-4">
                                <h4 class="text-sm font-semibold text-gray-700 mb-3">Custom Session</h4>
                                <div class="space-y-3">
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Session Title</label>
                                        <input
                                            type="text"
                                            id="custom-session-title"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                            placeholder="My Custom Learning Session"
                                        />
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Summary Title</label>
                                        <input
                                            type="text"
                                            id="custom-summary-title"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                            placeholder="Session Summary"
                                        />
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Summary Text</label>
                                        <textarea
                                            id="custom-summary-text"
                                            rows="2"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                            placeholder="Brief description of what was learned..."
                                        ></textarea>
                                    </div>
                                    <div class="grid grid-cols-2 gap-3">
                                        <div>
                                            <label class="block text-xs font-medium text-gray-600 mb-1">Learned Items (one per line)</label>
                                            <textarea
                                                id="custom-learned"
                                                rows="3"
                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                                placeholder="Item 1&#10;Item 2&#10;Item 3"
                                            ></textarea>
                                        </div>
                                        <div>
                                            <label class="block text-xs font-medium text-gray-600 mb-1">Skills (Title: Description)</label>
                                            <textarea
                                                id="custom-skills"
                                                rows="3"
                                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                                placeholder="Skill 1: Description&#10;Skill 2: Description"
                                            ></textarea>
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Next Steps (Title: Description)</label>
                                        <textarea
                                            id="custom-next-steps"
                                            rows="2"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                            placeholder="Step 1: What to do next&#10;Step 2: Another action"
                                        ></textarea>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-medium text-gray-600 mb-1">Reflections (Title: Description)</label>
                                        <textarea
                                            id="custom-reflections"
                                            rows="2"
                                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
                                            placeholder="Reflection 1: Key insight&#10;Reflection 2: Takeaway"
                                        ></textarea>
                                    </div>
                                    <button
                                        id="create-custom-session-btn"
                                        class="btn-secondary w-full text-white font-bold py-3 rounded-xl text-sm shadow-lg"
                                    >
                                        Create Custom Session
                                    </button>
                                </div>
                            </div>

                            <div id="ai-session-result" class="hidden mt-4 space-y-3">
                                <div class="glass-panel rounded-xl p-4">
                                    <span class="text-sm font-medium">Topic URI:</span>
                                    <code
                                        id="topic-uri-display"
                                        class="text-purple-600 text-xs break-all block mt-1"></code>
                                </div>
                                <div class="glass-panel rounded-xl p-4">
                                    <span class="text-sm font-medium">Session Credential:</span>
                                    <code
                                        id="session-credential-display"
                                        class="text-purple-600 text-xs break-all block mt-1"></code>
                                </div>
                                <div class="glass-panel rounded-xl p-4">
                                    <span class="text-sm font-medium">New Topic?</span>
                                    <span id="is-new-topic-display" class="text-gray-800"></span>
                                </div>
                            </div>
                        </div>

                        <div id="results" class="hidden space-y-6">
                            <h3 class="text-xl font-bold text-gray-800">Results</h3>

                            <div class="result-card rounded-2xl p-6">
                                <pre
                                    id="prompt-display"
                                    class="prompt-display text-green-300 text-sm whitespace-pre-wrap">
                                </pre>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div class="glass-panel rounded-xl p-5">
                                    <span class="text-sm font-medium">DID:</span>
                                    <code id="did-display" class="text-indigo-600 text-sm break-all"
                                    ></code>
                                </div>

                                <div class="glass-panel rounded-xl p-5">
                                    <span class="text-sm font-medium">Name:</span>
                                    <span id="name-display" class="text-gray-800"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                import { createPartnerConnect } from '@learncard/partner-connect';
                const learnCard = createPartnerConnect();

                let sessionCount = 0;

                // AI Session Presets
                const AI_SESSION_PRESETS: Record<string, {
                    sessionTitle: string;
                    summaryTitle: string;
                    summary: string;
                    learned: string[];
                    skills: Array<{ title: string; description: string }>;
                    nextSteps: Array<{
                        title: string;
                        description: string;
                        keywords: {
                            occupations: string[];
                            careers: string[];
                            jobs: string[];
                            skills: string[];
                            fieldOfStudy: string;
                        };
                    }>;
                    reflections: Array<{ title: string; description: string }>;
                }> = {
                    learning: {
                        sessionTitle: 'General Learning Session',
                        summaryTitle: 'Learning Summary',
                        summary: 'A comprehensive learning session covering various educational topics and skill development areas.',
                        learned: [
                            'Understanding core concepts',
                            'Applying theoretical knowledge',
                            'Developing practical skills',
                            'Building foundational understanding',
                        ],
                        skills: [
                            { title: 'Critical Thinking', description: 'Analyzing and evaluating information objectively' },
                            { title: 'Problem Solving', description: 'Developing solutions to complex challenges' },
                        ],
                        nextSteps: [
                            { title: 'Practice Exercises', description: 'Complete related practice problems', keywords: { occupations: ['Student'], careers: ['Education'], jobs: ['Learner'], skills: ['Practice', 'Study'], fieldOfStudy: 'General Education' } },
                            { title: 'Review Materials', description: 'Revisit key concepts for retention', keywords: { occupations: ['Student'], careers: ['Education'], jobs: ['Learner'], skills: ['Review', 'Memorization'], fieldOfStudy: 'General Education' } },
                        ],
                        reflections: [
                            { title: 'Learning Progress', description: 'Made significant progress in understanding the material' },
                            { title: 'Areas for Improvement', description: 'Need to focus on practical application' },
                        ],
                    },
                    coding: {
                        sessionTitle: 'Coding Practice Session',
                        summaryTitle: 'Programming Practice',
                        summary: 'Hands-on coding session focused on algorithm design, code implementation, and debugging techniques.',
                        learned: [
                            'Algorithm optimization techniques',
                            'Code refactoring best practices',
                            'Debugging strategies',
                            'Design pattern applications',
                        ],
                        skills: [
                            { title: 'TypeScript Programming', description: 'Writing type-safe JavaScript applications' },
                            { title: 'Problem Decomposition', description: 'Breaking complex problems into manageable pieces' },
                        ],
                        nextSteps: [
                            { title: 'Build a Project', description: 'Apply learned concepts in a real project', keywords: { occupations: ['Software Developer'], careers: ['Technology'], jobs: ['Developer'], skills: ['TypeScript', 'JavaScript'], fieldOfStudy: 'Computer Science' } },
                            { title: 'Code Review', description: 'Review and refactor existing code', keywords: { occupations: ['Software Engineer'], careers: ['Technology'], jobs: ['Engineer'], skills: ['Code Review', 'Refactoring'], fieldOfStudy: 'Software Engineering' } },
                        ],
                        reflections: [
                            { title: 'Technical Growth', description: 'Improved coding efficiency and code quality' },
                            { title: 'Tool Mastery', description: 'Better understanding of development tools and workflows' },
                        ],
                    },
                    design: {
                        sessionTitle: 'Design Workshop',
                        summaryTitle: 'Design Exploration',
                        summary: 'Creative design session exploring visual concepts, user experience principles, and design system patterns.',
                        learned: [
                            'Visual hierarchy principles',
                            'Color theory applications',
                            'Typography best practices',
                            'User-centered design approaches',
                        ],
                        skills: [
                            { title: 'UI Design', description: 'Creating intuitive and beautiful user interfaces' },
                            { title: 'UX Research', description: 'Understanding user needs and behaviors' },
                        ],
                        nextSteps: [
                            { title: 'Create Mockups', description: 'Design high-fidelity interface mockups', keywords: { occupations: ['UI Designer'], careers: ['Design'], jobs: ['Designer'], skills: ['Figma', 'UI Design'], fieldOfStudy: 'Design' } },
                            { title: 'User Testing', description: 'Conduct usability tests with real users', keywords: { occupations: ['UX Researcher'], careers: ['Design'], jobs: ['Researcher'], skills: ['User Testing', 'Research'], fieldOfStudy: 'User Experience' } },
                        ],
                        reflections: [
                            { title: 'Creative Process', description: 'Discovered new approaches to design challenges' },
                            { title: 'User Focus', description: 'Better appreciation for user-centered design' },
                        ],
                    },
                    minimal: {
                        sessionTitle: 'Quick Test Session',
                        summaryTitle: 'Minimal Test',
                        summary: 'A minimal test session for quick validation.',
                        learned: ['Basic concept testing'],
                        skills: [{ title: 'Testing', description: 'Basic test execution' }],
                        nextSteps: [{ title: 'Validate', description: 'Check if everything works', keywords: { occupations: ['Tester'], careers: ['QA'], jobs: ['QA Engineer'], skills: ['Testing'], fieldOfStudy: 'Quality Assurance' } }],
                        reflections: [{ title: 'Quick Check', description: 'Everything appears to be functioning' }],
                    },
                };

                // Helper: Parse text area content into array of strings
                function parseLines(value: string): string[] {
                    return value.split('\n').map(line => line.trim()).filter(line => line.length > 0);
                }

                // Helper: Parse skills from "Title: Description" format
                function parseSkills(value: string): Array<{ title: string; description: string }> {
                    return parseLines(value).map(line => {
                        const separatorIndex = line.indexOf(':');
                        if (separatorIndex > 0) {
                            return {
                                title: line.substring(0, separatorIndex).trim(),
                                description: line.substring(separatorIndex + 1).trim(),
                            };
                        }
                        return { title: line, description: '' };
                    });
                }

                // Helper: Parse next steps from "Title: Description" format with default keywords
                function parseNextSteps(value: string): Array<{
                    title: string;
                    description: string;
                    keywords: {
                        occupations: string[];
                        careers: string[];
                        jobs: string[];
                        skills: string[];
                        fieldOfStudy: string;
                    };
                }> {
                    return parseLines(value).map(line => {
                        const separatorIndex = line.indexOf(':');
                        const title = separatorIndex > 0 ? line.substring(0, separatorIndex).trim() : line;
                        const description = separatorIndex > 0 ? line.substring(separatorIndex + 1).trim() : '';
                        return {
                            title,
                            description,
                            keywords: {
                                occupations: ['Professional'],
                                careers: ['General'],
                                jobs: ['Specialist'],
                                skills: ['General Skills'],
                                fieldOfStudy: 'General',
                            },
                        };
                    });
                }

                // Helper: Parse reflections from "Title: Description" format
                function parseReflections(value: string): Array<{ title: string; description: string }> {
                    return parseLines(value).map(line => {
                        const separatorIndex = line.indexOf(':');
                        if (separatorIndex > 0) {
                            return {
                                title: line.substring(0, separatorIndex).trim(),
                                description: line.substring(separatorIndex + 1).trim(),
                            };
                        }
                        return { title: line, description: '' };
                    });
                }

                // Helper: Build AI session payload from preset
                function buildPresetPayload(presetKey: string) {
                    sessionCount++;
                    const preset = AI_SESSION_PRESETS[presetKey];
                    if (!preset) return null;
                    return {
                        sessionTitle: `${preset.sessionTitle} #${sessionCount}`,
                        summaryData: {
                            title: `${preset.summaryTitle} ${sessionCount}`,
                            summary: preset.summary,
                            learned: preset.learned,
                            skills: preset.skills,
                            nextSteps: preset.nextSteps,
                            reflections: preset.reflections,
                        },
                        metadata: {
                            testSession: true,
                            createdAt: new Date().toISOString(),
                            sessionNumber: sessionCount,
                            preset: presetKey,
                        },
                    };
                }

                // Helper: Build AI session payload from custom form
                function buildCustomPayload() {
                    const sessionTitleInput = document.getElementById('custom-session-title') as HTMLInputElement | null;
                    const summaryTitleInput = document.getElementById('custom-summary-title') as HTMLInputElement | null;
                    const summaryTextInput = document.getElementById('custom-summary-text') as HTMLTextAreaElement | null;
                    const learnedInput = document.getElementById('custom-learned') as HTMLTextAreaElement | null;
                    const skillsInput = document.getElementById('custom-skills') as HTMLTextAreaElement | null;
                    const nextStepsInput = document.getElementById('custom-next-steps') as HTMLTextAreaElement | null;
                    const reflectionsInput = document.getElementById('custom-reflections') as HTMLTextAreaElement | null;

                    if (!sessionTitleInput || !summaryTitleInput || !summaryTextInput || !learnedInput || !skillsInput || !nextStepsInput || !reflectionsInput) {
                        return null;
                    }

                    const sessionTitle = sessionTitleInput.value.trim();
                    const summaryTitle = summaryTitleInput.value.trim();
                    const summaryText = summaryTextInput.value.trim();

                    if (!sessionTitle || !summaryTitle || !summaryText) {
                        alert('Please fill in at least the Session Title, Summary Title, and Summary Text.');
                        return null;
                    }

                    sessionCount++;
                    return {
                        sessionTitle: `${sessionTitle} #${sessionCount}`,
                        summaryData: {
                            title: `${summaryTitle} ${sessionCount}`,
                            summary: summaryText,
                            learned: parseLines(learnedInput.value),
                            skills: parseSkills(skillsInput.value),
                            nextSteps: parseNextSteps(nextStepsInput.value),
                            reflections: parseReflections(reflectionsInput.value),
                        },
                        metadata: {
                            testSession: true,
                            createdAt: new Date().toISOString(),
                            sessionNumber: sessionCount,
                            preset: 'custom',
                        },
                    };
                }

                // Helper: Send AI session and display results
                async function sendAiSession(payload: ReturnType<typeof buildCustomPayload>, button: HTMLButtonElement | null, originalText: string): Promise<void> {
                    if (!payload) return;
                    if (button) {
                        button.disabled = true;
                        button.textContent = 'Creating...';
                    }

                    try {
                        const result = await learnCard.sendAiSessionCredential(payload);

                        const topicUriDisplay = document.getElementById('topic-uri-display');
                        const sessionCredentialDisplay = document.getElementById('session-credential-display');
                        const isNewTopicDisplay = document.getElementById('is-new-topic-display');
                        const aiSessionResult = document.getElementById('ai-session-result');
                        const authStatus = document.getElementById('auth-status');

                        if (topicUriDisplay) topicUriDisplay.textContent = result.topicUri || 'N/A';
                        if (sessionCredentialDisplay) sessionCredentialDisplay.textContent = result.sessionCredentialUri || 'N/A';
                        if (isNewTopicDisplay) isNewTopicDisplay.textContent = result.isNewTopic ? 'Yes (first session)' : 'No (existing topic)';
                        if (aiSessionResult) aiSessionResult.classList.remove('hidden');
                        if (authStatus) authStatus.textContent = 'AI Session created! Check your AI Sessions page in LearnCard.';
                    } catch (error: unknown) {
                        const authStatus = document.getElementById('auth-status');
                        const errorMessage = error instanceof Error ? error.message : String(error);
                        if (authStatus) authStatus.textContent = 'AI Session failed: ' + errorMessage;
                    } finally {
                        if (button) {
                            button.disabled = false;
                            button.textContent = originalText;
                        }
                    }
                }

                async function handleConnect() {
                    try {
                        await learnCard.requestIdentity();
                        const authStatus = document.getElementById('auth-status');
                        const authSection = document.getElementById('auth-section');
                        const controls = document.getElementById('controls');
                        const setupBanner = document.getElementById('setup-banner');
                        if (authStatus) authStatus.textContent = 'Connected!';
                        if (authSection) authSection.classList.add('hidden');
                        if (controls) controls.classList.remove('hidden');
                        if (setupBanner) setupBanner.classList.add('hidden');
                    } catch (error: unknown) {
                        const authStatus = document.getElementById('auth-status');
                        const errorMessage = error instanceof Error ? error.message : String(error);
                        if (authStatus) authStatus.textContent = 'Failed: ' + errorMessage;
                    }
                }

                async function handleRequestConsent() {
                    const btn = document.getElementById('request-consent-btn') as HTMLButtonElement | null;
                    if (!btn) return;
                    btn.disabled = true;
                    btn.textContent = 'Requesting...';

                    try {
                        // Request consent for data access
                        const consentResult = await learnCard.requestConsent();

                        if (consentResult.granted) {
                            // Consent granted - show request options
                            const consentSection = document.getElementById('consent-section');
                            const requestOptions = document.getElementById('request-options');
                            const authStatus = document.getElementById('auth-status');
                            if (consentSection) consentSection.classList.add('hidden');
                            if (requestOptions) requestOptions.classList.remove('hidden');
                            if (authStatus) authStatus.textContent = 'Consent granted! Configure your request below.';
                        } else {
                            // Consent denied
                            btn.disabled = false;
                            btn.textContent = 'Grant Access';
                            const authStatus = document.getElementById('auth-status');
                            if (authStatus) authStatus.textContent = 'Consent denied. Cannot access learner context without permission.';
                        }
                    } catch (error: unknown) {
                        btn.disabled = false;
                        btn.textContent = 'Grant Access';
                        const authStatus = document.getElementById('auth-status');
                        const errorMessage = error instanceof Error ? error.message : String(error);
                        if (authStatus) authStatus.textContent = 'Consent request failed: ' + errorMessage;
                    }
                }

                async function handleRequest() {
                    const credsToggle = document.getElementById('include-credentials') as HTMLInputElement | null;
                    const personalDataToggle = document.getElementById('include-personal-data') as HTMLInputElement | null;
                    const formatSelect = document.getElementById('format') as HTMLSelectElement | null;
                    const detailSelect = document.getElementById('detail-level') as HTMLSelectElement | null;

                    try {
                        const context = await learnCard.requestLearnerContext({
                            includeCredentials: credsToggle?.checked ?? true,
                            includePersonalData: personalDataToggle?.checked ?? false,
                            format: (formatSelect?.value as 'prompt' | 'structured') ?? 'prompt',
                            detailLevel: (detailSelect?.value as 'compact' | 'expanded') ?? 'expanded',
                        });

                        const promptDisplay = document.getElementById('prompt-display');
                        const didDisplay = document.getElementById('did-display');
                        const nameDisplay = document.getElementById('name-display');
                        const results = document.getElementById('results');
                        const authStatus = document.getElementById('auth-status');

                        if (promptDisplay) promptDisplay.textContent = context.prompt;
                        if (didDisplay) didDisplay.textContent = context.did;
                        if (nameDisplay) nameDisplay.textContent = context.displayName || 'N/A';
                        if (results) results.classList.remove('hidden');
                        if (authStatus) authStatus.textContent = 'Context retrieved successfully!';
                    } catch (error: unknown) {
                        const authStatus = document.getElementById('auth-status');
                        const errorMessage = error instanceof Error ? error.message : String(error);
                        if (authStatus) authStatus.textContent = 'Request failed: ' + errorMessage;
                    }
                }

                // Handler for preset buttons
                async function handlePresetClick(event: Event) {
                    const target = event.currentTarget as HTMLButtonElement;
                    const preset = target.dataset.preset as keyof typeof AI_SESSION_PRESETS;
                    if (!preset || !(preset in AI_SESSION_PRESETS)) return;

                    const originalText = target.textContent || '';
                    const payload = buildPresetPayload(preset);
                    await sendAiSession(payload, target, originalText);
                }

                // Handler for custom form submission
                async function handleCustomSession() {
                    const btn = document.getElementById('create-custom-session-btn') as HTMLButtonElement | null;
                    const payload = buildCustomPayload();
                    if (!payload || !btn) return;

                    const originalText = btn.textContent || '';
                    await sendAiSession(payload, btn, originalText);
                }

                // Event listeners
                const connectBtn = document.getElementById('connect-btn');
                const requestConsentBtn = document.getElementById('request-consent-btn');
                const requestBtn = document.getElementById('request-btn');
                const customSessionBtn = document.getElementById('create-custom-session-btn');

                if (connectBtn) connectBtn.addEventListener('click', handleConnect);
                if (requestConsentBtn) requestConsentBtn.addEventListener('click', handleRequestConsent);
                if (requestBtn) requestBtn.addEventListener('click', handleRequest);
                if (customSessionBtn) customSessionBtn.addEventListener('click', handleCustomSession);

                // Preset button listeners
                ['preset-learning-btn', 'preset-coding-btn', 'preset-design-btn', 'preset-minimal-btn'].forEach(id => {
                    const btn = document.getElementById(id);
                    if (btn) btn.addEventListener('click', handlePresetClick);
                });
            </script>
        </div>
    </body>
</html>
