# Optional: LearnCard host origin for postMessage validation.
# Use your local LearnCard app when running this example in development.
HOST_ORIGIN=http://localhost:3000

# Required for the server-side synced-credential query button.
# Generate one with: openssl rand -hex 32
LEARNCARD_ISSUER_SEED=YOUR_ISSUERS_SEED

# Optional: point initLearnCard({ network }) at a local brain-service.
# The app normalizes bare hosts like http://localhost:4000 to /trpc automatically.
LEARNCARD_NETWORK_URL=http://localhost:4000

# Required for contract-scoped consent + synced-credential queries in this demo.
# Use the app listing's configured consent contract URI.
APP_CONTRACT_URI=YOUR_APPS_URI
