---
const config = {
    optionalBoostUri: import.meta.env.BOOST_URI || undefined,
};
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LC Partner Demo: Identity & Actions</title>
        <meta
            name="description"
            content="LearnCard Partner Connect demo for zero-config credentials, consent, publishing, notifications, and counters"
        />
        <link rel="stylesheet" href="/src/styles/global.css" />
    </head>

    <body>
        <div id="app-container" class="card bg-white p-8 rounded-2xl shadow-2xl space-y-6">
            <h1 class="text-3xl font-extrabold text-gray-800">LearnCard Partner App Demo</h1>

            <div id="status-box" class="p-4 rounded-xl border-l-4 font-medium" role="alert">
                <p id="auth-status" class="text-gray-700">Initializing connection...</p>
            </div>

            <div id="controls" class="space-y-5">
                <p class="text-lg font-semibold text-indigo-700">Zero-config Partner Connect demos</p>

                <div class="bg-sky-50 rounded-xl p-4 space-y-3 border border-sky-200">
                    <div class="flex items-start justify-between gap-4 flex-wrap">
                        <div>
                            <p class="text-lg font-semibold text-sky-700">1. Identity / SSO</p>
                            <p class="text-sm text-gray-600">
                                Request identity when available. Other sections keep working even if this fails.
                            </p>
                        </div>

                        <button
                            id="request-identity-btn"
                            class="bg-sky-600 hover:bg-sky-700 text-white font-bold py-3 px-4 rounded-xl transition duration-200 shadow-lg"
                        >
                            Request Identity
                        </button>
                    </div>

                    <div id="identity-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-green-50 rounded-xl p-4 space-y-4 border border-green-200">
                    <div>
                        <p class="text-lg font-semibold text-green-700">2. Inline credential template</p>
                        <p class="text-sm text-gray-600">
                            Alias <span class="font-mono">demo-achievement</span> auto-creates and versions a template. No pre-created boost required.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Course Name</label>
                            <input
                                type="text"
                                id="course-name"
                                value="LearnCard 101"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                            />
                        </div>

                        <div class="flex items-end">
                            <p class="text-xs text-gray-500 leading-relaxed">
                                Template variables come from <span class="font-mono">templateData.courseName</span>. Blank it out to demo validation errors.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-2">
                        <button
                            id="validate-template-btn"
                            class="bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Validate Template
                        </button>
                        <button
                            id="issue-cred-btn"
                            class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Issue Credential
                        </button>
                        <button
                            id="check-credential-btn"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Check User Status
                        </button>
                        <button
                            id="check-issuance-btn"
                            class="bg-indigo-500 hover:bg-indigo-600 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Check Issuance
                        </button>
                        <button
                            id="get-recipients-btn"
                            class="bg-indigo-400 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Get Recipients
                        </button>
                    </div>

                    <div id="credential-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>

                    <div class="border-t border-green-200 pt-4 space-y-3">
                        <div>
                            <p class="text-sm font-semibold text-indigo-700">Optional arbitrary boost URI</p>
                            <p class="text-xs text-gray-500">
                                Paste any boost URI to inspect it. Leave empty to keep using the zero-config alias flow above.
                            </p>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Boost URI</label>
                                <input
                                    type="text"
                                    id="boost-uri-input"
                                    value={config.optionalBoostUri}
                                    placeholder="lc:network:...:boost:abc123"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                />
                            </div>

                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">Recipient (optional)</label>
                                <input
                                    type="text"
                                    id="boost-recipient-input"
                                    placeholder="Profile ID or DID; leave empty to use your own DID"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                                />
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                            <button
                                id="optional-boost-issuance-btn"
                                class="bg-indigo-300 hover:bg-indigo-400 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                            >
                                Check Optional Boost Issuance
                            </button>
                            <button
                                id="optional-boost-recipients-btn"
                                class="bg-indigo-200 hover:bg-indigo-300 text-gray-800 font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                            >
                                Get Optional Boost Recipients
                            </button>
                        </div>

                        <div id="boost-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                    </div>
                </div>

                <div class="bg-orange-50 rounded-xl p-4 space-y-3 border border-orange-200">
                    <div>
                        <p class="text-lg font-semibold text-orange-700">3. Scoped consent</p>
                        <p class="text-sm text-gray-600">
                            Zero-config scopes: read <span class="font-medium">Achievement</span> credentials and personal field <span class="font-medium">name</span>.
                        </p>
                    </div>

                    <ul class="text-sm text-gray-600 list-disc list-inside space-y-1">
                        <li><span class="font-medium">credentialCategories</span>: Achievement</li>
                        <li><span class="font-medium">personalFields</span>: name</li>
                        <li><span class="font-medium">reason</span>: Show off what LearnCard can share</li>
                    </ul>

                    <button
                        id="request-consent-btn"
                        class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Request Scoped Consent
                    </button>

                    <div id="consent-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-yellow-50 rounded-xl p-4 space-y-3 border border-yellow-200">
                    <p class="text-lg font-semibold text-yellow-700">4. Launch AI tutor</p>
                    <button
                        id="launch-ai-btn"
                        class="w-full bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Launch AI Tutor
                    </button>
                    <div id="launch-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-purple-50 rounded-xl p-4 space-y-3 border border-purple-200">
                    <p class="text-lg font-semibold text-purple-700">5. Request credential search</p>
                    <button
                        id="ask-cred-btn"
                        class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Request Credential Search
                    </button>
                    <div id="cred-search-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-pink-50 rounded-xl p-4 space-y-3 border border-pink-200">
                    <p class="text-lg font-semibold text-pink-700">6. Request specific credential</p>
                    <button
                        id="ask-specific-cred-btn"
                        class="w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Request Specific Credential
                    </button>
                    <div id="specific-cred-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-rose-50 rounded-xl p-4 space-y-3 border border-rose-200">
                    <p class="text-lg font-semibold text-rose-700">7. Initiate existing template issue</p>
                    <p class="text-sm text-gray-600">
                        Still useful for existing boosts. This demo is now optional and no longer required for the happy path.
                    </p>
                    <button
                        id="initiate-template-issue-btn"
                        class="w-full bg-rose-600 hover:bg-rose-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Initiate Template Issue
                    </button>
                    <div id="template-issue-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-cyan-50 rounded-xl p-4 space-y-3 border border-cyan-200">
                    <p class="text-lg font-semibold text-cyan-700">8. Learner context</p>
                    <button
                        id="learner-context-btn"
                        class="w-full bg-cyan-600 hover:bg-cyan-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Request Learner Context
                    </button>
                    <div id="learner-context-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                    <pre
                        id="learner-context-json"
                        class="hidden bg-white rounded-lg p-3 border border-cyan-200 text-xs text-gray-700 overflow-x-auto whitespace-pre-wrap"
                    ></pre>
                </div>

                <hr class="border-gray-200 my-2" />
                <p class="text-lg font-semibold text-teal-700">9. App Notifications</p>

                <div class="bg-teal-50 rounded-xl p-4 space-y-3 border border-teal-200">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Title</label>
                            <input
                                type="text"
                                id="notif-title"
                                value="Achievement Unlocked!"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            />
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Category</label>
                            <select
                                id="notif-category"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            >
                                <option value="reward">reward</option>
                                <option value="announcement">announcement</option>
                                <option value="status">status</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Body</label>
                        <input
                            type="text"
                            id="notif-body"
                            value="You earned the Gold Star badge"
                            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                        />
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Action Path</label>
                            <input
                                type="text"
                                id="notif-action-path"
                                value="/achievements"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            />
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Priority</label>
                            <select
                                id="notif-priority"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            >
                                <option value="normal">normal</option>
                                <option value="high">high</option>
                            </select>
                        </div>
                    </div>

                    <button
                        id="send-notif-btn"
                        class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        Send Notification
                    </button>

                    <div id="notif-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <hr class="border-gray-200 my-2" />
                <p class="text-lg font-semibold text-amber-700">10. App Counters</p>

                <div class="bg-amber-50 rounded-xl p-4 space-y-3 border border-amber-200">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Counter Key</label>
                            <input
                                type="text"
                                id="counter-key"
                                value="coins"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                            />
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Amount</label>
                            <input
                                type="number"
                                id="counter-amount"
                                value="1"
                                step="1"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                            />
                        </div>
                    </div>

                    <div class="grid grid-cols-3 gap-2">
                        <button
                            id="increment-counter-btn"
                            class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-2.5 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Increment
                        </button>

                        <button
                            id="get-counter-btn"
                            class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Get Counter
                        </button>

                        <button
                            id="get-all-counters-btn"
                            class="bg-amber-400 hover:bg-amber-500 text-white font-bold py-2.5 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Get All
                        </button>
                    </div>

                    <div id="counter-display" class="bg-white rounded-lg p-3 border border-amber-200">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Counter Values</span>
                            <span id="counter-updated" class="text-xs text-gray-400"></span>
                        </div>

                        <div id="counter-values" class="space-y-1">
                            <p class="text-sm text-gray-400 italic">No counters loaded yet</p>
                        </div>
                    </div>

                    <div id="counter-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                </div>

                <div class="bg-slate-50 rounded-xl p-4 space-y-3 border border-slate-200">
                    <div>
                        <p class="text-lg font-semibold text-slate-700">11. Publish</p>
                        <p class="text-sm text-gray-600">
                            Mock mode captures a manifest automatically as you use zero-config templates, consent scopes, counters, notifications, and feature launches.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                        <button
                            id="captured-manifest-btn"
                            class="bg-slate-700 hover:bg-slate-800 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Get Captured Manifest
                        </button>
                        <button
                            id="publish-url-btn"
                            class="bg-slate-600 hover:bg-slate-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            Get Publish URL
                        </button>
                    </div>

                    <div id="publish-result" class="hidden text-sm p-3 rounded-lg whitespace-pre-wrap"></div>
                    <div id="publish-link" class="hidden text-sm p-3 rounded-lg bg-white border border-slate-200"></div>
                    <pre
                        id="manifest-json"
                        class="hidden bg-white rounded-lg p-3 border border-slate-200 text-xs text-gray-700 overflow-x-auto whitespace-pre-wrap"
                    ></pre>
                </div>
            </div>
        </div>

        <script define:vars={{ config }}>
            window.__LC_CONFIG = config;
        </script>

        <script>
            import { createPartnerConnect } from '@learncard/partner-connect';

            const learnCard = createPartnerConnect();

            const statusBox = document.getElementById('status-box');
            const statusText = document.getElementById('auth-status');
            const identityResult = document.getElementById('identity-result');
            const manifestPre = document.getElementById('manifest-json');
            const publishLink = document.getElementById('publish-link');
            const learnerContextPre = document.getElementById('learner-context-json');

            const INLINE_TEMPLATE_ALIAS = 'demo-achievement';
            const INLINE_TEMPLATE = {
                name: 'Demo Achievement: {{courseName}}',
                description: 'Awarded for completing {{courseName}} in the Partner Connect demo.',
                achievementType: 'Badge',
                criteria: {
                    narrative: 'Complete the Partner Connect walkthrough and claim the demo achievement.',
                },
            };
            const CONSENT_SCOPES = {
                read: {
                    credentialCategories: ['Achievement'],
                    personalFields: ['name'],
                },
                reason: 'Show off what LearnCard can share',
            };

            const appState = {
                identity: null,
                lastIssuedCredentialId: null,
            };

            function setBanner(message, type = 'info') {
                statusText.textContent = message;
                statusBox.className = 'p-4 rounded-xl border-l-4 font-medium';

                if (type === 'success') {
                    statusBox.classList.add('bg-green-100', 'border-green-500', 'text-green-800');
                } else if (type === 'error') {
                    statusBox.classList.add('bg-red-100', 'border-red-500', 'text-red-800');
                } else if (type === 'warning') {
                    statusBox.classList.add('bg-amber-100', 'border-amber-500', 'text-amber-800');
                } else {
                    statusBox.classList.add('bg-indigo-100', 'border-indigo-500', 'text-indigo-800');
                }
            }

            function showResult(elementId, message, type = 'info') {
                const element = document.getElementById(elementId);
                if (!element) return;

                element.className = 'text-sm p-3 rounded-lg whitespace-pre-wrap';

                if (type === 'success') {
                    element.classList.add('bg-green-100', 'text-green-800');
                } else if (type === 'error') {
                    element.classList.add('bg-red-100', 'text-red-800');
                } else {
                    element.classList.add('bg-blue-100', 'text-blue-800');
                }

                element.textContent = message;
                element.classList.remove('hidden');
            }

            function hideElement(element) {
                if (!element) return;
                element.classList.add('hidden');
                element.textContent = '';
            }

            function formatError(error) {
                const code = error?.code || 'UNKNOWN_ERROR';
                const message = error?.message || 'Unknown error';
                return `${code}: ${message}`;
            }

            function getTemplateData() {
                return {
                    courseName: document.getElementById('course-name').value.trim(),
                };
            }

            function getBoostUri() {
                return document.getElementById('boost-uri-input').value.trim();
            }

            function getBoostRecipient() {
                return document.getElementById('boost-recipient-input').value.trim();
            }

            function renderIdentity(identity) {
                appState.identity = identity;
                showResult(
                    'identity-result',
                    `Signed in as ${identity.user.did}\nJWT received and ready for your backend session flow.`,
                    'success'
                );

                const modeLabel = typeof learnCard.isMocked === 'function' && learnCard.isMocked()
                    ? 'Mock host active.'
                    : 'Connected to LearnCard host.';
                setBanner(`${modeLabel} Identity is ready.`, 'success');
            }

            async function requestIdentityForSession(resultId = 'identity-result') {
                try {
                    const identity = await learnCard.requestIdentity();
                    renderIdentity(identity);
                    return identity;
                } catch (error) {
                    const message = formatError(error);
                    if (error?.code === 'LC_UNAUTHENTICATED') {
                        showResult(
                            resultId,
                            `Sign-in required. ${message}`,
                            'error'
                        );
                        setBanner(
                            'Connected, but no LearnCard user session is available yet. Other demos remain usable.',
                            'warning'
                        );
                        return null;
                    }

                    showResult(resultId, message, 'error');
                    setBanner(`Connection issue: ${message}`, 'error');
                    return null;
                }
            }

            async function ensureIdentity(resultId, actionLabel) {
                if (appState.identity) return appState.identity;

                const identity = await requestIdentityForSession(resultId);
                if (!identity) {
                    showResult(
                        resultId,
                        `Sign-in required for ${actionLabel}. Try "Request Identity" after logging into LearnCard.`,
                        'error'
                    );
                }

                return identity;
            }

            function renderRecipients(records) {
                return records
                    .map(record => {
                        const name = record.recipientDisplayName || record.recipientProfileId;
                        return `${name} (${record.status})`;
                    })
                    .join(', ');
            }

            async function handleRequestIdentity() {
                showResult('identity-result', 'Requesting identity...', 'info');
                await requestIdentityForSession('identity-result');
            }

            function handleValidateTemplate() {
                hideElement(manifestPre);
                hideElement(publishLink);

                try {
                    const validation = learnCard.validateCredentialTemplate(
                        INLINE_TEMPLATE,
                        getTemplateData()
                    );

                    if (validation.valid) {
                        showResult(
                            'credential-result',
                            'Template is valid. The inline template and templateData are ready to send.',
                            'success'
                        );
                    } else {
                        const details = validation.errors
                            .map(error => `${error.path}: ${error.message}`)
                            .join('\n');
                        showResult(
                            'credential-result',
                            `TEMPLATE_DATA_INVALID: Offline validation failed.\n${details}`,
                            'error'
                        );
                    }
                } catch (error) {
                    showResult('credential-result', formatError(error), 'error');
                }
            }

            async function handleIssueCredential() {
                showResult(
                    'credential-result',
                    'Issuing inline credential template. Waiting for LearnCard...',
                    'info'
                );

                try {
                    const response = await learnCard.sendCredential({
                        alias: INLINE_TEMPLATE_ALIAS,
                        template: INLINE_TEMPLATE,
                        templateData: getTemplateData(),
                        preventDuplicateClaim: true,
                    });

                    if (response.credentialId) {
                        appState.lastIssuedCredentialId = response.credentialId;
                    }

                    if (response.alreadyClaimed) {
                        showResult(
                            'credential-result',
                            `Already claimed. URI: ${response.credentialUri}\nVersion: ${response.templateVersion ?? 'unknown'}`,
                            'info'
                        );
                        return;
                    }

                    showResult(
                        'credential-result',
                        `Issued credential.\nURI: ${response.credentialUri}\nBoost URI: ${response.boostUri}\nVersion: ${response.templateVersion ?? 'unknown'}`,
                        'success'
                    );
                } catch (error) {
                    showResult('credential-result', formatError(error), 'error');
                }
            }

            async function handleCheckCredentialStatus() {
                showResult('credential-result', 'Checking credential status...', 'info');

                try {
                    const result = await learnCard.checkUserHasCredential({
                        templateAlias: INLINE_TEMPLATE_ALIAS,
                    });

                    if (result.hasCredential) {
                        showResult(
                            'credential-result',
                            `User has credential.\nStatus: ${result.status || 'claimed'}\nURI: ${result.credentialUri || 'n/a'}`,
                            'success'
                        );
                    } else if (result.status === 'revoked') {
                        showResult(
                            'credential-result',
                            'Credential was previously issued but is now revoked.',
                            'error'
                        );
                    } else {
                        showResult(
                            'credential-result',
                            'User does not have the demo achievement yet.',
                            'info'
                        );
                    }
                } catch (error) {
                    showResult('credential-result', formatError(error), 'error');
                }
            }

            async function handleCheckIssuanceStatus() {
                showResult('credential-result', 'Checking issuance status for your DID...', 'info');

                const identity = await ensureIdentity('credential-result', 'issuance status checks');
                if (!identity) return;

                try {
                    const result = await learnCard.getTemplateIssuanceStatus({
                        templateAlias: INLINE_TEMPLATE_ALIAS,
                        recipient: identity.user.did,
                    });

                    if (result.sent) {
                        showResult(
                            'credential-result',
                            `Credential was sent.\nStatus: ${result.status}\nSent: ${result.sentDate || 'unknown'}\nClaimed: ${result.claimedDate || 'not yet'}\nURI: ${result.credentialUri || 'n/a'}`,
                            'success'
                        );
                    } else {
                        showResult(
                            'credential-result',
                            'No issuance record yet for your current DID.',
                            'info'
                        );
                    }
                } catch (error) {
                    showResult('credential-result', formatError(error), 'error');
                }
            }

            async function handleGetTemplateRecipients() {
                showResult('credential-result', 'Loading template recipients...', 'info');

                try {
                    const result = await learnCard.getTemplateRecipients({
                        templateAlias: INLINE_TEMPLATE_ALIAS,
                        limit: 10,
                    });

                    if (result.records.length === 0) {
                        showResult('credential-result', 'No recipients found yet.', 'info');
                        return;
                    }

                    showResult(
                        'credential-result',
                        `Found ${result.records.length} recipient(s).\n${renderRecipients(result.records)}${result.hasMore ? '\nMore recipients are available.' : ''}`,
                        'success'
                    );
                } catch (error) {
                    showResult('credential-result', formatError(error), 'error');
                }
            }

            async function handleOptionalBoostIssuance() {
                const boostUri = getBoostUri();
                if (!boostUri) {
                    showResult(
                        'boost-result',
                        'Optional section: paste a boost URI if you want to inspect an existing host template.',
                        'info'
                    );
                    return;
                }

                showResult('boost-result', 'Checking optional boost issuance...', 'info');

                let recipient = getBoostRecipient();
                if (!recipient) {
                    const identity = await ensureIdentity('boost-result', 'optional boost issuance checks');
                    if (!identity) return;
                    recipient = identity.user.did;
                }

                try {
                    const result = await learnCard.getTemplateIssuanceStatus({
                        boostUri,
                        recipient,
                    });

                    if (result.sent) {
                        showResult(
                            'boost-result',
                            `Boost issuance found.\nStatus: ${result.status}\nSent: ${result.sentDate || 'unknown'}\nClaimed: ${result.claimedDate || 'not yet'}\nURI: ${result.credentialUri || 'n/a'}`,
                            'success'
                        );
                    } else {
                        showResult('boost-result', 'No issuance found for that boost and recipient.', 'info');
                    }
                } catch (error) {
                    showResult('boost-result', formatError(error), 'error');
                }
            }

            async function handleOptionalBoostRecipients() {
                const boostUri = getBoostUri();
                if (!boostUri) {
                    showResult(
                        'boost-result',
                        'Optional section: paste a boost URI if you want recipient data for an existing host template.',
                        'info'
                    );
                    return;
                }

                showResult('boost-result', 'Loading optional boost recipients...', 'info');

                try {
                    const result = await learnCard.getTemplateRecipients({
                        boostUri,
                        limit: 10,
                    });

                    if (result.records.length === 0) {
                        showResult('boost-result', 'No recipients found for that boost.', 'info');
                        return;
                    }

                    showResult(
                        'boost-result',
                        `Found ${result.records.length} recipient(s).\n${renderRecipients(result.records)}${result.hasMore ? '\nMore recipients are available.' : ''}`,
                        'success'
                    );
                } catch (error) {
                    showResult('boost-result', formatError(error), 'error');
                }
            }

            async function handleRequestConsent() {
                showResult('consent-result', 'Requesting scoped consent...', 'info');

                try {
                    const response = await learnCard.requestConsent(CONSENT_SCOPES);
                    showResult(
                        'consent-result',
                        response.granted
                            ? 'Consent granted for Achievement credentials + name.'
                            : 'Consent denied.',
                        response.granted ? 'success' : 'info'
                    );
                } catch (error) {
                    showResult('consent-result', formatError(error), 'error');
                }
            }

            async function handleLaunchFeature() {
                showResult('launch-result', 'Launching AI tutor...', 'info');

                try {
                    await learnCard.launchFeature(
                        '/ai/topics?shortCircuitStep=newTopic&selectedAppId=null',
                        'Summarize the postMessage security model for me.'
                    );
                    showResult('launch-result', 'AI tutor launch requested.', 'success');
                } catch (error) {
                    showResult('launch-result', formatError(error), 'error');
                }
            }

            async function handleAskCredential() {
                showResult('cred-search-result', 'Requesting credential search...', 'info');

                try {
                    const response = await learnCard.askCredentialSearch({
                        query: [
                            {
                                type: 'QueryByTitle',
                                credentialQuery: {
                                    reason: 'We need to verify your teamwork skills',
                                    title: 'Capstone',
                                },
                            },
                        ],
                        challenge: `challenge-${Date.now()}-${Math.random().toString(36).slice(2, 9)}`,
                        domain: window.location.hostname,
                    });

                    if (response?.verifiablePresentation) {
                        const credentials = Array.isArray(
                            response.verifiablePresentation.verifiableCredential
                        )
                            ? response.verifiablePresentation.verifiableCredential.length
                            : 0;

                        showResult(
                            'cred-search-result',
                            `Received a verifiable presentation with ${credentials} credential(s).`,
                            'success'
                        );
                    } else {
                        showResult('cred-search-result', 'No credential was shared.', 'info');
                    }
                } catch (error) {
                    showResult('cred-search-result', formatError(error), 'error');
                }
            }

            async function handleAskSpecificCredential() {
                const defaultId = appState.lastIssuedCredentialId || 'demo-credential-id-12345';
                const credentialId = prompt(
                    'Enter a credential ID to request (or use the last issued credential ID):',
                    defaultId
                );

                if (!credentialId) {
                    showResult('specific-cred-result', 'Request cancelled.', 'info');
                    return;
                }

                showResult('specific-cred-result', 'Requesting specific credential...', 'info');

                try {
                    const response = await learnCard.askCredentialSpecific(credentialId);

                    if (response.credential) {
                        showResult('specific-cred-result', 'Specific credential returned successfully.', 'success');
                    } else {
                        showResult('specific-cred-result', 'No credential returned.', 'info');
                    }
                } catch (error) {
                    showResult('specific-cred-result', formatError(error), 'error');
                }
            }

            async function handleInitiateTemplateIssue() {
                const defaultBoost = getBoostUri();
                const templateId = prompt(
                    'Enter an existing boost/template URI to issue:',
                    defaultBoost || ''
                );

                if (!templateId) {
                    showResult('template-issue-result', 'Template issue cancelled.', 'info');
                    return;
                }

                const recipientsInput = prompt(
                    'Optional draft recipients (comma-separated DIDs):',
                    ''
                );
                const draftRecipients = recipientsInput
                    ? recipientsInput
                          .split(',')
                          .map(recipient => recipient.trim())
                          .filter(Boolean)
                    : [];

                showResult('template-issue-result', 'Opening template issue flow...', 'info');

                try {
                    const response = await learnCard.initiateTemplateIssue(templateId, draftRecipients);
                    showResult(
                        'template-issue-result',
                        response.issued
                            ? 'Template issued successfully.'
                            : 'User cancelled the template issue flow.',
                        response.issued ? 'success' : 'info'
                    );
                } catch (error) {
                    showResult('template-issue-result', formatError(error), 'error');
                }
            }

            async function handleLearnerContext() {
                showResult('learner-context-result', 'Requesting learner context...', 'info');
                hideElement(learnerContextPre);

                try {
                    const context = await learnCard.requestLearnerContext({
                        includeCredentials: true,
                        waitForSync: true,
                        format: 'structured',
                    });

                    showResult(
                        'learner-context-result',
                        `Learner context status: ${context.status || 'ready'}\nDID: ${context.did}`,
                        'success'
                    );
                    learnerContextPre.textContent = JSON.stringify(context, null, 2);
                    learnerContextPre.classList.remove('hidden');
                } catch (error) {
                    showResult('learner-context-result', formatError(error), 'error');
                }
            }

            async function handleSendNotification() {
                const title = document.getElementById('notif-title').value.trim();
                const body = document.getElementById('notif-body').value.trim();
                const actionPath = document.getElementById('notif-action-path').value.trim();
                const category = document.getElementById('notif-category').value;
                const priority = document.getElementById('notif-priority').value;

                if (!title && !body) {
                    showResult('notif-result', 'Please provide at least a title or body.', 'error');
                    return;
                }

                showResult('notif-result', 'Sending notification...', 'info');

                try {
                    const result = await learnCard.sendNotification({
                        title: title || undefined,
                        body: body || undefined,
                        actionPath: actionPath || undefined,
                        category: category || undefined,
                        priority,
                    });

                    showResult(
                        'notif-result',
                        result.sent ? 'Notification sent.' : 'Notification was not sent.',
                        result.sent ? 'success' : 'info'
                    );
                } catch (error) {
                    showResult('notif-result', formatError(error), 'error');
                }
            }

            function renderCounters(counters) {
                const container = document.getElementById('counter-values');
                const timestamp = document.getElementById('counter-updated');

                if (!counters || counters.length === 0) {
                    container.innerHTML = '<p class="text-sm text-gray-400 italic">No counters found</p>';
                    timestamp.textContent = '';
                    return;
                }

                container.innerHTML = counters
                    .map(counter => {
                        const time = counter.updatedAt
                            ? new Date(counter.updatedAt).toLocaleTimeString()
                            : 'never';
                        return `
                            <div class="flex items-center justify-between py-1.5 px-2 rounded-md hover:bg-amber-50 transition">
                                <span class="font-mono text-sm font-semibold text-gray-700">${counter.key}</span>
                                <div class="flex items-center gap-3">
                                    <span class="text-lg font-bold text-amber-700">${counter.value}</span>
                                    <span class="text-xs text-gray-400">${time}</span>
                                </div>
                            </div>
                        `;
                    })
                    .join('');

                timestamp.textContent = `Updated ${new Date().toLocaleTimeString()}`;
            }

            async function refreshAllCounters() {
                const result = await learnCard.getCounters();
                renderCounters(result.counters);
                return result;
            }

            async function handleIncrementCounter() {
                const key = document.getElementById('counter-key').value.trim();
                const amount = parseInt(document.getElementById('counter-amount').value, 10);

                if (!key) {
                    showResult('counter-result', 'Please enter a counter key.', 'error');
                    return;
                }

                if (Number.isNaN(amount) || !Number.isInteger(amount) || amount === 0) {
                    showResult('counter-result', 'Amount must be a non-zero integer.', 'error');
                    return;
                }

                showResult('counter-result', `Incrementing ${key} by ${amount}...`, 'info');

                try {
                    const result = await learnCard.incrementCounter(key, amount);
                    showResult(
                        'counter-result',
                        `${result.key}: ${result.previousValue} → ${result.newValue}`,
                        'success'
                    );
                    try {
                        await refreshAllCounters();
                    } catch (error) {
                        showResult('counter-result', `Increment worked, but refresh failed.\n${formatError(error)}`, 'error');
                    }
                } catch (error) {
                    showResult('counter-result', formatError(error), 'error');
                }
            }

            async function handleGetCounter() {
                const key = document.getElementById('counter-key').value.trim();

                if (!key) {
                    showResult('counter-result', 'Please enter a counter key.', 'error');
                    return;
                }

                showResult('counter-result', `Reading ${key}...`, 'info');

                try {
                    const result = await learnCard.getCounter(key);
                    showResult(
                        'counter-result',
                        `${result.key} = ${result.value}${result.updatedAt ? `\nLast updated: ${new Date(result.updatedAt).toLocaleString()}` : ''}`,
                        'success'
                    );
                    try {
                        await refreshAllCounters();
                    } catch (error) {
                        showResult('counter-result', `Counter read worked, but refresh failed.\n${formatError(error)}`, 'error');
                    }
                } catch (error) {
                    showResult('counter-result', formatError(error), 'error');
                }
            }

            async function handleGetAllCounters() {
                showResult('counter-result', 'Loading counters...', 'info');

                try {
                    const result = await refreshAllCounters();
                    showResult(
                        'counter-result',
                        `Found ${result.counters.length} counter${result.counters.length === 1 ? '' : 's'}.`,
                        result.counters.length > 0 ? 'success' : 'info'
                    );
                } catch (error) {
                    renderCounters([]);
                    showResult('counter-result', formatError(error), 'error');
                }
            }

            async function handleCapturedManifest() {
                hideElement(publishLink);
                showResult('publish-result', 'Reading captured manifest...', 'info');

                try {
                    const manifest = learnCard.getCapturedManifest?.();
                    if (!manifest) {
                        hideElement(manifestPre);
                        showResult(
                            'publish-result',
                            'No captured manifest is available yet. In mock mode, use a few zero-config actions first.',
                            'info'
                        );
                        return;
                    }

                    manifestPre.textContent = JSON.stringify(manifest, null, 2);
                    manifestPre.classList.remove('hidden');
                    showResult('publish-result', 'Captured manifest loaded.', 'success');
                } catch (error) {
                    showResult('publish-result', formatError(error), 'error');
                }
            }

            async function handlePublishUrl() {
                hideElement(manifestPre);
                showResult('publish-result', 'Building publish URL...', 'info');

                try {
                    const url = learnCard.getPublishUrl?.();
                    publishLink.innerHTML = '';

                    if (!url) {
                        publishLink.classList.add('hidden');
                        showResult(
                            'publish-result',
                            'No publish URL yet. Mock mode needs enough captured surface area to make the manifest publishable.',
                            'info'
                        );
                        return;
                    }

                    const anchor = document.createElement('a');
                    anchor.href = url;
                    anchor.target = '_blank';
                    anchor.rel = 'noreferrer';
                    anchor.className = 'text-blue-600 underline break-all';
                    anchor.textContent = url;
                    publishLink.appendChild(anchor);
                    publishLink.classList.remove('hidden');

                    showResult('publish-result', 'Publish URL is ready.', 'success');
                } catch (error) {
                    showResult('publish-result', formatError(error), 'error');
                }
            }

            async function bootstrap() {
                const mocked = typeof learnCard.isMocked === 'function' && learnCard.isMocked();
                const embedded = typeof learnCard.isEmbedded === 'function' && learnCard.isEmbedded();

                if (mocked) {
                    setBanner('Standalone mock mode is active. Zero-config demos will still work and capture a publishable manifest.', 'info');
                } else if (embedded) {
                    setBanner('Embedded in LearnCard. Requesting identity if available...', 'info');
                } else {
                    setBanner('Running standalone without a LearnCard host. Some actions may return LC_NOT_EMBEDDED unless mock mode is active.', 'warning');
                }

                try {
                    await requestIdentityForSession('identity-result');
                } catch (error) {
                    showResult('identity-result', formatError(error), 'error');
                }

                try {
                    await refreshAllCounters();
                } catch {
                    renderCounters([]);
                }
            }

            window.addEventListener('load', () => {
                document
                    .getElementById('request-identity-btn')
                    ?.addEventListener('click', handleRequestIdentity);
                document
                    .getElementById('validate-template-btn')
                    ?.addEventListener('click', handleValidateTemplate);
                document
                    .getElementById('issue-cred-btn')
                    ?.addEventListener('click', handleIssueCredential);
                document
                    .getElementById('check-credential-btn')
                    ?.addEventListener('click', handleCheckCredentialStatus);
                document
                    .getElementById('check-issuance-btn')
                    ?.addEventListener('click', handleCheckIssuanceStatus);
                document
                    .getElementById('get-recipients-btn')
                    ?.addEventListener('click', handleGetTemplateRecipients);
                document
                    .getElementById('optional-boost-issuance-btn')
                    ?.addEventListener('click', handleOptionalBoostIssuance);
                document
                    .getElementById('optional-boost-recipients-btn')
                    ?.addEventListener('click', handleOptionalBoostRecipients);
                document
                    .getElementById('request-consent-btn')
                    ?.addEventListener('click', handleRequestConsent);
                document
                    .getElementById('launch-ai-btn')
                    ?.addEventListener('click', handleLaunchFeature);
                document
                    .getElementById('ask-cred-btn')
                    ?.addEventListener('click', handleAskCredential);
                document
                    .getElementById('ask-specific-cred-btn')
                    ?.addEventListener('click', handleAskSpecificCredential);
                document
                    .getElementById('initiate-template-issue-btn')
                    ?.addEventListener('click', handleInitiateTemplateIssue);
                document
                    .getElementById('learner-context-btn')
                    ?.addEventListener('click', handleLearnerContext);
                document
                    .getElementById('send-notif-btn')
                    ?.addEventListener('click', handleSendNotification);
                document
                    .getElementById('increment-counter-btn')
                    ?.addEventListener('click', handleIncrementCounter);
                document
                    .getElementById('get-counter-btn')
                    ?.addEventListener('click', handleGetCounter);
                document
                    .getElementById('get-all-counters-btn')
                    ?.addEventListener('click', handleGetAllCounters);
                document
                    .getElementById('captured-manifest-btn')
                    ?.addEventListener('click', handleCapturedManifest);
                document
                    .getElementById('publish-url-btn')
                    ?.addEventListener('click', handlePublishUrl);

                bootstrap().catch(error => {
                    setBanner(`Initialization failed: ${formatError(error)}`, 'error');
                });
            });
        </script>
    </body>
</html>
