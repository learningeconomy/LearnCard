---
// Server-side data (if needed for backend integration in the future)
const hostOriginEnv = import.meta.env.HOST_ORIGIN || 'https://learncard.app';
// Split by spaces to support multiple origins (e.g., "https://learncard.app https://staging.learncard.app")
const hostOrigin = hostOriginEnv.includes(' ') ? hostOriginEnv.split(/\s+/) : hostOriginEnv;

const config = {
    contractUri:
        import.meta.env.CONTRACT_URI ||
        'lc:network:network.learncard.com/trpc:contract:fc430a19-5f0d-46e2-95c5-15fa57f753c9',
    boostUri:
        import.meta.env.BOOST_URI ||
        'lc:network:network.learncard.com/trpc:boost:fbe30973-68b2-4a87-b0ac-80938ff382c4',
    templateAlias: import.meta.env.TEMPLATE_ALIAS || 'achievement',
    hostOrigin,
};
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>LC Partner Demo: Identity & Actions</title>
        <meta
            name="description"
            content="LearnCard App Store Partner Demo - SSO, Credential Issuance, Feature Launch, and Credential Requests"
        />

        <!-- Tailwind CSS is loaded via Astro integration -->
        <link rel="stylesheet" href="/src/styles/global.css" />
    </head>

    <body>
        <div id="app-container" class="card bg-white p-8 rounded-2xl shadow-2xl space-y-6">
            <h1 class="text-3xl font-extrabold text-gray-800">LearnCard Partner App Demo</h1>

            <!-- Status Indicator -->
            <div id="status-box" class="p-4 rounded-xl border-l-4 font-medium" role="alert">
                <p id="auth-status" class="text-gray-700">Initializing connection...</p>
            </div>

            <!-- Controls (Hidden until authenticated) -->
            <div id="controls" class="space-y-4 hidden">
                <p class="text-lg font-semibold text-indigo-700">Core Feature Demos:</p>

                <button
                    id="issue-cred-btn"
                    class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    1. Issue Credential (SDK: sendCredential + preventDuplicateClaim)
                </button>

                <button
                    id="check-credential-btn"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    2. Check Credential Status (SDK: checkUserHasCredential)
                </button>

                <button
                    id="check-issuance-btn"
                    class="w-full bg-indigo-500 hover:bg-indigo-600 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    2a. Check Issuance Status (SDK: getTemplateIssuanceStatus)
                </button>

                <button
                    id="get-recipients-btn"
                    class="w-full bg-indigo-400 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    2b. Get Template Recipients (SDK: getTemplateRecipients)
                </button>

                <button
                    id="arbitrary-boost-btn"
                    class="w-full bg-indigo-300 hover:bg-indigo-400 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    2c. Use Arbitrary Boost URI
                </button>

                <button
                    id="launch-ai-btn"
                    class="w-full bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    3. Launch AI Tutor (SDK: launchFeature)
                </button>

                <button
                    id="ask-cred-btn"
                    class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    4. Request Credential (SDK: askCredentialSearch)
                </button>

                <button
                    id="request-consent-btn"
                    class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    5. Request Consent (SDK: requestConsent)
                </button>

                <button
                    id="ask-specific-cred-btn"
                    class="w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    6. Request Specific Credential (SDK: askCredentialSpecific)
                </button>

                <button
                    id="initiate-template-issue-btn"
                    class="w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                >
                    7. Initiate Template Issue (SDK: initiateTemplateIssue)
                </button>

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- Notifications Section                              -->
                <!-- ═══════════════════════════════════════════════════ -->
                <hr class="border-gray-200 my-2" />
                <p class="text-lg font-semibold text-teal-700">App Notifications:</p>

                <div class="bg-teal-50 rounded-xl p-4 space-y-3 border border-teal-200">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Title</label>
                            <input
                                type="text"
                                id="notif-title"
                                value="Achievement Unlocked!"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            />
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Category</label>
                            <select
                                id="notif-category"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            >
                                <option value="reward">reward</option>
                                <option value="announcement">announcement</option>
                                <option value="status">status</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Body</label>
                        <input
                            type="text"
                            id="notif-body"
                            value="You earned the Gold Star badge"
                            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                        />
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Action Path</label>
                            <input
                                type="text"
                                id="notif-action-path"
                                value="/achievements"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            />
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Priority</label>
                            <select
                                id="notif-priority"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                            >
                                <option value="normal">normal</option>
                                <option value="high">high</option>
                            </select>
                        </div>
                    </div>

                    <button
                        id="send-notif-btn"
                        class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-xl transition duration-200 shadow-lg"
                    >
                        8. Send Notification (SDK: sendNotification)
                    </button>

                    <div id="notif-result" class="hidden text-sm p-3 rounded-lg"></div>
                </div>

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- Counters Section                                   -->
                <!-- ═══════════════════════════════════════════════════ -->
                <hr class="border-gray-200 my-2" />
                <p class="text-lg font-semibold text-amber-700">App Counters:</p>

                <div class="bg-amber-50 rounded-xl p-4 space-y-3 border border-amber-200">
                    <!-- Counter key + amount inputs -->
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Counter Key</label>
                            <input
                                type="text"
                                id="counter-key"
                                value="coins"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                            />
                        </div>

                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Amount</label>
                            <input
                                type="number"
                                id="counter-amount"
                                value="1"
                                step="1"
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500"
                            />
                        </div>
                    </div>

                    <!-- Action buttons row -->
                    <div class="grid grid-cols-3 gap-2">
                        <button
                            id="increment-counter-btn"
                            class="bg-amber-600 hover:bg-amber-700 text-white font-bold py-2.5 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            9. Increment
                        </button>

                        <button
                            id="get-counter-btn"
                            class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            10. Get Counter
                        </button>

                        <button
                            id="get-all-counters-btn"
                            class="bg-amber-400 hover:bg-amber-500 text-white font-bold py-2.5 rounded-xl transition duration-200 shadow-lg text-sm"
                        >
                            11. Get All
                        </button>
                    </div>

                    <!-- Live counter display -->
                    <div id="counter-display" class="bg-white rounded-lg p-3 border border-amber-200">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Counter Values</span>
                            <span id="counter-updated" class="text-xs text-gray-400"></span>
                        </div>

                        <div id="counter-values" class="space-y-1">
                            <p class="text-sm text-gray-400 italic">No counters loaded yet</p>
                        </div>
                    </div>

                    <!-- Result feedback -->
                    <div id="counter-result" class="hidden text-sm p-3 rounded-lg"></div>
                </div>
            </div>
        </div>

        <!-- Modal for Arbitrary Boost URI -->
        <div
            id="boost-modal"
            class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50"
        >
            <div class="bg-white rounded-2xl p-8 max-w-lg w-full mx-4 shadow-2xl">
                <h3 class="text-xl font-bold text-gray-800 mb-4">Query Boost by URI</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Boost URI</label
                        >
                        <input
                            type="text"
                            id="boost-uri-input"
                            placeholder="lc:network:network.learncard.com/trpc:boost:abc123"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                        />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Action</label>
                        <select
                            id="boost-action-select"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                        >
                            <option value="check-issuance">Check Issuance Status</option>
                            <option value="get-recipients">Get Recipients</option>
                        </select>
                    </div>

                    <div id="recipient-input-container">
                        <label class="block text-sm font-medium text-gray-700 mb-1"
                            >Recipient (Profile ID or DID)</label
                        >
                        <input
                            type="text"
                            id="recipient-input"
                            placeholder="user123 or did:web:network.learncard.com:users:user123"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                        />
                        <p class="text-xs text-gray-500 mt-1">
                            Leave empty to use your own profile
                        </p>
                    </div>
                </div>

                <div class="flex gap-3 mt-6">
                    <button
                        id="boost-modal-cancel"
                        class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition"
                    >
                        Cancel
                    </button>
                    <button
                        id="boost-modal-submit"
                        class="flex-1 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition"
                    >
                        Execute
                    </button>
                </div>
            </div>
        </div>

        <!-- Config variables for the module script -->
        <script define:vars={{ config }}>
            window.__LC_CONFIG = config;
        </script>

        <script>
            import { createPartnerConnect } from '@learncard/partner-connect';

            // --- CONFIGURATION ---
            // Initialize the LearnCard Partner Connect SDK
            const learnCard = createPartnerConnect({ hostOrigin: window.__LC_CONFIG.hostOrigin });

            // --- STATE & UTILITIES ---
            const statusBox = document.getElementById('status-box');
            const statusText = document.getElementById('auth-status');
            const controls = document.getElementById('controls');
            let lastIssuedCredentialId = null; // Track the last issued credential ID

            // Helper to update the status UI
            function updateStatus(message, type = 'info') {
                statusText.textContent = message;
                statusBox.className = 'p-4 rounded-xl border-l-4 font-medium'; // Reset classes

                if (type === 'success') {
                    statusBox.classList.add('bg-green-100', 'border-green-500', 'text-green-800');
                    controls.classList.remove('hidden');
                } else if (type === 'error') {
                    statusBox.classList.add('bg-red-100', 'border-red-500', 'text-red-800');
                    controls.classList.add('hidden');
                } else {
                    // info/loading
                    statusBox.classList.add(
                        'bg-indigo-100',
                        'border-indigo-500',
                        'text-indigo-800'
                    );
                }
            }

            // --- IMPLEMENTATION OF ACTIONS ---

            // A. SSO - Identity Request
            async function initiateSSO() {
                updateStatus(`Attempting LearnCard Single Sign-On...`);

                try {
                    const identity = await learnCard.requestIdentity();

                    // --- PARTNER BACKEND SIMULATION ---
                    // PARTNER ACTION: Send this token securely to your own backend (Astro endpoint)
                    console.log('RECEIVED JWT IDENTITY TOKEN:', identity.token);
                    // Your backend would validate the JWT, look up the user, and set a partner cookie here.
                    // If validation fails, your backend should fail, and the client should show an error.
                    // ---------------------------------

                    updateStatus(
                        `SSO Success! User ID received. Token passed to simulated backend.`,
                        'success'
                    );
                } catch (error) {
                    if (error.code === 'LC_UNAUTHENTICATED') {
                        // Host responded that user is not logged in to LearnCard
                        updateStatus(
                            'Please log into your LearnCard app to enable this partner application.',
                            'error'
                        );
                    } else {
                        updateStatus(
                            `SSO Error: ${
                                error.message || 'Unknown error during identity request.'
                            }`,
                            'error'
                        );
                    }
                }
            }

            // B. Issue Credential
            async function handleIssueCredential() {
                updateStatus(
                    'Issuing credential request. Waiting for user consent popup...',
                    'info'
                );

                try {
                    const response = await learnCard.sendCredential({
                        templateAlias: window.__LC_CONFIG.templateAlias,
                        templateData: {
                            issuedAt: new Date().toISOString(),
                        },
                        preventDuplicateClaim: true,
                    });

                    if (response.alreadyClaimed) {
                        updateStatus(
                            `Already earned! Existing credential: ${response.credentialUri}`,
                            'info'
                        );
                        return;
                    }

                    if (response.credentialId) {
                        lastIssuedCredentialId = response.credentialId;
                        updateStatus(
                            `Credential Issued! New ID: ${response.credentialId}`,
                            'success'
                        );
                        return;
                    }

                    updateStatus(`Credential Issued! URI: ${response.credentialUri}`, 'success');
                } catch (error) {
                    updateStatus(
                        `Issue Failed: ${error.message || 'User rejected credential.'}`,
                        'error'
                    );
                }
            }

            // C. Check Credential Status
            async function handleCheckCredentialStatus() {
                updateStatus('Checking credential status silently...', 'info');

                try {
                    const result = await learnCard.checkUserHasCredential({
                        templateAlias: window.__LC_CONFIG.templateAlias,
                    });

                    if (result.hasCredential) {
                        updateStatus(
                            `Already earned! Status: ${result.status} (${result.credentialUri})`,
                            'success'
                        );
                    } else if (result.status === 'revoked') {
                        updateStatus(
                            'Credential was previously issued but is now revoked.',
                            'error'
                        );
                    } else {
                        updateStatus(
                            'Not earned yet. Click "Issue Credential" to claim it.',
                            'info'
                        );
                    }
                } catch (error) {
                    updateStatus(
                        `Check Failed: ${error.message || 'Unable to check credential status.'}`,
                        'error'
                    );
                }
            }

            // C2. Check Template Issuance Status
            async function handleCheckIssuanceStatus() {
                updateStatus('Checking if you have issued this template to yourself...', 'info');

                try {
                    const identity = await learnCard.requestIdentity();
                    const result = await learnCard.getTemplateIssuanceStatus({
                        templateAlias: window.__LC_CONFIG.templateAlias,
                        recipient: identity.user.did,
                    });

                    if (result.sent) {
                        updateStatus(
                            `You issued this credential on ${new Date(
                                result.sentDate
                            ).toLocaleDateString()}. ` +
                                `Status: ${result.status}${
                                    result.claimedDate
                                        ? ' (claimed on ' +
                                          new Date(result.claimedDate).toLocaleDateString() +
                                          ')'
                                        : ' (pending)'
                                }`,
                            'success'
                        );
                    } else {
                        updateStatus(
                            'You have not issued this template to this recipient yet.',
                            'info'
                        );
                    }
                } catch (error) {
                    updateStatus(
                        `Issuance Check Failed: ${
                            error.message || 'Unable to check issuance status.'
                        }`,
                        'error'
                    );
                }
            }

            // C3. Get Template Recipients
            async function handleGetTemplateRecipients() {
                updateStatus('Fetching list of recipients for this template...', 'info');

                try {
                    const result = await learnCard.getTemplateRecipients({
                        templateAlias: window.__LC_CONFIG.templateAlias,
                        limit: 10,
                    });

                    if (result.records.length === 0) {
                        updateStatus('No recipients found for this template yet.', 'info');
                    } else {
                        const recipientList = result.records
                            .map(
                                r =>
                                    `${r.recipientDisplayName || r.recipientProfileId} (${
                                        r.status
                                    })`
                            )
                            .join(', ');
                        updateStatus(
                            `Found ${result.records.length} recipient(s): ${recipientList}${
                                result.hasMore ? '...' : ''
                            }`,
                            'success'
                        );
                    }
                } catch (error) {
                    updateStatus(
                        `Recipients Fetch Failed: ${
                            error.message || 'Unable to fetch recipients.'
                        }`,
                        'error'
                    );
                }
            }

            // C4. Use Arbitrary Boost URI - Modal-based UI
            const boostModal = document.getElementById('boost-modal');
            const boostUriInput = document.getElementById('boost-uri-input');
            const boostActionSelect = document.getElementById('boost-action-select');
            const recipientInput = document.getElementById('recipient-input');
            const recipientContainer = document.getElementById('recipient-input-container');
            const boostModalCancel = document.getElementById('boost-modal-cancel');
            const boostModalSubmit = document.getElementById('boost-modal-submit');

            function openBoostModal() {
                boostModal.classList.remove('hidden');
                boostModal.classList.add('flex');
                boostUriInput.focus();
            }

            function closeBoostModal() {
                boostModal.classList.add('hidden');
                boostModal.classList.remove('flex');
                boostUriInput.value = '';
                recipientInput.value = '';
            }

            boostActionSelect.addEventListener('change', () => {
                if (boostActionSelect.value === 'get-recipients') {
                    recipientContainer.classList.add('hidden');
                } else {
                    recipientContainer.classList.remove('hidden');
                }
            });

            boostModalCancel.addEventListener('click', closeBoostModal);

            boostModal.addEventListener('click', e => {
                if (e.target === boostModal) closeBoostModal();
            });

            async function handleBoostModalSubmit() {
                const boostUri = boostUriInput.value.trim();
                const action = boostActionSelect.value;
                let recipient = recipientInput.value.trim();

                if (!boostUri) {
                    updateStatus('Please enter a boost URI.', 'error');
                    return;
                }

                closeBoostModal();

                if (action === 'check-issuance') {
                    if (!recipient) {
                        const identity = await learnCard.requestIdentity();
                        recipient = identity.user.did;
                    }

                    updateStatus(`Checking issuance status for ${boostUri}...`, 'info');
                    try {
                        const result = await learnCard.getTemplateIssuanceStatus({
                            boostUri,
                            recipient,
                        });

                        if (result.sent) {
                            updateStatus(
                                `Credential sent on ${new Date(
                                    result.sentDate
                                ).toLocaleDateString()}. ` +
                                    `Status: ${result.status}${
                                        result.claimedDate ? ' (claimed)' : ' (pending)'
                                    }`,
                                'success'
                            );
                        } else {
                            updateStatus(
                                'No credential found for this boost and recipient.',
                                'info'
                            );
                        }
                    } catch (error) {
                        updateStatus(
                            `Check Failed: ${error.message || 'Error checking issuance status.'}`,
                            'error'
                        );
                    }
                } else if (action === 'get-recipients') {
                    updateStatus(`Fetching recipients for ${boostUri}...`, 'info');
                    try {
                        const result = await learnCard.getTemplateRecipients({
                            boostUri,
                            limit: 10,
                        });

                        if (result.records.length === 0) {
                            updateStatus('No recipients found for this boost.', 'info');
                        } else {
                            const recipientList = result.records
                                .map(
                                    r =>
                                        `${r.recipientDisplayName || r.recipientProfileId} (${
                                            r.status
                                        })`
                                )
                                .join(', ');
                            updateStatus(
                                `Found ${result.records.length} recipient(s): ${recipientList}${
                                    result.hasMore ? '...' : ''
                                }`,
                                'success'
                            );
                        }
                    } catch (error) {
                        updateStatus(
                            `Fetch Failed: ${error.message || 'Error fetching recipients.'}`,
                            'error'
                        );
                    }
                }
            }

            boostModalSubmit.addEventListener('click', handleBoostModalSubmit);

            function handleArbitraryBoostUri() {
                openBoostModal();
            }

            // D. Launch Feature
            async function handleLaunchFeature() {
                updateStatus('Requesting LearnCard Host to launch AI Tutor...');

                try {
                    await learnCard.launchFeature(
                        '/ai/topics?shortCircuitStep=newTopic&selectedAppId=null',
                        'Summarize the postMessage security model for me.'
                    );
                    updateStatus('AI Tutor launched in the main LearnCard window!', 'info');
                } catch (error) {
                    updateStatus(`Launch Failed: ${error.message}`, 'error');
                }
            }

            // E. Request Credential (Gated Content)
            async function handleAskCredential() {
                updateStatus(
                    'Requesting user to share a credential (searching for "Learning History"). Waiting for consent...',
                    'info'
                );

                try {
                    const response = await learnCard.askCredentialSearch({
                        query: [
                            {
                                type: 'QueryByTitle',
                                credentialQuery: {
                                    reason: 'We need to verify your teamwork skills',
                                    title: 'Capstone',
                                },
                            },
                        ],
                        challenge: `challenge-${Date.now()}-${Math.random()
                            .toString(36)
                            .substring(2, 9)}`,
                        domain: window.location.hostname,
                    });

                    console.log('VPR RESPONSE:', response);
                    if (response && response.verifiablePresentation) {
                        // Successfully received a signed Verifiable Presentation
                        const vp = response.verifiablePresentation;
                        const credCount = Array.isArray(vp.verifiableCredential)
                            ? vp.verifiableCredential.length
                            : 0;

                        console.log('RECEIVED VERIFIABLE PRESENTATION:', vp);
                        updateStatus(
                            `Success! User shared ${credCount} credential(s) in a signed VP. Gated content unlocked.`,
                            'success'
                        );
                    } else {
                        updateStatus('User declined to share the requested credential.', 'error');
                    }
                } catch (error) {
                    updateStatus(
                        `Request Failed: ${error.message || 'Error requesting credential.'}`,
                        'error'
                    );
                }
            }

            // F. Request Consent
            async function handleRequestConsent() {
                updateStatus(
                    'Requesting user consent for general permissions. Waiting for consent...',
                    'info'
                );

                try {
                    const response = await learnCard.requestConsent(window.__LC_CONFIG.contractUri);

                    console.log('CONSENT RESPONSE:', response);
                    if (response.granted) {
                        updateStatus(
                            'Consent granted! You can now access advanced features.',
                            'success'
                        );
                    } else {
                        updateStatus('Consent denied. Some features may be limited.', 'error');
                    }
                } catch (error) {
                    updateStatus(
                        `Consent Request Failed: ${error.message || 'Error requesting consent.'}`,
                        'error'
                    );
                }
            }

            // G. Request Specific Credential
            async function handleAskSpecificCredential() {
                updateStatus(
                    'Requesting a specific credential by ID. Waiting for user to share...',
                    'info'
                );

                // For demo purposes, use a placeholder credential ID
                // In a real app, you would know the ID from a previous interaction or database
                // Use the last issued credential ID if available, otherwise use a demo ID
                const defaultId = lastIssuedCredentialId || 'demo-credential-id-12345';
                const demoCredentialId = prompt(
                    'Enter a credential ID to request (or leave empty for the last issued credential):',
                    defaultId
                );

                if (!demoCredentialId) {
                    updateStatus('Credential request cancelled.', 'error');
                    return;
                }

                try {
                    const response = await learnCard.askCredentialSpecific(demoCredentialId);

                    console.log('RECEIVED SPECIFIC CREDENTIAL:', response);
                    if (response.credential) {
                        updateStatus(
                            `Success! Received credential: ${
                                response.credential.type?.join(', ') || 'Unknown type'
                            }`,
                            'success'
                        );
                    } else {
                        updateStatus('No credential returned.', 'error');
                    }
                } catch (error) {
                    if (error.code === 'CREDENTIAL_NOT_FOUND') {
                        updateStatus(`Credential not found: ${demoCredentialId}`, 'error');
                    } else if (error.code === 'USER_REJECTED') {
                        updateStatus('User declined to share the credential.', 'error');
                    } else {
                        updateStatus(
                            `Request Failed: ${
                                error.message || 'Error requesting specific credential.'
                            }`,
                            'error'
                        );
                    }
                }
            }

            // H. Initiate Template Issue (Boost)
            async function handleInitiateTemplateIssue() {
                updateStatus('Initiating template issue flow. Opening Send Boost modal...', 'info');

                // For demo purposes, prompt for template ID
                // In a real app, you would know the template ID from your system
                const templateId = prompt(
                    'Enter a template/boost ID to issue:',
                    window.__LC_CONFIG.boostUri
                );

                if (!templateId) {
                    updateStatus('Template issue cancelled.', 'error');
                    return;
                }

                // Optional: prompt for draft recipients
                const recipientsInput = prompt(
                    'Enter draft recipients (comma-separated DIDs, or leave empty):',
                    ''
                );

                const draftRecipients = recipientsInput
                    ? recipientsInput
                          .split(',')
                          .map(did => did.trim())
                          .filter(Boolean)
                    : [];

                try {
                    const response = await learnCard.initiateTemplateIssue(
                        templateId,
                        draftRecipients
                    );

                    console.log('TEMPLATE ISSUE RESPONSE:', response);

                    if (response.issued) {
                        updateStatus(
                            'Template issued successfully! User completed the boost send.',
                            'success'
                        );
                    } else {
                        updateStatus('User cancelled the boost send flow.', 'info');
                    }
                } catch (error) {
                    if (error.code === 'UNAUTHORIZED') {
                        updateStatus(
                            'Unauthorized: You are not an admin of this template.',
                            'error'
                        );
                    } else if (error.code === 'TEMPLATE_NOT_FOUND') {
                        updateStatus(`Template not found: ${templateId}`, 'error');
                    } else {
                        updateStatus(
                            `Template Issue Failed: ${
                                error.message || 'Error initiating template issue.'
                            }`,
                            'error'
                        );
                    }
                }
            }

            // ==================== NOTIFICATIONS ====================

            // Inline feedback helper for section-specific result divs
            function showResult(elementId, message, type) {
                const el = document.getElementById(elementId);
                el.classList.remove('hidden', 'bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800', 'bg-blue-100', 'text-blue-800');

                if (type === 'success') {
                    el.classList.add('bg-green-100', 'text-green-800');
                } else if (type === 'error') {
                    el.classList.add('bg-red-100', 'text-red-800');
                } else {
                    el.classList.add('bg-blue-100', 'text-blue-800');
                }

                el.textContent = message;
            }

            // I. Send Notification
            async function handleSendNotification() {
                const title = document.getElementById('notif-title').value.trim();
                const body = document.getElementById('notif-body').value.trim();
                const actionPath = document.getElementById('notif-action-path').value.trim();
                const category = document.getElementById('notif-category').value;
                const priority = document.getElementById('notif-priority').value;

                if (!title && !body) {
                    showResult('notif-result', 'Please provide at least a title or body.', 'error');
                    return;
                }

                showResult('notif-result', 'Sending notification...', 'info');

                try {
                    const result = await learnCard.sendNotification({
                        title: title || undefined,
                        body: body || undefined,
                        actionPath: actionPath || undefined,
                        category: category || undefined,
                        priority,
                    });

                    console.log('NOTIFICATION RESULT:', result);

                    if (result.sent) {
                        showResult('notif-result', `Notification sent! Check your LearnCard inbox.`, 'success');
                    } else {
                        showResult('notif-result', 'Notification was not sent.', 'error');
                    }
                } catch (error) {
                    console.error('Notification error:', error);
                    showResult('notif-result', `Failed: ${error.message || 'Unknown error'}`, 'error');
                }
            }

            // ==================== COUNTERS ====================

            // Render counter values into the display panel
            function renderCounters(counters) {
                const container = document.getElementById('counter-values');
                const timestamp = document.getElementById('counter-updated');

                if (!counters || counters.length === 0) {
                    container.innerHTML = '<p class="text-sm text-gray-400 italic">No counters found</p>';
                    timestamp.textContent = '';
                    return;
                }

                container.innerHTML = counters
                    .map(c => {
                        const time = c.updatedAt ? new Date(c.updatedAt).toLocaleTimeString() : 'never';
                        return `
                            <div class="flex items-center justify-between py-1.5 px-2 rounded-md hover:bg-amber-50 transition">
                                <span class="font-mono text-sm font-semibold text-gray-700">${c.key}</span>
                                <div class="flex items-center gap-3">
                                    <span class="text-lg font-bold text-amber-700">${c.value}</span>
                                    <span class="text-xs text-gray-400">${time}</span>
                                </div>
                            </div>
                        `;
                    })
                    .join('');

                timestamp.textContent = `Updated ${new Date().toLocaleTimeString()}`;
            }

            // J. Increment Counter
            async function handleIncrementCounter() {
                const key = document.getElementById('counter-key').value.trim();
                const amount = parseInt(document.getElementById('counter-amount').value, 10);

                if (!key) {
                    showResult('counter-result', 'Please enter a counter key.', 'error');
                    return;
                }

                if (isNaN(amount) || amount === 0 || !Number.isInteger(amount)) {
                    showResult('counter-result', 'Amount must be a non-zero integer.', 'error');
                    return;
                }

                showResult('counter-result', `Incrementing "${key}" by ${amount}...`, 'info');

                try {
                    const result = await learnCard.incrementCounter(key, amount);

                    console.log('INCREMENT RESULT:', result);

                    const direction = amount > 0 ? '+' : '';
                    showResult(
                        'counter-result',
                        `${result.key}: ${result.previousValue} → ${result.newValue} (${direction}${amount})`,
                        'success'
                    );

                    // Refresh the display with all counters
                    await refreshAllCounters();
                } catch (error) {
                    console.error('Increment error:', error);
                    showResult('counter-result', `Failed: ${error.message || 'Unknown error'}`, 'error');
                }
            }

            // K. Get Single Counter
            async function handleGetCounter() {
                const key = document.getElementById('counter-key').value.trim();

                if (!key) {
                    showResult('counter-result', 'Please enter a counter key.', 'error');
                    return;
                }

                showResult('counter-result', `Reading "${key}"...`, 'info');

                try {
                    const result = await learnCard.getCounter(key);

                    console.log('GET COUNTER RESULT:', result);

                    showResult(
                        'counter-result',
                        `${result.key} = ${result.value}${result.updatedAt ? ` (last updated ${new Date(result.updatedAt).toLocaleString()})` : ''}`,
                        'success'
                    );

                    // Also refresh display
                    await refreshAllCounters();
                } catch (error) {
                    console.error('Get counter error:', error);
                    showResult('counter-result', `Failed: ${error.message || 'Unknown error'}`, 'error');
                }
            }

            // L. Get All Counters
            async function refreshAllCounters() {
                try {
                    const result = await learnCard.getCounters();

                    console.log('GET ALL COUNTERS RESULT:', result);

                    renderCounters(result.counters);
                } catch (error) {
                    console.error('Get all counters error:', error);
                    renderCounters([]);
                }
            }

            async function handleGetAllCounters() {
                showResult('counter-result', 'Loading all counters...', 'info');

                try {
                    const result = await learnCard.getCounters();

                    console.log('GET ALL COUNTERS RESULT:', result);

                    renderCounters(result.counters);

                    const count = result.counters.length;
                    showResult(
                        'counter-result',
                        `Found ${count} counter${count !== 1 ? 's' : ''}`,
                        count > 0 ? 'success' : 'info'
                    );
                } catch (error) {
                    console.error('Get all counters error:', error);
                    showResult('counter-result', `Failed: ${error.message || 'Unknown error'}`, 'error');
                }
            }

            // --- INITIALIZATION ---
            window.onload = function () {
                // Attach event listeners to the buttons
                document
                    .getElementById('issue-cred-btn')
                    .addEventListener('click', handleIssueCredential);
                document
                    .getElementById('check-credential-btn')
                    .addEventListener('click', handleCheckCredentialStatus);
                document
                    .getElementById('check-issuance-btn')
                    ?.addEventListener('click', handleCheckIssuanceStatus);
                document
                    .getElementById('get-recipients-btn')
                    ?.addEventListener('click', handleGetTemplateRecipients);
                document
                    .getElementById('arbitrary-boost-btn')
                    ?.addEventListener('click', handleArbitraryBoostUri);
                document
                    .getElementById('launch-ai-btn')
                    .addEventListener('click', handleLaunchFeature);
                document
                    .getElementById('ask-cred-btn')
                    .addEventListener('click', handleAskCredential);
                document
                    .getElementById('request-consent-btn')
                    .addEventListener('click', handleRequestConsent);
                document
                    .getElementById('ask-specific-cred-btn')
                    .addEventListener('click', handleAskSpecificCredential);
                document
                    .getElementById('initiate-template-issue-btn')
                    .addEventListener('click', handleInitiateTemplateIssue);

                // Notifications
                document
                    .getElementById('send-notif-btn')
                    ?.addEventListener('click', handleSendNotification);

                // Counters
                document
                    .getElementById('increment-counter-btn')
                    ?.addEventListener('click', handleIncrementCounter);
                document
                    .getElementById('get-counter-btn')
                    ?.addEventListener('click', handleGetCounter);
                document
                    .getElementById('get-all-counters-btn')
                    ?.addEventListener('click', handleGetAllCounters);

                // Begin the SSO flow immediately when the app loads
                initiateSSO();
            };
        </script>
    </body>
</html>
