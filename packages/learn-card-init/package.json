{
    "name": "@learncard/init",
    "version": "2.4.0",
    "description": "Primary initialization of LearnCard SDK",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/init.esm.js",
    "exports": {
        ".": {
            "node": {
                "import": {
                    "types": "./dist/index.d.ts",
                    "default": "./dist/node-esm.mjs"
                },
                "require": {
                    "types": "./dist/index.d.cts",
                    "default": "./dist/index.cjs"
                }
            },
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/init.esm.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./dist/init.esm.js": {
            "types": "./dist/index.d.ts",
            "default": "./dist/init.esm.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ./scripts/build.mjs && shx cp ./scripts/mixedEntypoint.js ./dist/index.cjs && tsc --p tsconfig.build.json && shx cp ./dist/index.d.ts ./dist/index.d.cts",
        "start": "aqu watch",
        "lint": "aqu lint",
        "lint:fix": "aqu lint --fix",
        "test": "vitest"
    },
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "homepage": "https://github.com/learningeconomy/LearnCard/tree/main/packages/learn-card-init/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/learningeconomy/LearnCard"
    },
    "bugs": {
        "url": "https://github.com/learningeconomy/LearnCard/issues"
    },
    "devDependencies": {
        "@types/jest": "^29.2.2",
        "@types/node": "^17.0.31",
        "aqu": "0.4.3",
        "esbuild": "^0.27.1",
        "esbuild-jest": "^0.5.0",
        "esbuild-plugin-copy": "^1.3.0",
        "jest": "^29.3.0",
        "jest-resolver-enhanced": "^1.1.0",
        "jimp": "^0.16.1",
        "qrcode-reader": "^1.0.4",
        "shx": "^0.3.4",
        "ts-jest": "^29.0.3"
    },
    "types": "./dist/index.d.ts",
    "dependencies": {
        "@learncard/chapi-plugin": "workspace:*",
        "@learncard/core": "workspace:*",
        "@learncard/crypto-plugin": "workspace:*",
        "@learncard/didkey-plugin": "workspace:*",
        "@learncard/didkit-plugin": "workspace:*",
        "@learncard/did-web-plugin": "workspace:*",
        "@learncard/dynamic-loader-plugin": "workspace:*",
        "@learncard/encryption-plugin": "workspace:*",
        "@learncard/ethereum-plugin": "workspace:*",
        "@learncard/expiration-plugin": "workspace:*",
        "@learncard/helpers": "workspace:*",
        "@learncard/learn-card-plugin": "workspace:*",
        "@learncard/learn-cloud-plugin": "workspace:*",
        "@learncard/network-plugin": "workspace:^",
        "@learncard/openid4vc-plugin": "workspace:*",
        "@learncard/sd-jwt-vc-plugin": "workspace:*",
        "@learncard/types": "workspace:*",
        "@learncard/vc-api-plugin": "workspace:*",
        "@learncard/vc-plugin": "workspace:*",
        "@learncard/vc-templates-plugin": "workspace:*",
        "@learncard/vpqr-plugin": "workspace:*"
    },
    "optionalDependencies": {
        "@learncard/didkit-plugin-node": "workspace:*"
    },
    "sideEffects": false
}
