{
    "name": "@learncard/types",
    "version": "5.17.0",
    "description": "Shared types for learn card",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/types.esm.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/types.esm.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ./scripts/build.mjs && shx cp ./scripts/mixedEntypoint.js ./dist/index.cjs && tsc --p tsconfig.json && shx cp ./dist/index.d.ts ./dist/index.d.cts",
        "start": "aqu watch"
    },
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "homepage": "https://github.com/learningeconomy/LearnCard/tree/main/packages/learn-card-types/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/learningeconomy/LearnCard"
    },
    "bugs": {
        "url": "https://github.com/learningeconomy/LearnCard/issues"
    },
    "devDependencies": {
        "@esbuild-plugins/node-resolve": "^0.2.2",
        "@size-limit/preset-small-lib": "^7.0.8",
        "@types/node": "^17.0.38",
        "aqu": "0.4.3",
        "esbuild": "^0.27.1",
        "husky": "^8.0.1",
        "lint-staged": "^13.0.0",
        "np": "^7.6.1",
        "size-limit": "^7.0.8",
        "typescript": "5.6.2"
    },
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "size-limit": [
        {
            "path": "dist/types.cjs.production.min.js",
            "limit": "10 KB"
        },
        {
            "path": "dist/types.esm.js",
            "limit": "10 KB"
        }
    ]
}
