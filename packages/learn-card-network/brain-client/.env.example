# Neo4j Database Configuration
# Get credentials from Neo4j Aura console or your database admin
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
AURA_INSTANCENAME=your-instance-name

# LearnCard SEED - Generate a secure 64-character hex string
# WARNING: This controls access to your LearnCard identity
SEED=your-64-character-hex-seed-here
