{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "lib": ["dom", "es2021", "es2022.error"],
        "noLib": false,
        "rootDir": "src",
        "skipLibCheck": true,
        "paths": {},
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "bundler"
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
