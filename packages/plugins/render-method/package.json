{
    "name": "@learncard/render-method-plugin",
    "version": "2.0.0",
    "description": "LearnCard plugin for attaching W3C renderMethod to Verifiable Credentials",
    "main": "./dist/index.js",
    "module": "./dist/render-method-plugin.esm.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "module": "./dist/render-method-plugin.esm.js",
            "import": "./dist/render-method-plugin.esm.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ./scripts/build.mjs && shx cp ./scripts/mixedEntrypoint.js ./dist/index.js && tsc --p tsconfig.json",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --silent --ci --coverage --coverageReporters=\"text\" --coverageReporters=\"text-summary\""
    },
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "homepage": "https://github.com/learningeconomy/LearnCard/tree/main/packages/plugins/render-method/README.md",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/learningeconomy/LearnCard.git"
    },
    "bugs": {
        "url": "https://github.com/learningeconomy/LearnCard/issues"
    },
    "devDependencies": {
        "@learncard/core": "workspace:*",
        "@learncard/helpers": "workspace:*",
        "@learncard/types": "workspace:*",
        "@types/jest": "^29.2.2",
        "@types/node": "^17.0.31",
        "aqu": "0.4.3",
        "esbuild": "^0.14.38",
        "esbuild-jest": "^0.5.0",
        "esbuild-plugin-copy": "^1.3.0",
        "jest": "^29.3.0",
        "rimraf": "^3.0.2",
        "shx": "^0.3.4",
        "ts-jest": "^29.0.3"
    },
    "peerDependencies": {
        "@learncard/core": "workspace:*",
        "@learncard/helpers": "workspace:*",
        "@learncard/types": "workspace:*"
    },
    "dependencies": {
        "@learncard/helpers": "workspace:*"
    },
    "types": "./dist/index.d.ts",
    "sideEffects": false
}
