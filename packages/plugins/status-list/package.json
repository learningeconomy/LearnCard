    },
    "devDependencies": {
        "@learncard/types": "workspace:*",
        "@types/jest": "^29.2.2",
        "@types/node": "^17.0.31",
        "esbuild": "^0.27.1",
        "esbuild-jest": "^0.5.0",
        "jest": "^29.3.0",
        "shx": "^0.3.4",
        "ts-jest": "^29.0.3"
    },
