{
    "name": "@learncard/openid4vc-plugin",
    "version": "0.1.0",
    "description": "OpenID for Verifiable Credentials (OID4VCI + OID4VP + SIOPv2) holder support for LearnCard",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/openid4vc-plugin.esm.js",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/openid4vc-plugin.esm.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node ./scripts/build.mjs && shx cp ./scripts/mixedEntypoint.js ./dist/index.cjs && tsc --p tsconfig.json && shx cp ./dist/index.d.ts ./dist/index.d.cts",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --silent --ci --coverage --coverageReporters=\"text\" --coverageReporters=\"text-summary\"",
        "try-offer": "tsx ./scripts/try-offer.ts",
        "try-verify": "tsx ./scripts/try-verify.ts"
    },
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "homepage": "https://github.com/learningeconomy/LearnCard/tree/main/packages/plugins/openid4vc/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/learningeconomy/LearnCard"
    },
    "bugs": {
        "url": "https://github.com/learningeconomy/LearnCard/issues"
    },
    "devDependencies": {
        "@learncard/types": "workspace:*",
        "@types/jest": "^29.2.2",
        "@types/node": "^17.0.31",
        "aqu": "0.4.3",
        "esbuild": "^0.27.1",
        "esbuild-jest": "^0.5.0",
        "esbuild-plugin-copy": "^1.3.0",
        "jest": "^29.3.0",
        "shx": "^0.3.4",
        "ts-jest": "^29.0.3",
        "tsx": "^4.20.6"
    },
    "types": "./dist/index.d.ts",
    "dependencies": {
        "@learncard/core": "workspace:*",
        "@learncard/didkit-plugin": "workspace:^",
        "@learncard/vc-plugin": "workspace:^",
        "@peculiar/x509": "^1.12.0",
        "dcql": "^3.0.0",
        "jose": "^5.9.6",
        "safe-regex": "^2.1.1"
    },
    "sideEffects": false
}
