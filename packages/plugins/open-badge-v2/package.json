{
    "name": "@learncard/open-badge-v2-plugin",
    "version": "1.1.28",
    "description": "OpenBadge v2 wrapper plugin for LearnCard. Wraps OBv2 assertions into self-issued VCs.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/open-badge-v2-plugin.esm.js",
    "exports": {
        ".": {
            "development": "./src/index.ts",
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/open-badge-v2-plugin.esm.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "node ./scripts/build.mjs && shx cp ./scripts/mixedEntypoint.js ./dist/index.cjs && tsc --p tsconfig.json && shx cp ./dist/index.d.ts ./dist/index.d.cts",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:coverage": "jest --silent --ci --coverage --coverageReporters=\"text\" --coverageReporters=\"text-summary\""
    },
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "homepage": "https://github.com/learningeconomy/LearnCard/tree/main/packages/plugins/open-badge-v2/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/learningeconomy/LearnCard"
    },
    "bugs": {
        "url": "https://github.com/learningeconomy/LearnCard/issues"
    },
    "devDependencies": {
        "@types/jest": "^29.2.2",
        "@types/node": "^17.0.31",
        "aqu": "0.4.3",
        "esbuild": "^0.27.1",
        "esbuild-jest": "^0.5.0",
        "esbuild-plugin-copy": "^1.3.0",
        "jest": "^29.3.0",
        "shx": "^0.3.4",
        "ts-jest": "^29.0.3"
    },
    "types": "./dist/index.d.ts",
    "dependencies": {
        "@learncard/core": "workspace:*",
        "@learncard/crypto-plugin": "workspace:*",
        "@learncard/vc-plugin": "workspace:*",
        "@learncard/types": "workspace:*"
    },
    "sideEffects": false
}
