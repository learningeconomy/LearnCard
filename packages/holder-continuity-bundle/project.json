{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "holder-continuity",
    "sourceRoot": "packages/holder-continuity-bundle/src",
    "projectType": "library",
    "root": "packages/holder-continuity-bundle",
    "tags": [],
    "implicitDependencies": ["init", "types", "sss-key-manager"],
    "namedInputs": {
        "scripts": ["{projectRoot}/scripts/**/*"],
        "source": ["{projectRoot}/src/**/*"],
        "dist": ["{projectRoot}/dist/**/*"]
    },
    "targets": {
        "build": {
            "executor": "nx:run-script",
            "inputs": ["source", "scripts"],
            "options": {
                "script": "build"
            }
        },
        "test": {
            "executor": "nx:run-script",
            "options": {
                "script": "test"
            }
        }
    }
}
