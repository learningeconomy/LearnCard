source "https://rubygems.org"

gem "fastlane", "~> 2.226"
gem "cocoapods", "~> 1.16"
gem "xcodeproj", "~> 1.25"

# fastlane's Google/App Store Connect gems (google-apis-core) `require 'multi_json'`
# at runtime but don't always declare it as a dependency. Without it explicitly in
# the bundle, a fresh `bundle install` can resolve a graph where multi_json is loaded
# but not bundled, causing: "multi_json is not part of the bundle (Gem::LoadError)".
gem "multi_json"

plugins_path = File.join(File.dirname(__FILE__), 'fastlane', 'Pluginfile')
eval_gemfile(plugins_path) if File.exist?(plugins_path)
