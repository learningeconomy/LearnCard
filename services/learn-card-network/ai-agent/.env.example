# AI Agent Service
PORT=4300
AI_AGENT_MODEL=gpt-5.5

# Optional for local boot. Chat endpoints return 503 until this is set.
OPENAI_API_KEY=

# Required for Mongo-backed persistence encryption and LearnCard wallet tools.
# Mongo persistence uses this wallet's DIDKit DAG-JWE methods; do not configure raw AES keys.
SEED=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
AI_AGENT_CLOUD_URL=
AI_AGENT_NETWORK_URL=
AI_AGENT_CONSENT_FLOW_APP_URL=http://localhost:3000
AI_AGENT_CONSENT_FLOW_CONTRACT_URI=

# DID Auth and debug endpoints
AI_AGENT_AUTH_DOMAIN=http://localhost:4300
AI_AGENT_AUTH_CHALLENGE_TTL_MS=300000
# Number of trusted reverse-proxy hops used to resolve client IPs for rate limiting.
AI_AGENT_TRUST_PROXY_HOPS=0
AI_AGENT_ENCRYPTION_KEY_ID=agent-learncard-dag-jwe-v1
AI_AGENT_DEBUG_ENABLED=true
# Sent as X-AI-Agent-Debug-Token for debug endpoints.
AI_AGENT_DEBUG_TOKEN=

# MongoDB. Leave blank to boot local/dev without persistence when no wallet seed is configured.
AI_AGENT_MONGO_URI=
AI_AGENT_MONGO_DB_NAME=learn-card-ai-agent

# Per-user self-improvement. Enabled by default outside NODE_ENV=production.
AI_AGENT_SELF_IMPROVEMENT_ENABLED=true
AI_AGENT_RETRO_MODEL=
AI_AGENT_RETRO_MAX_TRACE_CHARS=24000

# Development-only autonomous schedule worker. The worker is a separate process and never starts
# with the HTTP service. Set AI_AGENT_AUTONOMY_DEV_DIDS to the exact DID(s) whose due schedules
# may run locally.
AI_AGENT_AUTONOMY_DEV_ENABLED=false
AI_AGENT_AUTONOMY_DEV_DIDS=
AI_AGENT_AUTONOMY_DEV_POLL_INTERVAL_MS=30000
AI_AGENT_AUTONOMY_DEV_MAX_RUNS_PER_CYCLE=3
AI_AGENT_AUTONOMY_DEV_LEASE_MS=900000

# Development-only Trigger.dev scheduler. The HTTP service needs the DEV secret to synchronize
# Assistant schedule CRUD; `trigger:dev` runs the registered dispatch/execution tasks.
# Do not enable this together with AI_AGENT_AUTONOMY_DEV_ENABLED.
AI_AGENT_TRIGGER_ENABLED=false
AI_AGENT_TRIGGER_ENVIRONMENT=dev
TRIGGER_SECRET_KEY=

# Current-info web search. If provider is unset and BRAVE_SEARCH_API_KEY is present, Brave is enabled.
AI_AGENT_WEB_SEARCH_PROVIDER=none
BRAVE_SEARCH_API_KEY=
AI_AGENT_WEB_SEARCH_DEFAULT_LIMIT=5
AI_AGENT_WEB_SEARCH_MAX_LIMIT=10
AI_AGENT_WEB_SEARCH_COUNTRY=US
AI_AGENT_WEB_SEARCH_LANG=en
AI_AGENT_WEB_SEARCH_SAFESEARCH=moderate
