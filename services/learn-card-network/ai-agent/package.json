{
    "name": "@learncard/ai-agent-service",
    "version": "0.0.1",
    "private": true,
    "description": "Prototype LearnCard AI agent service with a debug chat UI.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "shx rm -rf dist && node esbuild.mjs && tsc --p tsconfig.build.json",
        "dev": "nodemon --watch src --watch public -e ts,js,html,css --exec \"pnpm build && node dist/index.js\"",
        "dev:prod": "nodemon --watch src --watch public -e ts,js,html,css --exec \"pnpm build && node dist/index.js\"",
        "start": "node dist/index.js",
        "test": "vitest"
    },
    "keywords": [],
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "dependencies": {
        "@learncard/didkit-plugin": "workspace:*",
        "@learncard/didkit-plugin-node": "workspace:*",
        "@learncard/init": "workspace:*",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "mongodb": "^6.2.0",
        "openai": "^4.55.7",
        "zod": "4.1.13"
    },
    "devDependencies": {
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.15",
        "@types/node": "^18.0.0",
        "esbuild": "^0.27.1",
        "nodemon": "3.1.14",
        "shx": "^0.3.4",
        "vitest": "^1.4.0"
    },
    "repository": {
        "type": "git",
