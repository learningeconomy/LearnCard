# The 64-char hex seed that derives this service's single did:key issuer identity.
# This DID must match the `issuers[].id` in the W3C test-suite manifests.
SEED=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Local dev port for `bun run start` / `bun run dev`
PORT=3000

# Optional deploy overrides (defaults target vc-api.learncard.com in serverless.yml)
# SERVERLESS_SERVICE_NAME=
# SERVERLESS_DOMAIN_NAME=
# SERVERLESS_HOSTED_ZONE_NAMES=
