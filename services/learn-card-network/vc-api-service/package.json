{
    "name": "@learncard/vc-api-service",
    "version": "1.0.0",
    "private": true,
    "description": "Stateless W3C VC-API conformance issuer/verifier service (used by the W3C/CCG interoperability test suites, e.g. canivc.com).",
    "main": "dist/index.js",
    "scripts": {
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "build": "shx rm -rf dist && node esbuild.mjs",
        "build:docker": "shx rm -rf dist && node esbuild.mjs",
        "dev": "bun --watch src/index.ts",
        "start": "bun src/index.ts",
        "start:docker": "bun src/index.ts",
        "serverless-deploy": "COREPACK_ENABLE_PROJECT_SPEC=0 serverless deploy --verbose"
    },
    "keywords": [],
    "author": "Learning Economy Foundation (www.learningeconomy.io)",
    "license": "MIT",
    "devDependencies": {
        "@types/aws-lambda": "^8.10.106",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.15",
        "@types/node": "^18.0.0",
        "esbuild": "^0.27.1",
        "serverless": "3.40.0",
        "serverless-certificate-creator": "1.6.0",
        "serverless-domain-manager": "6.3.1",
        "serverless-esbuild": "1.55.0",
        "serverless-http": "3.2.0",
        "serverless-offline": "^14.4.0",
        "shx": "^0.3.4"
    },
    "dependencies": {
        "@learncard/core": "workspace:*",
        "@learncard/crypto-plugin": "workspace:*",
        "@learncard/didkey-plugin": "workspace:*",
        "@learncard/didkit-plugin": "workspace:*",
        "@learncard/dynamic-loader-plugin": "workspace:*",
        "@learncard/encryption-plugin": "workspace:*",
        "@learncard/expiration-plugin": "workspace:*",
        "@learncard/learn-card-plugin": "workspace:*",
        "@learncard/types": "workspace:*",
        "@learncard/vc-plugin": "workspace:*",
        "@learncard/vc-templates-plugin": "workspace:*",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "libsodium-wrappers": "^0.7.11",
        "serverless-http": "3.2.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/learningeconomy/LearnCard"
    },
    "homepage": "https://github.com/learningeconomy/LearnCard/tree/main/services/learn-card-network/vc-api-service/README.md",
    "bugs": {
        "url": "https://github.com/learningeconomy/LearnCard/issues"
    }
}
