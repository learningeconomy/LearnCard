# =============================================================================
# LCA API Service — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
SEED=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
DOMAIN_NAME=
AUTHORIZED_DIDS=false

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=test

# ---------------------------------------------------------------------------
# Email Delivery (Postmark)
# ---------------------------------------------------------------------------
# Postmark API key. If unset, email delivery falls back to console logging.
POSTMARK_SERVER_TOKEN=
# Default "From" email address
POSTMARK_FROM_EMAIL=noreply@example.com
# Brand name used in email copy
POSTMARK_BRAND_NAME=LearnCard
# Template alias for login verification OTP emails
POSTMARK_LOGIN_CODE_TEMPLATE_ALIAS=
# Template alias for endorsement request emails
POSTMARK_ENDORSEMENT_REQUEST_TEMPLATE_ALIAS=
# (Optional) Template alias for recovery email verification codes. Falls back to plain-text if unset.
# Template model: verificationCode, verificationEmail
POSTMARK_RECOVERY_EMAIL_CODE_TEMPLATE_ALIAS=
# (Optional) Template alias for recovery key backup emails. Falls back to plain-text if unset.
# Template model: brandName, recoveryKey
POSTMARK_RECOVERY_KEY_TEMPLATE_ALIAS=

# ---------------------------------------------------------------------------
# Firebase (Auth token verification)
# ---------------------------------------------------------------------------
# Firebase Admin SDK service account JSON (stringified)
GOOGLE_APPLICATION_CREDENTIAL=

# ---------------------------------------------------------------------------
# External Services
# ---------------------------------------------------------------------------
OPENAI_API_KEY=some_string
METABASE_SECRET_KEY=some_string
# Scouts SSO client secret
SCOUTS_SSO_CLIENT_SECRET=
# LearnCloud service URL
LEARN_CLOUD_URL=

# ---------------------------------------------------------------------------
# Monitoring (Optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENV=development